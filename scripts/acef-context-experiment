#!/usr/bin/env node
const fs = require("node:fs");
const path = require("node:path");
const cp = require("node:child_process");
const crypto = require("node:crypto");

const repoRoot = path.basename(path.dirname(__dirname)) === ".acef"
  ? path.resolve(__dirname, "..", "..")
  : path.resolve(__dirname, "..");
const acefQuery = path.join(__dirname, "acef-query");

function usage() {
  console.log(`ACEF context experiment

Usage:
  acef-context-experiment --repo <path> --story <id> --role <role> --task-type <review|atdd|dev> --mode <baseline|files|context-mode> [options]

Options:
  --runs <n>                Number of records to append (default: 1)
  --fixture <path>          Task fixture markdown to include in every mode
  --output <path>           JSONL output path (default: docs/experiments/context-retrieval/runs/<date>.jsonl)
  --result <pass|fail|invalid>  Recorded result label (default: invalid)
  --tests-passed <true|false>   Recorded test status (default: false)
  --extra-file-reads <n>    Manually recorded extra file reads (default: 0)
  --tool-calls <n>          Manually recorded tool calls (default: 0)
  --retry-count <n>         Manually recorded retries (default: 0)
  --known-findings-recalled <n> Manually recorded known finding recall count (default: 0)
  --review-findings-count <n>   Manually recorded review finding count (default: 0)
  --false-positive-count <n>    Manually recorded false positive count (default: 0)

This harness measures context surface and records quality fields. It does not satisfy ACEF gates.`);
}

function parseArgs(argv) {
  const opts = {
    repo: "",
    story: "",
    role: "",
    taskType: "",
    mode: "",
    runs: 1,
    fixture: "",
    output: "",
    result: "invalid",
    testsPassed: false,
    extraFileReads: 0,
    toolCalls: 0,
    retryCount: 0,
    knownFindingsRecalled: 0,
    reviewFindingsCount: 0,
    falsePositiveCount: 0,
  };
  for (let index = 0; index < argv.length; index += 1) {
    const arg = argv[index];
    if (arg === "--repo") opts.repo = argv[++index] || "";
    else if (arg === "--story") opts.story = argv[++index] || "";
    else if (arg === "--role") opts.role = argv[++index] || "";
    else if (arg === "--task-type") opts.taskType = argv[++index] || "";
    else if (arg === "--mode") opts.mode = argv[++index] || "";
    else if (arg === "--runs") opts.runs = Number(argv[++index]);
    else if (arg === "--fixture") opts.fixture = argv[++index] || "";
    else if (arg === "--output") opts.output = argv[++index] || "";
    else if (arg === "--result") opts.result = argv[++index] || "";
    else if (arg === "--tests-passed") opts.testsPassed = parseBool(argv[++index]);
    else if (arg === "--extra-file-reads") opts.extraFileReads = Number(argv[++index]);
    else if (arg === "--tool-calls") opts.toolCalls = Number(argv[++index]);
    else if (arg === "--retry-count") opts.retryCount = Number(argv[++index]);
    else if (arg === "--known-findings-recalled") opts.knownFindingsRecalled = Number(argv[++index]);
    else if (arg === "--review-findings-count") opts.reviewFindingsCount = Number(argv[++index]);
    else if (arg === "--false-positive-count") opts.falsePositiveCount = Number(argv[++index]);
    else if (arg === "-h" || arg === "--help") {
      usage();
      process.exit(0);
    } else {
      throw new Error(`Unknown argument: ${arg}`);
    }
  }

  if (!opts.repo) throw new Error("--repo is required");
  if (!opts.story) throw new Error("--story is required");
  if (!opts.role) throw new Error("--role is required");
  if (!new Set(["review", "atdd", "dev"]).has(opts.taskType)) throw new Error("--task-type must be review, atdd, or dev");
  if (!new Set(["baseline", "files", "context-mode"]).has(opts.mode)) throw new Error("--mode must be baseline, files, or context-mode");
  if (!Number.isInteger(opts.runs) || opts.runs < 1 || opts.runs > 50) throw new Error("--runs must be between 1 and 50");
  if (!new Set(["pass", "fail", "invalid"]).has(opts.result)) throw new Error("--result must be pass, fail, or invalid");
  for (const key of ["extraFileReads", "toolCalls", "retryCount", "knownFindingsRecalled", "reviewFindingsCount", "falsePositiveCount"]) {
    if (!Number.isInteger(opts[key]) || opts[key] < 0) throw new Error(`--${kebab(key)} must be a non-negative integer`);
  }

  opts.repo = path.resolve(opts.repo);
  if (!fs.existsSync(opts.repo)) throw new Error(`Repository path does not exist: ${opts.repo}`);
  if (opts.fixture) {
    opts.fixture = path.resolve(opts.fixture);
    if (!fs.existsSync(opts.fixture)) throw new Error(`Fixture does not exist: ${opts.fixture}`);
  }
  if (!opts.output) {
    opts.output = path.join(repoRoot, "docs", "experiments", "context-retrieval", "runs", `${dateStamp()}.jsonl`);
  } else {
    opts.output = path.resolve(opts.output);
  }
  if (!under(opts.output, repoRoot)) throw new Error("--output must stay inside the ACEF target repository");
  return opts;
}

function parseBool(value) {
  if (value === "true") return true;
  if (value === "false") return false;
  throw new Error("boolean options must be true or false");
}

function kebab(value) {
  return value.replace(/[A-Z]/g, (match) => `-${match.toLowerCase()}`);
}

function under(filePath, root) {
  const rel = path.relative(root, filePath);
  return rel === "" || (!rel.startsWith("..") && !path.isAbsolute(rel));
}

function dateStamp() {
  return new Date().toISOString().slice(0, 10);
}

function runId() {
  return `${Date.now().toString(36)}-${crypto.randomBytes(4).toString("hex")}`;
}

function readText(filePath) {
  return fs.readFileSync(filePath, "utf8");
}

function bytes(text) {
  return Buffer.byteLength(text || "");
}

function rel(repo, filePath) {
  return path.relative(repo, filePath);
}

function activeLedger(repo) {
  const pointer = path.join(repo, "docs", "ai", "ACEF_ACTIVE_LEDGER");
  if (!fs.existsSync(pointer)) return "";
  const firstLine = readText(pointer).split(/\r?\n/).find((line) => line.trim());
  if (!firstLine) return "";
  const resolved = path.resolve(repo, firstLine.trim());
  return under(resolved, repo) && fs.existsSync(resolved) ? resolved : "";
}

function walk(dir, out = []) {
  if (!fs.existsSync(dir)) return out;
  for (const entry of fs.readdirSync(dir).sort((a, b) => a.localeCompare(b))) {
    const filePath = path.join(dir, entry);
    const stat = fs.statSync(filePath);
    if (stat.isDirectory()) walk(filePath, out);
    else out.push(filePath);
  }
  return out;
}

function storyRegex(story) {
  const escaped = story.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
  const dashed = story.replace(/\./g, "-").replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
  return new RegExp(`(^|[^0-9])(?:Story\\s*)?(${escaped}|${dashed})(?![0-9])`, "i");
}

function collectBaselineFiles(repo, story) {
  const files = [];
  const pushIfExists = (filePath) => {
    if (filePath && fs.existsSync(filePath) && fs.statSync(filePath).isFile()) files.push(filePath);
  };

  pushIfExists(activeLedger(repo));
  pushIfExists(path.join(repo, "docs", "ai", "ACEF_CURRENT_CONTEXT.md"));
  pushIfExists(path.join(repo, "docs", "ai", "pattern-registry.json"));

  const epic = story.split(".")[0];
  pushIfExists(path.join(repo, "docs", "ai", `epic-${epic}-context-pack.md`));

  const matcher = storyRegex(story);
  for (const base of [
    path.join(repo, "_bmad-output"),
    path.join(repo, "docs", "stories"),
    path.join(repo, "docs", "ai"),
  ]) {
    for (const filePath of walk(base)) {
      if (!/\.(md|json|txt)$/i.test(filePath)) continue;
      const relative = rel(repo, filePath);
      if (/ACEF_ACTIVE_LEDGER$/.test(relative)) continue;
      if (files.includes(filePath)) continue;
      if (matcher.test(relative) || matcher.test(path.basename(filePath))) files.push(filePath);
    }
  }
  return files.sort((a, b) => rel(repo, a).localeCompare(rel(repo, b)));
}

function fixtureInfo(opts) {
  if (!opts.fixture) return { bytes: 0, path: "" };
  return {
    bytes: fs.statSync(opts.fixture).size,
    path: path.relative(repoRoot, opts.fixture),
  };
}

function baselineMetrics(opts) {
  const files = collectBaselineFiles(opts.repo, opts.story);
  const sourceBytes = files.reduce((total, filePath) => total + fs.statSync(filePath).size, 0);
  const fixture = fixtureInfo(opts);
  const totalBytes = sourceBytes + fixture.bytes;
  return {
    provider: "baseline",
    source_files: files.map((filePath) => rel(opts.repo, filePath)),
    source_bytes: totalBytes,
    output_bytes: totalBytes,
    reduction_percent: 0,
    content: "",
    fixture_path: fixture.path,
    fixture_bytes: fixture.bytes,
  };
}

function queryMetrics(opts, provider) {
  const args = [
    "context",
    "--repo", opts.repo,
    "--story", opts.story,
    "--role", opts.role,
    "--provider", provider,
    "--format", "json",
  ];
  const started = Date.now();
  const stdout = cp.execFileSync(acefQuery, args, {
    cwd: repoRoot,
    encoding: "utf8",
    stdio: ["ignore", "pipe", "pipe"],
  });
  const elapsed = Date.now() - started;
  const parsed = JSON.parse(stdout);
  const fixture = fixtureInfo(opts);
  const sourceBytes = parsed.source_bytes + fixture.bytes;
  const outputBytes = parsed.output_bytes + fixture.bytes;
  const reduction = sourceBytes > 0 ? Math.max(0, 100 - ((outputBytes / sourceBytes) * 100)) : 0;
  return {
    provider: parsed.provider,
    source_files: parsed.source_files,
    source_bytes: sourceBytes,
    output_bytes: outputBytes,
    reduction_percent: Number(reduction.toFixed(1)),
    content: parsed.content,
    fixture_path: fixture.path,
    fixture_bytes: fixture.bytes,
    retrieval_ms: elapsed,
  };
}

function record(opts, metrics, runtimeMs) {
  const now = new Date().toISOString();
  return {
    run_id: runId(),
    recorded_at: now,
    repo: path.basename(opts.repo),
    repo_path: opts.repo,
    task_type: opts.taskType,
    mode: opts.mode,
    provider: metrics.provider,
    story: opts.story,
    role: opts.role,
    input_tokens: null,
    cached_input_tokens: null,
    output_tokens: null,
    cost: null,
    source_bytes: metrics.source_bytes,
    returned_bytes: metrics.output_bytes,
    reduction_pct: metrics.reduction_percent,
    fixture_path: metrics.fixture_path || "",
    fixture_bytes: metrics.fixture_bytes || 0,
    source_files: metrics.source_files,
    extra_file_reads: opts.extraFileReads,
    tool_calls: opts.toolCalls,
    runtime_seconds: Number((runtimeMs / 1000).toFixed(3)),
    retrieval_ms: metrics.retrieval_ms || runtimeMs,
    tests_passed: opts.testsPassed,
    review_findings_count: opts.reviewFindingsCount,
    known_findings_recalled: opts.knownFindingsRecalled,
    false_positive_count: opts.falsePositiveCount,
    retry_count: opts.retryCount,
    stale_story_leak: false,
    wrong_scope_touch: false,
    result: opts.result,
  };
}

function appendJsonl(filePath, rows) {
  fs.mkdirSync(path.dirname(filePath), { recursive: true });
  fs.appendFileSync(filePath, `${rows.map((row) => JSON.stringify(row)).join("\n")}\n`);
}

function main() {
  const opts = parseArgs(process.argv.slice(2));
  const rows = [];
  for (let index = 0; index < opts.runs; index += 1) {
    const started = Date.now();
    const metrics = opts.mode === "baseline" ? baselineMetrics(opts) : queryMetrics(opts, opts.mode);
    rows.push(record(opts, metrics, Date.now() - started));
  }
  appendJsonl(opts.output, rows);
  const medianReduction = rows.map((row) => row.reduction_pct).sort((a, b) => a - b)[Math.floor(rows.length / 2)];
  console.log([
    "ACEF context experiment recorded",
    `output: ${opts.output}`,
    `rows: ${rows.length}`,
    `mode: ${opts.mode}`,
    `story: ${opts.story}`,
    `role: ${opts.role}`,
    `median_reduction_pct: ${medianReduction}`,
  ].join("\n"));
}

try {
  main();
} catch (error) {
  console.error(`ERROR: ${error.message}`);
  process.exit(1);
}
