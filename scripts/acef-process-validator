#!/usr/bin/env node
const fs = require("node:fs");
const path = require("node:path");
const cp = require("node:child_process");
const crypto = require("node:crypto");
const {
  parseActiveRun,
  parseActorRecord,
  parseApproval,
  parseEvidenceManifest,
  parseGateVerdict,
  parseLightweightRun,
  parsePrReview,
  parsePrReviewProfile,
  parseCapabilityChange,
  parseSpecReadiness,
  parseWorkerScope,
  safeRelative,
  parseControlDosing,
} = require("./lib/acef-state-parser");

function usage() {
  console.log(`ACEF process validator

Usage:
  scripts/acef-process-validator [--repo <path>] [--check <name>] [--ledger <path>] [--adapter <path>] [--target-epic <n>]

Checks:
  all                 Run all checks that have enough inputs
  clean-tree          Require git working tree to be clean before certification/Process Judge
  preflight           Require docs/ai/ACEF_PREFLIGHT.md with Verdict/Status: PASS
  claims              Require claimed output paths in the ledger to exist
  adapter-freshness   Require adapter/codebase-map freshness commit to match HEAD
  pattern-registry    Require docs/ai/pattern-registry.json to satisfy the ACEF registry contract
  reuse-before-create Require the delivery ledger to record a reuse-before-create probe
  do-not-copy         Fail when ledger treats do-not-copy entries as reusable patterns
  partial-workshape   In PARTIAL registries, require ledger-declared covered workShape or human risk acceptance
  finding-promotion   Require each conformance finding to record a patch/registry/check/defer disposition
  graduation-reconciliation Require promoted findings to reconcile to a real file or enforcedBy value
  vertical-slice      Require capabilities to trace actor -> real surface/entrypoint -> application path -> runtime evidence
  test-authenticity   Reject fake-green tests: warnings-as-pass, silent catch/continue, self-asserts, and status-only smoke
  guarded-test-floor  For guarded work, require a symbol-grounded asserted boundary test and independent Test Author
  actor-separation    For full BMAD, require distinct phase actors with durable provenance evidence
  worker-scope       Require active worker identity and write scope to match the typed active run
  evidence-manifest  Validate typed evidence provenance, hashes, actor binding, and source freshness
  gate-verdict       Require the active scope to have a typed PASS verdict backed by successful surface evidence
  source-reconciliation For full BMAD, require every planning source to record use/conflict/resolution
  epic-context-pack  Require an epic-level context pack before story workers consume the epic
  current-context    Require a role-scoped, ledger-reconciled hot context before worker dispatch
  pr-review          Validate bounded PR-review context and reject reviewer-authored patches
  spec-readiness     Require file-backed product/spec readiness before planning or dispatch
  goal-coverage      Require user-facing goals to close with visible product surface evidence
  lane-selection     Require active lane choice to match recorded risk triggers
  lane-closeout      Require the active lane's complete validator bundle before close
  lightweight-lifecycle Require the six-step lightweight lifecycle, promotion disposition, and surface evidence
  lean-evidence       Require story/epic close evidence to live in artifacts, not chat
  control-dosing      Validate the machine-readable lane/control dosing manifest
  capability-change   Require ACEF flow/gate/capability changes to declare documented/wired/enforced/proven layers
  session-handoff     Require a structured Session Handoff block in the delivery ledger
  seeded-epic-gates   Require Epic N Process Judge rows/artifacts for epics mentioned in ledger
  epic-boundary       Require Epic N-1 Process Judge PASS before target Epic N
  epic-transition-approval Require explicit human approval before starting Epic N
  replan-counter      Fail when the same scope has 2+ REPLAN decisions in ledger text
`);
}

function parseArgs(argv) {
  const args = {
    repo: process.cwd(),
    check: "all",
    ledger: "",
    adapter: "",
    targetEpic: 0,
  };

  for (let index = 2; index < argv.length; index += 1) {
    const arg = argv[index];
    if (arg === "--help" || arg === "-h") {
      args.help = true;
    } else if (arg === "--repo") {
      args.repo = argv[++index] || "";
    } else if (arg === "--check") {
      args.check = argv[++index] || "";
    } else if (arg === "--ledger") {
      args.ledger = argv[++index] || "";
    } else if (arg === "--adapter") {
      args.adapter = argv[++index] || "";
    } else if (arg === "--target-epic") {
      args.targetEpic = Number(argv[++index] || "0");
    } else {
      throw new Error(`Unknown argument: ${arg}`);
    }
  }

  args.repo = path.resolve(args.repo || process.cwd());
  if (args.ledger) args.ledger = resolvePath(args.ledger, args.repo);
  if (args.adapter) args.adapter = resolvePath(args.adapter, args.repo);
  return args;
}

function resolvePath(value, repoRoot) {
  if (!value) return "";
  const expanded = value.replace(/^~(?=\/|$)/, process.env.HOME || "");
  return path.resolve(path.isAbsolute(expanded) ? expanded : path.join(repoRoot, expanded));
}

function exists(filePath) {
  try {
    return fs.existsSync(filePath);
  } catch {
    return false;
  }
}

function read(filePath) {
  return fs.readFileSync(filePath, "utf8");
}

function listFiles(dirPath) {
  const out = [];
  function walk(current) {
    let entries = [];
    try {
      entries = fs.readdirSync(current, { withFileTypes: true });
    } catch {
      return;
    }
    for (const entry of entries) {
      const filePath = path.join(current, entry.name);
      if (entry.isDirectory()) walk(filePath);
      else if (entry.isFile()) out.push(filePath);
    }
  }
  walk(dirPath);
  return out;
}

function gitHead(repoRoot) {
  try {
    return cp.execFileSync("git", ["rev-parse", "--short", "HEAD"], {
      cwd: repoRoot,
      encoding: "utf8",
      stdio: ["ignore", "pipe", "ignore"],
    }).trim();
  } catch {
    return "";
  }
}

function gitIsAncestor(repoRoot, ancestor, descendant) {
  try {
    cp.execFileSync("git", ["merge-base", "--is-ancestor", ancestor, descendant], {
      cwd: repoRoot,
      stdio: ["ignore", "ignore", "ignore"],
    });
    return true;
  } catch {
    return false;
  }
}

function gitChangedFiles(repoRoot, fromRef, toRef) {
  try {
    const output = cp.execFileSync("git", ["diff", "--name-only", `${fromRef}..${toRef}`], {
      cwd: repoRoot,
      encoding: "utf8",
      stdio: ["ignore", "pipe", "ignore"],
    });
    return output.split(/\r?\n/).filter(Boolean);
  } catch {
    return [];
  }
}

function gitStatusPorcelain(repoRoot) {
  try {
    const output = cp.execFileSync("git", ["status", "--porcelain=v1", "--untracked-files=all"], {
      cwd: repoRoot,
      encoding: "utf8",
      stdio: ["ignore", "pipe", "ignore"],
    });
    return output.split(/\r?\n/).filter(Boolean);
  } catch {
    return null;
  }
}

function jsonRecords(dirPath) {
  if (!exists(dirPath)) return [];
  return fs.readdirSync(dirPath, { withFileTypes: true })
    .filter((entry) => entry.isFile() && entry.name.endsWith(".json"))
    .map((entry) => path.join(dirPath, entry.name))
    .sort();
}

function sha256(value) {
  return crypto.createHash("sha256").update(value).digest("hex");
}

function sha256File(filePath) {
  return crypto.createHash("sha256").update(fs.readFileSync(filePath)).digest("hex");
}

function evidenceRunnerProof(record) {
  return sha256(JSON.stringify({
    schema: "acef-evidence-runner-proof-v1",
    runner: "acef-state evidence-run",
    evidenceId: record.evidenceId,
    kind: record.kind,
    command: record.command,
    exitCode: record.exitCode,
    startedAt: record.startedAt || null,
    finishedAt: record.finishedAt || null,
    repositoryCommit: record.repositoryCommit,
    repositoryTree: record.repositoryTree || null,
    dirtyDigest: record.dirtyDigest,
    dirtyApplicationPathsBefore: record.dirtyApplicationPathsBefore || [],
    dirtyApplicationPathsAfter: record.dirtyApplicationPathsAfter || [],
    environmentDigest: record.environmentDigest || null,
    actorInstanceId: record.actorInstanceId,
    story: record.story,
    rawArtifact: record.rawArtifact,
    satisfies: record.satisfies,
  }));
}

function lightweightSurfaceProof(entry, artifactSha256) {
  return sha256(JSON.stringify({
    schema: "acef-lightweight-surface-proof-v1",
    runner: "acef-lightweight-surface-evidence",
    surface: entry.surface,
    evidencePath: entry.evidencePath,
    command: entry.command,
    exitCode: entry.exitCode,
    artifactSha256,
  }));
}

function artifactHasRunnerHeader(text, command, exitCode) {
  return text.includes(`command: ${command}\n`) && text.includes(`exit_code: ${exitCode}\n`);
}

function normalizedScope(value) {
  return String(value || "").trim().toLowerCase().replace(/[^a-z0-9]+/g, "");
}

function stateControlPath(filePath) {
  const normalized = String(filePath || "").replaceAll(path.sep, "/");
  return /^docs\/ai\/(?:actors|evidence|gates|approvals)\//.test(normalized)
    || /^docs\/ai\/ACEF_(?:ACTIVE_RUN|ACTIVE_WORKER_SCOPE|CURRENT_CONTEXT|ACTIVE_LEDGER)(?:\.json)?$/.test(normalized)
    || /^docs\/ai\/ACEF_.*_DELIVERY_AUDIT\.md$/.test(normalized);
}

function ancestorCommitError(repoRoot, commit, label) {
  const head = gitHead(repoRoot);
  if (!commit || !gitIsAncestor(repoRoot, commit, head)) return `${label} commit ${commit || "missing"} is not an ancestor of HEAD ${head}`;
  return "";
}

function recordCommitError(repoRoot, commit, label) {
  const ancestorError = ancestorCommitError(repoRoot, commit, label);
  if (ancestorError) return ancestorError;
  const head = gitHead(repoRoot);
  const changed = gitChangedFiles(repoRoot, commit, head).filter((filePath) => !stateControlPath(filePath));
  if (changed.length) return `${label} is stale; application paths changed since ${commit}: ${changed.slice(0, 8).join(", ")}`;
  return "";
}

function workingApplicationChanges(repoRoot) {
  const lines = gitStatusPorcelain(repoRoot) || [];
  return lines.map((line) => line.slice(3)).filter((filePath) => filePath && !stateControlPath(filePath));
}

function isTestPath(filePath) {
  return /(^|\/)(__tests__|tests?|specs?)(\/|$)|(\.|-)(test|spec)\.[cm]?[jt]sx?$|Test\.(php|py|rb|cs)$/i.test(String(filePath || ""));
}

function changedTestPaths(repoRoot) {
  return pathHints(repoRoot).filter(isTestPath);
}

function gitDiff(repoRoot, filePath) {
  try {
    return cp.execFileSync("git", ["diff", "--unified=0", "--", filePath], {
      cwd: repoRoot,
      encoding: "utf8",
      stdio: ["ignore", "pipe", "ignore"],
    });
  } catch {
    return "";
  }
}

function testEditIntegrityFailures(repoRoot, testPath) {
  const diff = gitDiff(repoRoot, testPath);
  if (!diff) return [];
  const failures = [];
  const added = [];
  const removed = [];
  for (const line of diff.split(/\r?\n/)) {
    if (line.startsWith("+++") || line.startsWith("---")) continue;
    if (line.startsWith("+")) added.push(line.slice(1));
    if (line.startsWith("-")) removed.push(line.slice(1));
  }
  const addedText = added.join("\n");
  const removedText = removed.join("\n");
  if (/\b(?:describe|context|it|test)\.(?:skip|only|todo)\b|\b(?:xit|xtest|xdescribe)\s*\(|markTestSkipped\s*\(|@pytest\.mark\.skip|pytest\.skip\s*\(|\bxfail\b/i.test(addedText)) {
    failures.push(`${testPath}: added skip/only/todo/xfail pattern`);
  }
  const assertionPattern = /\b(?:expect|assert|assertEquals|assertSame|assertTrue|assertFalse|assertNot|toBe|toEqual|toMatch|toContain|toHave|should|must|verify)\b/i;
  const removedAssertions = removed.filter((line) => assertionPattern.test(line)).length;
  const addedAssertions = added.filter((line) => assertionPattern.test(line)).length;
  if (removedAssertions > addedAssertions) {
    failures.push(`${testPath}: assertion count appears to drop in diff (${removedAssertions} removed, ${addedAssertions} added)`);
  }
  if (/\btoBeTruthy\s*\(|\btoBeDefined\s*\(|\btoBeGreaterThanOrEqual\s*\(\s*0\s*\)|assertTrue\s*\(\s*true\s*\)/i.test(addedText)
    && /\btoEqual\s*\(|\btoMatchObject\s*\(|\btoContain\s*\(|\btoHaveLength\s*\(|assertSame\s*\(|assertEquals\s*\(/i.test(removedText)) {
    failures.push(`${testPath}: matcher appears loosened`);
  }
  return failures;
}

function pathHints(repoRoot, activeScope = null) {
  const paths = new Set(workingApplicationChanges(repoRoot));
  if (activeScope?.baseRef && gitIsAncestor(repoRoot, activeScope.baseRef, gitHead(repoRoot))) {
    for (const filePath of gitChangedFiles(repoRoot, activeScope.baseRef, "HEAD")) {
      if (!stateControlPath(filePath)) paths.add(filePath);
    }
  }
  return [...paths].map((filePath) => filePath.replaceAll(path.sep, "/"));
}

function inferredSurfaces(paths) {
  const surfaces = new Set();
  for (const filePath of paths) {
    if (/(^|\/)(components|pages|screens|views|ui|frontend)(\/|$)|\.(tsx|jsx|vue|svelte)$/i.test(filePath)) surfaces.add("ui");
    if (/(^|\/)(app|mobile)(\/|$)|\.(swift|kt)$/i.test(filePath)) surfaces.add("mobile");
    if (/(^|\/)(routes|controllers|api|http|server)(\/|$)|route|controller/i.test(filePath)) surfaces.add("api");
    if (/webhook/i.test(filePath)) surfaces.add("webhook");
    if (/(^|\/)(jobs|workers)(\/|$)|job/i.test(filePath)) surfaces.add("job");
    if (/(^|\/)(queues|queue)(\/|$)/i.test(filePath)) surfaces.add("queue");
    if (/(^|\/)(scheduler|cron)(\/|$)|schedule/i.test(filePath)) surfaces.add("scheduler");
    if (/(^|\/)(migrations|database|schema)(\/|$)/i.test(filePath)) surfaces.add("database");
    if (/(^|\/)(config|configs)(\/|$)|\.ya?ml$|\.toml$|\.env/i.test(filePath)) surfaces.add("config");
    if (/(^|\/)(cli|bin|commands?)(\/|$)|command/i.test(filePath)) surfaces.add("cli");
    if (/(^|\/)(lib|src|packages|modules)(\/|$)/i.test(filePath) && !surfaces.size) surfaces.add("library");
  }
  return [...surfaces];
}

function inferredRiskTriggers(paths) {
  const triggers = new Set();
  for (const filePath of paths) {
    if (/auth|authorization|permission|roles?/i.test(filePath)) triggers.add("auth");
    if (/payment|billing|invoice|checkout|subscription|accounting|finance|financial|revenue|expense|tax|ledger|muhasebe/i.test(filePath)) triggers.add("financial");
    if (/crm|lead|notes?|follow[-_]?up|conversion|history|tracking/i.test(filePath)) triggers.add("stateful-product-data");
    if (/app[-_]?store|memory|singleton|demo[-_]?data|fixture[-_]?store/i.test(filePath)) triggers.add("stateful-product-data");
    if (/migration|delete|destroy|purge|truncate/i.test(filePath)) triggers.add("migration");
    if (/(^|\/)(migrations|database|schema)(\/|$)/i.test(filePath)) triggers.add("persistence");
    if (/security|token|session|secret|credential/i.test(filePath)) triggers.add("security");
    if (/webhook/i.test(filePath)) triggers.add("webhook");
    if (/tenant|privacy|pii|personal[-_]?data/i.test(filePath)) triggers.add("tenant-privacy");
  }
  return [...triggers];
}

function stateChangingRisk(repoRoot, activeRun, activeScope = null) {
  const text = [
    activeRun?.activeStory,
    activeRun?.laneRationale,
    ...(activeRun?.riskTriggers || []),
    ...(activeScope?.surfaces || []),
    ...pathHints(repoRoot, activeScope),
  ].filter(Boolean).join(" ");
  return /\b(create|capture|record|save|store|persist|write|update|delete|notes?|lead|crm|follow[-_ ]?up|conversion|history|tracking|payment|billing|invoice|finance|financial|payout|receipt|balance|migration|database|schema|app[-_ ]?store|memory|singleton|demo[-_ ]?data|fixture[-_ ]?store)\b/i.test(text);
}

function durablePersistenceEvidenceText(text) {
  return /\b(postgres|postgresql|database|db\b|drizzle|sql|insert(?:ed)?|select(?:ed)?|row(?:s)?|transaction|migration|persistent|persisted|durable|write[-_ ]?read|read[-_ ]?after[-_ ]?write|fresh request|new request|cold start|process reset|store reset|reload|requery|round[-_ ]?trip)\b/i.test(text)
    && /\b(create|capture|record|save|write|insert|update|persist|read|select|query|requery|reload|visible|found|exists)\b/i.test(text);
}

function stateChangingEvidenceFailure(label, rawText) {
  if (durablePersistenceEvidenceText(rawText)) return "";
  if (/\b(route|page|http|status|200|render|smoke|component|fixture|mock|memory|singleton|demo[-_ ]?data|schema only|schema exists|model exists)\b/i.test(rawText)) {
    return `${label} must prove durable write/read persistence, not only route/render/status/schema/in-memory evidence`;
  }
  return `${label} must include durable write/read persistence evidence for state-changing work`;
}

function evidenceRawText(repoRoot, evidence) {
  if (!evidence?.rawArtifact?.path) return "";
  const rawPath = resolvePath(evidence.rawArtifact.path, repoRoot);
  if (!exists(rawPath)) return "";
  return read(rawPath);
}

function specReadinessPath(repoRoot, activeRun = null) {
  const configured = activeRun?.specReadinessPath || activeRun?.specReadiness?.path || "";
  return configured ? resolvePath(configured, repoRoot) : path.join(repoRoot, "docs", "ai", "ACEF_SPEC_READINESS.json");
}

function isDispatchPhase(activeRun) {
  if (!activeRun || activeRun.status === "complete") return false;
  const phase = String(activeRun.activePhase || "").toLowerCase();
  if (!phase) return false;
  if (new Set(["planning", "atdd", "development", "code-review", "verify-patch", "test-review", "process-judge", "closeout"]).has(phase)) {
    return true;
  }
  return /(plan|atdd|develop|developer|implementation|code[-_ ]?review|verify|test[-_ ]?review|process[-_ ]?judge|closeout)/i.test(phase);
}

function specReadinessRequired(activeRun, triggers = []) {
  if (!activeRun) return false;
  if (!isDispatchPhase(activeRun)) return false;
  if (["full-bmad", "guarded"].includes(activeRun.lane)) return true;
  const riskText = triggers.join(" ");
  return /(feature|crm|notes?|tracking|reporting|dashboard|workflow|persistence|database|schema|migration|auth|authorization|permission|roles?|payment|billing|invoice|accounting|finance|financial|revenue|expense|tax|ledger|muhasebe|payout|security|tenant|privacy|pii)/i.test(riskText);
}

function validateSpecReadinessForDispatch(repoRoot, activeRun, triggers = []) {
  if (!specReadinessRequired(activeRun, triggers)) return [];
  const failures = [];
  const filePath = specReadinessPath(repoRoot, activeRun);
  if (!exists(filePath)) return [`planning/execution requires file-backed spec readiness verdict at ${path.relative(repoRoot, filePath)}`];
  let verdict;
  try {
    verdict = parseSpecReadiness(filePath);
  } catch (error) {
    return [`spec readiness verdict invalid: ${error.message}`];
  }
  const commitError = recordCommitError(repoRoot, verdict.repositoryCommit, "spec readiness verdict");
  if (commitError) failures.push(commitError);
  const highRisk = (triggers.concat(verdict.riskFlags || [])).some((item) => /(schema|migration|auth|authorization|permission|role|payment|billing|invoice|accounting|finance|financial|revenue|expense|tax|ledger|muhasebe|payout|security|tenant|privacy|pii|persistence|database|crm)/i.test(item));
  if (verdict.status !== "PASS") {
    const questions = (verdict.blockingQuestions || []).slice(0, 3).join(" | ");
    const suffix = questions ? ` Blocking question(s): ${questions}` : "";
    failures.push(`spec readiness is ${verdict.status}; route to ${verdict.nextArtifact}.${suffix}`);
  }
  if (verdict.status === "PASS" && verdict.ambiguity > 0.2 && !verdict.fastTrack) {
    failures.push(`spec readiness PASS has ambiguity ${verdict.ambiguity}; non-fast-track work must be <= 0.20`);
  }
  if (highRisk && verdict.fastTrack) {
    failures.push("spec readiness fastTrack cannot be used for guarded/high-risk work");
  }
  if (highRisk && verdict.status !== "PASS" && !verdict.blockingQuestions.length) {
    failures.push("non-PASS guarded spec readiness must include blockingQuestions");
  }
  return failures;
}

function missingInferredSurfaces(repoRoot, declared, activeScope = null) {
  const inferred = inferredSurfaces(pathHints(repoRoot, activeScope));
  const declaredSet = new Set(declared || []);
  return inferred.filter((surface) => !declaredSet.has(surface));
}

function actorRecordById(repoRoot, actorId) {
  const filePath = path.join(repoRoot, "docs", "ai", "actors", `${actorId}.json`);
  if (!exists(filePath)) throw new Error(`Missing actor record ${actorId}`);
  const actor = parseActorRecord(filePath);
  if (actor.actorInstanceId !== actorId) throw new Error(`Actor filename/id mismatch for ${actorId}`);
  return actor;
}

function evidenceRecordById(repoRoot, evidenceId) {
  const filePath = path.join(repoRoot, "docs", "ai", "evidence", `${evidenceId}.json`);
  if (!exists(filePath)) throw new Error(`Missing evidence manifest ${evidenceId}`);
  const evidence = parseEvidenceManifest(filePath);
  if (evidence.evidenceId !== evidenceId) throw new Error(`Evidence filename/id mismatch for ${evidenceId}`);
  return evidence;
}

function validateEvidenceRecord(repoRoot, evidence) {
  const failures = [];
  const commitError = recordCommitError(repoRoot, evidence.repositoryCommit, `evidence ${evidence.evidenceId}`);
  if (commitError) failures.push(commitError);
  try {
    const actor = actorRecordById(repoRoot, evidence.actorInstanceId);
    if (normalizedScope(actor.story) !== normalizedScope(evidence.story)) failures.push(`evidence ${evidence.evidenceId} actor story mismatch`);
  } catch (error) {
    failures.push(error.message);
  }
  try {
    const rawPath = path.resolve(repoRoot, evidence.rawArtifact.path);
    safeRelative(rawPath, repoRoot);
    if (!exists(rawPath)) failures.push(`evidence ${evidence.evidenceId} raw artifact is missing`);
    else {
      safeRelative(fs.realpathSync(rawPath), fs.realpathSync(repoRoot));
      if (sha256File(rawPath) !== evidence.rawArtifact.sha256) failures.push(`evidence ${evidence.evidenceId} raw artifact hash mismatch`);
      const rawText = read(rawPath);
      if (!artifactHasRunnerHeader(rawText, evidence.command, evidence.exitCode)) {
        failures.push(`evidence ${evidence.evidenceId} raw artifact missing runner command/exit header`);
      }
    }
  } catch (error) {
    failures.push(`evidence ${evidence.evidenceId}: ${error.message}`);
  }
  if (evidence.runnerProof?.schema !== "acef-evidence-runner-proof-v1") {
    failures.push(`evidence ${evidence.evidenceId} runnerProof schema mismatch`);
  } else if (evidence.runnerProof?.runner !== "acef-state evidence-run") {
    failures.push(`evidence ${evidence.evidenceId} runnerProof runner mismatch`);
  } else if (evidence.runnerProof?.sha256 !== evidenceRunnerProof(evidence)) {
    failures.push(`evidence ${evidence.evidenceId} runnerProof hash mismatch`);
  }
  return failures;
}

function checkCleanTree(repoRoot) {
  const status = gitStatusPorcelain(repoRoot);
  if (status === null) return result("clean-tree", false, "Could not read git status");
  if (status.length) {
    return result("clean-tree", false, `Working tree is dirty: ${status.slice(0, 8).join(", ")}`);
  }
  return result("clean-tree", true, "Working tree clean");
}

function nestedGitRepos(repoRoot) {
  const repos = [];
  function walk(current, depth) {
    if (depth > 2) return;
    let entries = [];
    try {
      entries = fs.readdirSync(current, { withFileTypes: true });
    } catch {
      return;
    }

    if (entries.some((entry) => entry.isDirectory() && entry.name === ".git")) {
      repos.push(path.relative(repoRoot, current) || ".");
      return;
    }

    for (const entry of entries) {
      if (!entry.isDirectory()) continue;
      if (entry.name.startsWith(".") || entry.name === "node_modules") continue;
      walk(path.join(current, entry.name), depth + 1);
    }
  }
  walk(repoRoot, 0);
  return repos;
}

function findLedger(repoRoot) {
  // Prefer the active run's declared ledger. The alphabetical fallback below can
  // otherwise resolve a stale/legacy ledger (e.g. ACEF_ACTIVE_LEDGER sorts ahead
  // of ACEF_CREDIT_LEDGER_DELIVERY_AUDIT.md) that lacks the active run's evidence,
  // producing false FAILs for callers that omit --ledger (e.g. the pre-commit hook).
  const activeRunPath = path.join(repoRoot, "docs", "ai", "ACEF_ACTIVE_RUN.json");
  if (exists(activeRunPath)) {
    const activeRun = parseActiveRun(activeRunPath);
    const declared = activeRun && resolvePath(activeRun.ledgerPath, repoRoot);
    if (declared && exists(declared)) return declared;
  }
  const roots = [
    path.join(repoRoot, "docs", "ai"),
    path.join(repoRoot, "_bmad-output"),
  ];
  const candidates = roots.flatMap((root) => listFiles(root))
    .filter((filePath) => /delivery|audit|ledger/i.test(path.basename(filePath)))
    .sort();
  return candidates[0] || "";
}

function findAdapter(repoRoot) {
  const candidates = [
    path.join(repoRoot, "docs", "codebase-map.md"),
    path.join(repoRoot, "docs", "ai", "project-adapter.md"),
    path.join(repoRoot, "docs", "ai", "pattern-registry.json"),
    ...listFiles(path.join(repoRoot, "docs", "ai")).filter((filePath) => /adapter|codebase-map|pattern-registry/i.test(path.basename(filePath))),
  ];
  return candidates.find(exists) || "";
}

function findPatternRegistry(repoRoot, adapterPath) {
  const preferred = path.join(repoRoot, "docs", "ai", "pattern-registry.json");
  if (exists(preferred)) return preferred;
  if (adapterPath && /pattern-registry\.json$/i.test(adapterPath) && exists(adapterPath)) return adapterPath;
  return "";
}

function result(name, ok, message) {
  return { name, ok, message };
}

function checkPreflight(repoRoot) {
  const filePath = path.join(repoRoot, "docs", "ai", "ACEF_PREFLIGHT.md");
  if (!exists(filePath)) return result("preflight", false, `Missing ${path.relative(repoRoot, filePath)}`);
  const text = read(filePath);
  const pass = /\b(Verdict|Status)\s*:\s*PASS\b/i.test(text)
    || /\|\s*(Verdict|Status)\s*\|[^|\n]*\bPASS\b/i.test(text);
  return result("preflight", pass, pass ? "Preflight PASS found" : "Preflight exists but PASS verdict/status was not found");
}

function extractClaimedPaths(text) {
  const claims = new Set();
  const lines = text.split(/\r?\n/);
  let inOutputs = false;

  for (const line of lines) {
    if (/^\s*(#{1,6}\s*)?(Outputs?|Artifacts?|Generated files?|Claimed outputs?)\s*:?\s*$/i.test(line)) {
      inOutputs = true;
      continue;
    }
    if (/^\s*(Inputs?|Evidence|Verdict|Next allowed|Tests?|Checks?|Reuse[- ]before[- ]create|Reuse probe|Golden neighbors?|Do[- ]not[- ]copy)\s*:/i.test(line) || /^#{1,6}\s+/.test(line)) {
      inOutputs = false;
    }

    const shouldScan = inOutputs || /^\s*(Outputs?|Artifacts?|Generated files?|Claimed outputs?)\s*:/i.test(line);
    if (!shouldScan) continue;

    const matches = [...line.matchAll(/`([^`]+\.[A-Za-z0-9]{1,12})`|(?:^|[\s:])((?:\.\/)?(?:docs|src|app|modules|shared|lib|components|hooks|services|stores|utils|constants|types|_bmad-output)\/[^\s,;|)]+)/g)];
    for (const match of matches) {
      const value = (match[1] || match[2] || "").replace(/[.,;:]$/, "");
      if (value && !/pending|none|n\/a/i.test(value)) claims.add(value);
    }
  }

  return [...claims];
}

function checkClaims(repoRoot, ledgerPath) {
  if (!ledgerPath || !exists(ledgerPath)) return result("claims", false, "Missing ledger path for claimed-output validation");
  const claims = extractClaimedPaths(read(ledgerPath));
  const missing = claims
    .map((claim) => ({ claim, filePath: resolvePath(claim, repoRoot) }))
    .filter(({ filePath }) => !exists(filePath));

  if (!claims.length) return result("claims", true, "No claimed output paths found");
  if (missing.length) {
    return result("claims", false, `Missing claimed outputs: ${missing.map((item) => item.claim).join(", ")}`);
  }
  return result("claims", true, `All ${claims.length} claimed output path(s) exist`);
}

function extractFreshnessCommit(text) {
  const patterns = [
    /\b(?:commit|revision|generatedFromCommit|lastVerifiedCommit)\b["':\s-]*([0-9a-f]{6,40})\b/i,
    /\*\s*generated_at:[^·\n]*·\s*commit:\s*([0-9a-f]{6,40})\b/i,
  ];
  for (const pattern of patterns) {
    const match = text.match(pattern);
    if (match) return match[1].slice(0, 12);
  }
  return "";
}

function extractCoveredScopes(text) {
  try {
    const json = JSON.parse(text);
    if (Array.isArray(json.coveredScopes)) {
      return json.coveredScopes.filter((scope) => typeof scope === "string" && scope.trim()).map((scope) => scope.trim());
    }
  } catch {
    // Markdown adapter; fall through to textual extraction.
  }

  const covered = text.match(/\bcovered:\s*([^·\n]+)/i);
  if (!covered) return [];
  return covered[1].split(/[,;]/).map((scope) => scope.trim()).filter(Boolean);
}

function isPathLikeScope(scope) {
  return scope.includes("/") || scope.includes(".") || scope === "src" || scope === "app" || scope === "modules" || scope === "lib";
}

function scopeMatches(filePath, scope) {
  const normalized = scope.replace(/^\.\//, "").replace(/\/$/, "");
  if (!normalized || normalized === ".") return true;
  if (!isPathLikeScope(normalized)) return false;
  return filePath === normalized || filePath.startsWith(`${normalized}/`);
}

function coveredChangesSince(repoRoot, stamp, head, adapterText) {
  const changed = gitChangedFiles(repoRoot, stamp, head);
  const scopes = extractCoveredScopes(adapterText);
  const pathLikeScopes = scopes.filter(isPathLikeScope);
  const defaultSourceScopes = [
    "src",
    "app",
    "modules",
    "lib",
    "components",
    "hooks",
    "services",
    "stores",
    "utils",
    "constants",
    "types",
    "package.json",
    "pnpm-lock.yaml",
    "yarn.lock",
    "package-lock.json",
  ];
  const activeScopes = pathLikeScopes.length ? pathLikeScopes : defaultSourceScopes;
  return changed.filter((filePath) => activeScopes.some((scope) => scopeMatches(filePath, scope)));
}

function checkAdapterFreshness(repoRoot, adapterPath) {
  if (!adapterPath || !exists(adapterPath)) return result("adapter-freshness", false, "Missing adapter/codebase-map/pattern-registry file");
  const head = gitHead(repoRoot);
  if (!head) {
    const nested = nestedGitRepos(repoRoot);
    const suffix = nested.length
      ? ` This looks like a workspace root; choose a git repo with --repo. Nested repos: ${nested.slice(0, 8).join(", ")}`
      : "";
    return result("adapter-freshness", false, `Could not resolve git HEAD.${suffix}`);
  }
  const text = read(adapterPath);
  const stamp = extractFreshnessCommit(text);
  if (!stamp) return result("adapter-freshness", false, `No freshness commit found in ${path.relative(repoRoot, adapterPath)}`);
  const exact = head.startsWith(stamp) || stamp.startsWith(head);
  if (exact) return result("adapter-freshness", true, `Adapter freshness matches HEAD ${head}`);

  if (!gitIsAncestor(repoRoot, stamp, "HEAD")) {
    return result("adapter-freshness", false, `Adapter freshness ${stamp} is not an ancestor of HEAD ${head}`);
  }

  const coveredChanges = coveredChangesSince(repoRoot, stamp, "HEAD", text);
  if (coveredChanges.length) {
    return result("adapter-freshness", false, `Adapter freshness ${stamp} is stale; covered changes since stamp: ${coveredChanges.slice(0, 8).join(", ")}`);
  }

  return result("adapter-freshness", true, `Adapter freshness ${stamp} is ancestor of HEAD ${head}; no covered changes since stamp`);
}

function mentionedEpics(text) {
  const epics = new Set();
  for (const match of text.matchAll(/\b(?:Epic|E)\s*[-_ ]?(\d+)\b/gi)) {
    epics.add(Number(match[1]));
  }
  return [...epics].filter(Boolean).sort((a, b) => a - b);
}

function hasEpicProcessJudge(text, epicNumber) {
  const epic = `Epic\\s+${epicNumber}\\s+Process\\s+Judge`;
  return new RegExp(epic, "i").test(text)
    || new RegExp(`epic[-_ ]${epicNumber}[-_ ]process[-_ ]judge`, "i").test(text);
}

function hasEpicProcessJudgePass(text, epicNumber) {
  if (!hasEpicProcessJudge(text, epicNumber)) return false;
  return /\b(Verdict|Status)\s*:\s*PASS\b/i.test(text)
    || new RegExp(`\\|[^\\n]*Epic\\s+${epicNumber}\\s+Process\\s+Judge[^\\n]*\\|[^\\n]*\\bPASS\\b`, "i").test(text);
}

function allArtifactText(repoRoot, ledgerPath) {
  const files = [
    ledgerPath,
    ...listFiles(path.join(repoRoot, "docs", "ai")),
    ...listFiles(path.join(repoRoot, "_bmad-output")),
  ].filter(Boolean).filter(exists);
  return files.map((filePath) => `\n--- ${path.relative(repoRoot, filePath)} ---\n${read(filePath)}`).join("\n");
}

function checkSeededEpicGates(repoRoot, ledgerPath) {
  if (!ledgerPath || !exists(ledgerPath)) return result("seeded-epic-gates", false, "Missing ledger path");
  const ledgerText = read(ledgerPath);
  const epics = mentionedEpics(ledgerText);
  if (!epics.length) return result("seeded-epic-gates", true, "No epics mentioned in ledger");
  const text = allArtifactText(repoRoot, ledgerPath);
  const missing = epics.filter((epicNumber) => !hasEpicProcessJudge(text, epicNumber));
  if (missing.length) return result("seeded-epic-gates", false, `Missing Epic Process Judge gate(s): ${missing.join(", ")}`);
  return result("seeded-epic-gates", true, `Epic Process Judge gate exists for epic(s): ${epics.join(", ")}`);
}

function checkEpicBoundary(repoRoot, ledgerPath, targetEpic) {
  if (!targetEpic || targetEpic <= 1) return result("epic-boundary", true, "No prior epic required");
  const prior = targetEpic - 1;
  const text = allArtifactText(repoRoot, ledgerPath);
  const ok = hasEpicProcessJudgePass(text, prior);
  return result("epic-boundary", ok, ok
    ? `Epic ${prior} Process Judge PASS found`
    : `Epic ${prior} Process Judge PASS required before starting Epic ${targetEpic}`);
}

function explicitEpicApprovalQuote(text, targetEpic) {
  const genericContinuation = /\b(go on|continue|devam|tamamla|bunları tamamla|proceed|ilerle)\b/i;
  const epicMention = new RegExp(`\\b(?:Epic|E)\\s*[-_ ]?${targetEpic}\\b`, "i");
  const approvalVerb = /\b(start|begin|launch|approve|approved|approval|başla|basla|başlat|baslat|geç|gec|onay|onayla|onaylandı|onaylandi)\b/i;

  const lines = text.split(/\r?\n/);
  for (const line of lines) {
    if (!epicMention.test(line)) continue;
    if (!/\b(user_quote|user quote|human quote|approval quote|approved by user|human approval|transition approval|epic transition approval)\b/i.test(line)) continue;
    if (!approvalVerb.test(line)) continue;
    if (genericContinuation.test(line) && !approvalVerb.test(line.replace(genericContinuation, ""))) continue;
    return line.trim();
  }

  return "";
}

function hasEpicTransitionApproval(text, targetEpic) {
  const approvalSection = extractSection(text, "Epic Transition Approval")
    || extractSection(text, `Epic ${targetEpic} Transition Approval`)
    || "";
  const searchText = approvalSection || text;
  const statusApproved = /\b(status|verdict|decision)\s*:\s*(?:APPROVED|PASS)\b/i.test(searchText)
    || /\bEpic\s*[-_ ]?\d+\s+Transition\s+Approval\b[^\n]*\b(APPROVED|PASS)\b/i.test(searchText);
  return statusApproved && explicitEpicApprovalQuote(searchText, targetEpic);
}

function explicitEpicApprovalQuoteValue(quote, targetEpic) {
  const text = String(quote || "");
  const epicMention = new RegExp(`\\b(?:Epic|E)\\s*[-_ ]?${targetEpic}\\b`, "i");
  const approvalVerb = /\b(start|begin|launch|approve|approved|approval|başla|basla|başlat|baslat|geç|gec|onay|onayla|onaylandı|onaylandi)\b/i;
  const genericOnly = /^\s*(?:go on|continue|devam|tamamla|bunları tamamla|proceed|ilerle)[.!\s]*$/i;
  return epicMention.test(text) && approvalVerb.test(text) && !genericOnly.test(text);
}

function checkTypedEpicTransitionApproval(repoRoot, targetEpic) {
  const files = jsonRecords(path.join(repoRoot, "docs", "ai", "approvals"));
  const failures = [];
  let matched = null;
  for (const filePath of files) {
    try {
      const approval = parseApproval(filePath);
      if (approval.targetEpic !== targetEpic) continue;
      if (approval.actorType !== "human" || approval.decision !== "APPROVE") continue;
      if (!explicitEpicApprovalQuoteValue(approval.userQuote, targetEpic)) {
        failures.push(`${approval.approvalId} lacks an explicit Epic ${targetEpic} approval quote`);
        continue;
      }
      if (crypto.createHash("sha256").update(approval.userQuote).digest("hex") !== approval.statementHash) {
        failures.push(`${approval.approvalId} statementHash mismatch`);
        continue;
      }
      const commitError = ancestorCommitError(repoRoot, approval.repositoryCommit, `approval ${approval.approvalId}`);
      if (commitError) {
        failures.push(commitError);
        continue;
      }
      matched = approval;
    } catch (error) {
      failures.push(`${path.relative(repoRoot, filePath)}: ${error.message}`);
    }
  }
  if (matched) return result("epic-transition-approval", true, `Typed human approval ${matched.approvalId} authorizes Epic ${targetEpic}`);
  return result("epic-transition-approval", false, failures.length
    ? failures.join("; ")
    : `Epic ${targetEpic} requires a typed human approval receipt`);
}

function checkEpicTransitionApproval(repoRoot, ledgerPath, targetEpic) {
  if (!targetEpic || targetEpic <= 1) return result("epic-transition-approval", true, "No explicit transition approval required for Epic 1");
  if (!ledgerPath || !exists(ledgerPath)) return result("epic-transition-approval", false, "Missing ledger path");
  if (typedActiveRun(repoRoot)) return checkTypedEpicTransitionApproval(repoRoot, targetEpic);
  const text = allArtifactText(repoRoot, ledgerPath);
  if (hasEpicTransitionApproval(text, targetEpic)) {
    return result("epic-transition-approval", true, `Explicit human approval found for Epic ${targetEpic}`);
  }
  return result("epic-transition-approval", false, `Epic ${targetEpic} requires explicit human approval. Generic continuation phrases such as "go on", "continue", "devam", or "tamamla" are not valid epic transition approval.`);
}

function checkReplanCounter(ledgerPath) {
  if (!ledgerPath || !exists(ledgerPath)) return result("replan-counter", false, "Missing ledger path");
  const text = read(ledgerPath);
  const count = (text.match(/\bREPLAN\b/g) || []).length;
  return result("replan-counter", count < 2, count < 2
    ? `REPLAN count ${count}`
    : `REPLAN count ${count}; human escalation required`);
}

function readPatternRegistry(registryPath) {
  if (!registryPath || !exists(registryPath)) {
    throw new Error("Missing docs/ai/pattern-registry.json");
  }
  return JSON.parse(read(registryPath));
}

const requiredPatternFields = [
  "id",
  "workShape",
  "status",
  "maturity",
  "enforcedBy",
  "evidence",
  "completionEvidence",
  "sourceEvidence",
  "goldenNeighbors",
  "reuseProbe",
  "doNotCopy",
  "confidence",
  "lastVerifiedAt",
  "lastVerifiedCommit",
  "refreshTriggers",
];

function checkPatternRegistry(registryPath) {
  let registry;
  try {
    registry = readPatternRegistry(registryPath);
  } catch (error) {
    return result("pattern-registry", false, error.message);
  }

  const missing = [];
  for (const field of ["schemaVersion", "repo", "generatedAt", "generatedFromCommit", "coveredScopes", "status", "patterns", "doNotCopy"]) {
    if (!(field in registry)) missing.push(field);
  }
  if (!Number.isInteger(registry.schemaVersion) || registry.schemaVersion < 2) {
    missing.push("schemaVersion>=2");
  }

  if (!Array.isArray(registry.patterns)) missing.push("patterns[]");
  if (!Array.isArray(registry.doNotCopy)) missing.push("doNotCopy[]");

  for (const [index, pattern] of (registry.patterns || []).entries()) {
    for (const field of requiredPatternFields) {
      if (!(field in pattern)) missing.push(`patterns[${index}].${field}`);
    }
    if (typeof pattern.completionEvidence !== "object" || pattern.completionEvidence === null || Array.isArray(pattern.completionEvidence)) {
      missing.push(`patterns[${index}].completionEvidence`);
    } else {
      for (const field of ["structure", "registration", "discoverability", "runtime"]) {
        if (!hasMeaningfulValue(pattern.completionEvidence[field])) {
          missing.push(`patterns[${index}].completionEvidence.${field}`);
        }
      }
    }
    if (!Array.isArray(pattern.sourceEvidence) || !pattern.sourceEvidence.length) missing.push(`patterns[${index}].sourceEvidence`);
    if (!Array.isArray(pattern.goldenNeighbors) || !pattern.goldenNeighbors.length) missing.push(`patterns[${index}].goldenNeighbors`);
    if (!Array.isArray(pattern.reuseProbe) || !pattern.reuseProbe.length) missing.push(`patterns[${index}].reuseProbe`);
  }

  for (const [index, entry] of (registry.doNotCopy || []).entries()) {
    for (const field of ["id", "reason", "sourceEvidence", "lastVerifiedCommit"]) {
      if (!(field in entry)) missing.push(`doNotCopy[${index}].${field}`);
    }
  }

  if (missing.length) return result("pattern-registry", false, `Missing required field(s): ${missing.slice(0, 12).join(", ")}`);
  return result("pattern-registry", true, `Registry ${registry.status} with ${registry.patterns.length} pattern(s) and ${registry.doNotCopy.length} do-not-copy entr(ies)`);
}

function registryTerms(registry) {
  const terms = new Set();
  for (const pattern of registry.patterns || []) {
    for (const term of pattern.reuseProbe || []) terms.add(String(term));
    for (const neighbor of pattern.goldenNeighbors || []) {
      if (neighbor?.path) terms.add(String(neighbor.path));
    }
  }
  return [...terms].filter(Boolean);
}

function checkReuseBeforeCreate(ledgerPath, registryPath) {
  if (!ledgerPath || !exists(ledgerPath)) return result("reuse-before-create", false, "Missing ledger path");

  let registry;
  try {
    registry = readPatternRegistry(registryPath);
  } catch (error) {
    return result("reuse-before-create", false, error.message);
  }

  const text = read(ledgerPath);
  if (!/reuse[- ]before[- ]create|reuse probe|reuse check|nearest neighbor|golden neighbor/i.test(text)) {
    return result("reuse-before-create", false, "Missing reuse-before-create / golden-neighbor ledger entry");
  }

  const terms = registryTerms(registry);
  const matched = terms.filter((term) => text.includes(term));
  if (!matched.length) {
    return result("reuse-before-create", false, "Reuse ledger entry does not cite any registry probe term or golden neighbor");
  }

  return result("reuse-before-create", true, `Reuse ledger cites registry evidence: ${matched.slice(0, 5).join(", ")}`);
}

function doNotCopyEntries(registry) {
  const entries = [];
  for (const entry of registry.doNotCopy || []) {
    entries.push({ id: entry.id, paths: (entry.sourceEvidence || []).map((source) => source.path).filter(Boolean) });
  }
  for (const pattern of registry.patterns || []) {
    for (const id of pattern.doNotCopy || []) entries.push({ id, paths: [] });
  }
  const seen = new Set();
  return entries.filter((entry) => {
    if (!entry.id || seen.has(entry.id)) return false;
    seen.add(entry.id);
    return true;
  });
}

function checkDoNotCopy(ledgerPath, registryPath) {
  if (!ledgerPath || !exists(ledgerPath)) return result("do-not-copy", false, "Missing ledger path");

  let registry;
  try {
    registry = readPatternRegistry(registryPath);
  } catch (error) {
    return result("do-not-copy", false, error.message);
  }

  const text = read(ledgerPath);
  const badMentions = [];
  for (const entry of doNotCopyEntries(registry)) {
    const idPattern = new RegExp(`\\b${entry.id.replace(/[.*+?^${}()|[\]\\]/g, "\\$&")}\\b`, "i");
    if (!idPattern.test(text)) continue;
    const line = text.split(/\r?\n/).find((item) => idPattern.test(item)) || "";
    if (!/\b(avoid|avoided|blocked|reject|rejected|do not copy|not copied|do-not-copy)\b/i.test(line)) {
      badMentions.push(entry.id);
    }
  }

  if (badMentions.length) {
    return result("do-not-copy", false, `Do-not-copy entr(y/ies) mentioned without rejection context: ${badMentions.join(", ")}`);
  }

  return result("do-not-copy", true, `No do-not-copy entry is treated as reusable (${doNotCopyEntries(registry).length} known)`);
}

function ledgerField(text, name) {
  const match = text.match(new RegExp(`^\\s*${name}\\s*:\\s*([^\\n#|]+)`, "im"));
  return match ? match[1].trim().replace(/[`"'.,;]+$/g, "") : "";
}

function hasHumanRiskAcceptance(text) {
  return /\b(human risk acceptance|risk acceptance|explicit human acceptance|human accepted risk|user accepted risk)\b/i.test(text);
}

function coveredWorkShapes(registry) {
  return new Set((registry.patterns || []).map((pattern) => String(pattern.workShape || "").trim()).filter(Boolean));
}

function partialWorkshapeVerdict(registry, ledgerText) {
  if (String(registry.status || "").toUpperCase() !== "PARTIAL") {
    return { ok: true, message: `Registry ${registry.status || "UNKNOWN"} does not require PARTIAL work-shape blocking` };
  }

  const track = ledgerField(ledgerText, "track").toLowerCase();
  const workShape = ledgerField(ledgerText, "workShape");
  const accepted = hasHumanRiskAcceptance(ledgerText);

  if (!workShape) return { ok: false, message: "PARTIAL registry requires ledger field workShape: <name>" };

  const covered = coveredWorkShapes(registry);
  const isCovered = covered.has(workShape);
  if (track === "guarded" && !accepted) {
    return { ok: false, message: `PARTIAL registry blocks guarded workShape ${workShape} without human risk acceptance` };
  }
  if (!isCovered && !accepted) {
    return { ok: false, message: `PARTIAL registry does not cover workShape ${workShape}; human risk acceptance required` };
  }

  if (!isCovered && accepted) return { ok: true, message: `Uncovered workShape ${workShape} allowed by human risk acceptance` };
  if (track === "guarded" && accepted) return { ok: true, message: `Guarded workShape ${workShape} allowed by human risk acceptance` };
  return { ok: true, message: `PARTIAL registry covers workShape ${workShape}` };
}

function checkPartialWorkshape(ledgerPath, registryPath) {
  if (!ledgerPath || !exists(ledgerPath)) return result("partial-workshape", false, "Missing ledger path");

  let registry;
  try {
    registry = readPatternRegistry(registryPath);
  } catch (error) {
    return result("partial-workshape", false, error.message);
  }

  const verdict = partialWorkshapeVerdict(registry, read(ledgerPath));
  return result("partial-workshape", verdict.ok, verdict.message);
}

function extractConformanceFindings(text) {
  const lines = text.split(/\r?\n/);
  const findings = [];
  for (let index = 0; index < lines.length; index += 1) {
    const line = lines[index];
    if (!/^\s*(?:[-*]\s*)?(?:conformance\s+)?finding(?:\s+\[[^\]]+\])?\s*[:|-]/i.test(line)) continue;
    const windowText = lines.slice(index, index + 8).join("\n");
    findings.push({ line: index + 1, text: windowText });
  }
  return findings;
}

function hasPromotionDisposition(text) {
  return /\bDisposition\s*:\s*(?:code\s+)?patch\b/i.test(text)
    || /\bDisposition\s*:\s*(?:pattern\s+)?registry\s+update\b/i.test(text)
    || /\bDisposition\s*:\s*do[- ]not[- ]copy\s+update\b/i.test(text)
    || /\bDisposition\s*:\s*(?:proposed\s+)?(?:mechanical|validator|hook|lint|fitness)\s+(?:check|gate|rule|test)\b/i.test(text)
    || /\bDisposition\s*:\s*(?:explicit\s+)?human\s+(?:decision\s+to\s+)?defer\b/i.test(text)
    || /\bDisposition\s*:\s*(?:accepted\s+risk|risk\s+acceptance|explicit\s+human\s+acceptance)\b/i.test(text);
}

function checkFindingPromotion(ledgerPath) {
  if (!ledgerPath || !exists(ledgerPath)) return result("finding-promotion", false, "Missing ledger path");
  const findings = extractConformanceFindings(read(ledgerPath));
  if (!findings.length) return result("finding-promotion", true, "No conformance findings recorded");

  const missing = findings.filter((finding) => !hasPromotionDisposition(finding.text));
  if (missing.length) {
    return result(
      "finding-promotion",
      false,
      `Conformance finding(s) missing disposition at line(s): ${missing.map((finding) => finding.line).join(", ")}`
    );
  }
  return result("finding-promotion", true, `All ${findings.length} conformance finding(s) have dispositions`);
}

function needsGraduationReconciliation(text) {
  return /\bDisposition\s*:\s*(?:pattern\s+)?registry\s+update\b/i.test(text)
    || /\bDisposition\s*:\s*do[- ]not[- ]copy\s+update\b/i.test(text)
    || /\bDisposition\s*:\s*(?:proposed\s+)?(?:mechanical|validator|hook|lint|fitness)\s+(?:check|gate|rule|test)\b/i.test(text);
}

function reconciliationLine(text) {
  return text.split(/\r?\n/).find((line) => /^\s*(?:[-*]\s*)?Reconciled\s*:/i.test(line)) || "";
}

function pathClaimsFromText(text) {
  const claims = new Set();
  const matches = [...text.matchAll(/`([^`]+)`|(?:^|[\s:])((?:\.\/)?(?:docs|src|app|modules|shared|lib|components|hooks|services|stores|utils|constants|types|tests?|specs?|scripts|claude-plugins|skills|method|\.github)\/[^\s,;|)]+)/g)];
  for (const match of matches) {
    const value = (match[1] || match[2] || "").replace(/[.,;:]$/, "");
    if (value && !/pending|none|n\/a/i.test(value)) claims.add(value);
  }
  return [...claims];
}

function normalizedTableHeader(value) {
  return String(value || "").trim().toLowerCase().replace(/[^a-z0-9]+/g, "");
}

function markdownTable(section) {
  const sectionLines = section.split(/\r?\n/);
  const start = sectionLines.findIndex((line) => /^\s*\|.*\|\s*$/.test(line));
  if (start < 0) return { headers: [], rows: [] };
  const lines = [];
  for (let index = start; index < sectionLines.length; index += 1) {
    if (!/^\s*\|.*\|\s*$/.test(sectionLines[index])) break;
    lines.push(sectionLines[index]);
  }
  if (lines.length < 3) return { headers: [], rows: [] };
  const cells = (line) => line.trim().slice(1, -1).split("|").map((cell) => cell.trim());
  const headers = cells(lines[0]).map(normalizedTableHeader);
  const rows = lines.slice(2).map(cells).filter((row) => row.some(hasMeaningfulValue));
  return { headers, rows };
}

function evidenceReference(value) {
  const normalized = String(value || "").trim().replace(/^`|`$/g, "");
  const separator = normalized.indexOf("#");
  if (separator <= 0 || separator === normalized.length - 1) return null;
  return {
    path: normalized.slice(0, separator).trim(),
    probe: normalized.slice(separator + 1).trim(),
  };
}

function verifyEvidenceReference(repoRoot, value, options = {}) {
  const reference = evidenceReference(value);
  if (!reference) return "must use path#probe evidence syntax";
  const filePath = resolvePath(reference.path, repoRoot);
  if (!exists(filePath)) return `missing evidence file ${reference.path}`;
  const content = read(filePath);
  if (!content.includes(reference.probe)) return `probe not found in ${reference.path}: ${reference.probe}`;
  if (options.requireAssertion && !/(?:\bassert\w*\s*\(|->assert\w*\s*\(|\bexpect\s*\(|\bshould\s*[.(]|\btest\s*\()/i.test(content)) {
    return `runtime evidence has no executable assertion in ${reference.path}`;
  }
  return "";
}

function checkVerticalSlice(repoRoot, ledgerPath) {
  if (!ledgerPath || !exists(ledgerPath)) return result("vertical-slice", false, "Missing ledger path");
  const section = extractSection(read(ledgerPath), "Vertical Slice Trace");
  if (!section) return result("vertical-slice", false, "Missing ## Vertical Slice Trace section");

  const table = markdownTable(section);
  const required = ["capability", "actor", "surface", "entrypoint", "entrypointevidence", "applicationpath", "runtimeevidence", "status"];
  const missingHeaders = required.filter((field) => !table.headers.includes(field));
  if (missingHeaders.length) {
    return result("vertical-slice", false, `Missing column(s): ${missingHeaders.join(", ")}`);
  }
  if (!table.rows.length) return result("vertical-slice", false, "Vertical Slice Trace has no capability rows");

  const index = Object.fromEntries(required.map((field) => [field, table.headers.indexOf(field)]));
  const supportingOnly = /^(?:controller|service|repository|model|form|seeder|helper|class|file|database)$/i;
  const failures = [];
  for (const [rowIndex, row] of table.rows.entries()) {
    const values = Object.fromEntries(required.map((field) => [field, normalizedFieldValue(row[index[field]])]));
    const missing = required.filter((field) => !hasMeaningfulValue(values[field]));
    if (missing.length) failures.push(`row ${rowIndex + 1}: missing ${missing.join("/")}`);
    if (supportingOnly.test(values.surface)) failures.push(`row ${rowIndex + 1}: supporting artifact is not a user/runtime surface`);
    if (!/(?:->|→)/.test(values.applicationpath)) failures.push(`row ${rowIndex + 1}: application path must show at least two linked layers`);
    if (!/^pass$/i.test(values.status)) failures.push(`row ${rowIndex + 1}: status must be PASS at close`);
    const entrypointError = verifyEvidenceReference(repoRoot, row[index.entrypointevidence]);
    if (entrypointError) failures.push(`row ${rowIndex + 1}: entrypoint evidence ${entrypointError}`);
    const runtimeError = verifyEvidenceReference(repoRoot, row[index.runtimeevidence], { requireAssertion: true });
    if (runtimeError) failures.push(`row ${rowIndex + 1}: runtime evidence ${runtimeError}`);
  }

  if (failures.length) return result("vertical-slice", false, failures.join("; "));
  return result("vertical-slice", true, `${table.rows.length} capability slice(s) reconcile to real surfaces and runtime evidence`);
}

function testFileCandidates(repoRoot) {
  const roots = ["tests", "test", "__tests__", "spec"].map((dir) => path.join(repoRoot, dir)).filter(exists);
  return roots.flatMap((root) => listFiles(root))
    .filter((filePath) => /\.(?:php|js|jsx|ts|tsx|mjs|cjs|py|rb|go|rs)$/i.test(filePath))
    .sort();
}

function splitTopLevelArguments(argsText) {
  const args = [];
  let current = "";
  let quote = "";
  let depth = 0;
  for (let index = 0; index < argsText.length; index += 1) {
    const char = argsText[index];
    const prev = argsText[index - 1];
    if (quote) {
      current += char;
      if (char === quote && prev !== "\\") quote = "";
      continue;
    }
    if (char === "\"" || char === "'" || char === "`") {
      quote = char;
      current += char;
      continue;
    }
    if ("([{".includes(char)) depth += 1;
    if (")]}".includes(char)) depth -= 1;
    if (char === "," && depth === 0) {
      args.push(current.trim());
      current = "";
      continue;
    }
    current += char;
  }
  if (current.trim()) args.push(current.trim());
  return args;
}

function simpleSelfAssertFailure(text, lineNumber) {
  const line = text.split(/\r?\n/)[lineNumber - 1] || "";
  const match = line.match(/\b(?:assertSame|assertEquals|toEqual|toBe|equal|deepEqual|strictEqual)\s*\((.*)\)/);
  if (!match) return "";
  const args = splitTopLevelArguments(match[1]);
  if (args.length < 2) return "";
  const left = args[0].replace(/\s+/g, " ");
  const right = args[1].replace(/\s+/g, " ");
  if (left && left === right) return "self-referential assertion compares a value with itself";
  return "";
}

function statusOnlySmokeFailure(block) {
  const nameLooksRuntime = /\b(?:smoke|runtime|gate|real[-_ ]?path|entrypoint|admin[-_ ]?route|cms[-_ ]?runtime)\b/i.test(block);
  if (!nameLooksRuntime) return "";
  const hasStatus = /(?:->assert(?:Ok|Status\s*\(\s*200)|\bassertStatus\s*\(\s*200|\bassertOk\s*\()/i.test(block);
  if (!hasStatus) return "";
  const hasMeaningfulAssertion = /(?:assertSee|assertDontSee|assertSeeText|assertJson|assertDatabase|assertRedirect|assertHeader|assertDownload|assertFile|assertMissing|assertExists|assertQueued|assertDispatched|assertSent|assertForbidden|assertUnauthorized|assertNotFound|assertNoContent|assertSessionHasErrors|assertInvalid|assertValid|expect\([^)]*\)->(?:toContain|not->toContain|toMatch|toHave)|assertStringContains|assertMatchesRegularExpression)/i.test(block);
  if (!hasMeaningfulAssertion) return "runtime/smoke/gate test checks only HTTP/status without content, negative, DB, storage, queue, or dispatch proof";
  return "";
}

function checkTestAuthenticity(repoRoot) {
  const files = testFileCandidates(repoRoot);
  if (!files.length) return result("test-authenticity", true, "No test files found");
  const failures = [];

  for (const filePath of files) {
    const relative = path.relative(repoRoot, filePath);
    const text = read(filePath);
    const lines = text.split(/\r?\n/);
    lines.forEach((line, index) => {
      const lineNumber = index + 1;
      if (/\baddWarning\s*\(/.test(line)) failures.push(`${relative}:${lineNumber} uses addWarning, which can turn a gate failure into a warning`);
      const selfAssert = simpleSelfAssertFailure(text, lineNumber);
      if (selfAssert) failures.push(`${relative}:${lineNumber} ${selfAssert}`);
    });

    for (const match of text.matchAll(/catch\s*\([^)]*\)\s*\{([\s\S]*?)\}/g)) {
      const block = match[1] || "";
      if (/\bcontinue\s*;/.test(block) || /\breturn\s*;/.test(block)) {
        const lineNumber = text.slice(0, match.index).split(/\r?\n/).length;
        failures.push(`${relative}:${lineNumber} catch block silently continues/returns; gate tests must fail or explicitly skip with a blocker`);
      }
    }

    const chunks = text.split(/\n\s*(?:public\s+)?function\s+|(?:^|\n)\s*(?:it|test)\s*\(/);
    for (const chunk of chunks.slice(1)) {
      const failure = statusOnlySmokeFailure(chunk);
      if (failure) {
        const prefix = text.slice(0, text.indexOf(chunk));
        const lineNumber = prefix ? prefix.split(/\r?\n/).length : 1;
        failures.push(`${relative}:${lineNumber} ${failure}`);
      }
    }
  }

  if (failures.length) return result("test-authenticity", false, failures.slice(0, 12).join("; "));
  return result("test-authenticity", true, `${files.length} test file(s) have no fake-green gate patterns`);
}

function isFullBmad(text) {
  return /\b(?:active_?lane|lane)\s*:\s*[^\n]*(?:full\s+)?bmad\b/i.test(text)
    || /\bfull\s+bmad\s+v?2\b/i.test(text);
}

function checkGuardedTestFloor(repoRoot, ledgerPath) {
  if (!ledgerPath || !exists(ledgerPath)) return result("guarded-test-floor", false, "Missing ledger path");
  const text = read(ledgerPath);
  const track = (ledgerField(text, "track") || ledgerField(text, "active_track")).toLowerCase();
  if (track !== "guarded") return result("guarded-test-floor", true, "Track is not guarded");

  const section = extractSection(text, "Guarded Test Floor");
  if (!section) return result("guarded-test-floor", false, "Missing ## Guarded Test Floor section");
  const fields = sessionHandoffFields(section);
  const required = ["boundary", "boundary_symbol", "test_evidence", "test_author_actor", "status"];
  const missing = required.filter((field) => !hasMeaningfulValue(fields[field]));
  if (missing.length) return result("guarded-test-floor", false, `Missing field(s): ${missing.join(", ")}`);
  if (!/^pass$/i.test(fields.status)) return result("guarded-test-floor", false, "Guarded test floor status must be PASS");
  if (/^(?:conductor|dispatcher|orchestrator|main|general-purpose)$/i.test(fields.test_author_actor)) {
    return result("guarded-test-floor", false, "Test Author must be a dedicated actor");
  }
  const reference = evidenceReference(fields.test_evidence);
  if (!reference || reference.probe !== fields.boundary_symbol) {
    return result("guarded-test-floor", false, "test_evidence must use path#probe with probe equal to boundary_symbol");
  }
  const evidenceError = verifyEvidenceReference(repoRoot, fields.test_evidence, { requireAssertion: true });
  if (evidenceError) return result("guarded-test-floor", false, evidenceError);
  return result("guarded-test-floor", true, `Guarded boundary ${fields.boundary} is grounded at ${fields.boundary_symbol}`);
}

function normalizedPhase(value) {
  return String(value || "").toLowerCase().replace(/[^a-z0-9]+/g, "");
}

function canonicalPhase(value) {
  const phase = normalizedPhase(value);
  const aliases = {
    dev: "development",
    developer: "development",
    review: "codereview",
    reviewer: "codereview",
    codereviewer: "codereview",
    verifier: "verifypatch",
    testreviewer: "testreview",
    judge: "processjudge",
    storyprocessjudge: "processjudge",
  };
  return aliases[phase] || phase;
}

function typedActiveRun(repoRoot) {
  const activeRunPath = path.join(repoRoot, "docs", "ai", "ACEF_ACTIVE_RUN.json");
  return exists(activeRunPath) ? parseActiveRun(activeRunPath) : null;
}

function checkTypedActorSeparation(repoRoot, activeRun) {
  const actorFiles = jsonRecords(path.join(repoRoot, "docs", "ai", "actors"));
  const actors = actorFiles.map(parseActorRecord).filter((actor) => normalizedScope(actor.story) === normalizedScope(activeRun.activeStory));
  const requiredPhases = ["atdd", "development", "codereview", "verifypatch", "testreview", "processjudge"];
  const byPhase = new Map();
  for (const actor of actors) {
    const phase = canonicalPhase(actor.phase);
    if (!byPhase.has(phase)) byPhase.set(phase, actor);
  }
  const missing = requiredPhases.filter((phase) => !byPhase.has(phase));
  if (missing.length) return result("actor-separation", false, `Typed actor records missing phase(s): ${missing.join(", ")}`);
  const ids = requiredPhases.map((phase) => byPhase.get(phase).actorInstanceId);
  const duplicates = ids.filter((id, index) => ids.indexOf(id) !== index);
  if (duplicates.length) return result("actor-separation", false, `Typed phase actors must be distinct: ${[...new Set(duplicates)].join(", ")}`);
  const failures = [];
  for (const phase of requiredPhases) {
    const actor = byPhase.get(phase);
    if (/^(?:conductor|dispatcher|orchestrator|main|general-purpose)$/i.test(actor.role)) failures.push(`${phase}: invalid role ${actor.role}`);
    const commitError = ancestorCommitError(repoRoot, actor.inputCommit, `actor ${actor.actorInstanceId}`);
    if (commitError) failures.push(commitError);
  }
  if (failures.length) return result("actor-separation", false, failures.join("; "));
  return result("actor-separation", true, `Six typed full-BMAD phase actors are distinct for ${activeRun.activeStory}`);
}

function checkActorSeparation(repoRoot, ledgerPath) {
  if (!ledgerPath || !exists(ledgerPath)) return result("actor-separation", false, "Missing ledger path");
  const text = read(ledgerPath);
  const activeRun = typedActiveRun(repoRoot);
  if (activeRun) {
    if (!["full-bmad", "guarded"].includes(activeRun.lane)) return result("actor-separation", true, "Typed lane is not full BMAD/guarded");
    return checkTypedActorSeparation(repoRoot, activeRun);
  }
  if (!isFullBmad(text)) return result("actor-separation", true, "Lane is not full BMAD");
  const section = extractSection(text, "Actor Separation");
  if (!section) return result("actor-separation", false, "Missing ## Actor Separation section");
  const table = markdownTable(section);
  const requiredHeaders = ["phase", "actor", "evidence"];
  const missingHeaders = requiredHeaders.filter((field) => !table.headers.includes(field));
  if (missingHeaders.length) return result("actor-separation", false, `Missing column(s): ${missingHeaders.join(", ")}`);
  const index = Object.fromEntries(requiredHeaders.map((field) => [field, table.headers.indexOf(field)]));
  const requiredPhases = ["atdd", "development", "codereview", "verifypatch", "testreview", "processjudge"];
  const rows = new Map(table.rows.map((row) => [normalizedPhase(row[index.phase]), row]));
  const missingPhases = requiredPhases.filter((phase) => !rows.has(phase));
  if (missingPhases.length) return result("actor-separation", false, `Missing phase(s): ${missingPhases.join(", ")}`);

  const actors = [];
  const failures = [];
  for (const phase of requiredPhases) {
    const row = rows.get(phase);
    const actor = normalizedFieldValue(row[index.actor]);
    actors.push(actor);
    if (!hasMeaningfulValue(actor)) failures.push(`${phase}: missing actor`);
    if (/^(?:conductor|dispatcher|orchestrator|main|general-purpose)$/i.test(actor)) failures.push(`${phase}: invalid actor ${actor}`);
    const reference = evidenceReference(row[index.evidence]);
    if (!reference || reference.probe !== actor) failures.push(`${phase}: evidence must use path#actor`);
    else {
      const evidenceError = verifyEvidenceReference(repoRoot, row[index.evidence]);
      if (evidenceError) failures.push(`${phase}: ${evidenceError}`);
    }
  }
  const duplicates = actors.filter((actor, indexValue) => actor && actors.indexOf(actor) !== indexValue);
  if (duplicates.length) failures.push(`actors must be distinct: ${[...new Set(duplicates)].join(", ")}`);
  if (failures.length) return result("actor-separation", false, failures.join("; "));
  return result("actor-separation", true, "Six full-BMAD phases have distinct actors and durable evidence");
}

function checkWorkerScope(repoRoot) {
  const activeRun = typedActiveRun(repoRoot);
  if (!activeRun) return result("worker-scope", true, "No typed active run; legacy scope checks remain in guards");
  if (!activeRun.workerRole || /^(?:conductor|dispatcher|orchestrator)$/i.test(activeRun.workerRole)) {
    return result("worker-scope", true, "Active run is not assigned to a worker");
  }
  const scopePath = resolvePath(activeRun.workerScopePath || "docs/ai/ACEF_ACTIVE_WORKER_SCOPE.json", repoRoot);
  if (!exists(scopePath)) return result("worker-scope", false, `Missing worker scope ${path.relative(repoRoot, scopePath)}`);
  try {
    const scope = parseWorkerScope(scopePath);
    const failures = [];
    if (normalizedScope(scope.activeStory) !== normalizedScope(activeRun.activeStory)) failures.push("activeStory does not match active run");
    if (canonicalPhase(scope.phase) !== canonicalPhase(activeRun.activePhase)) failures.push("phase does not match active run");
    if (activeRun.activeActorId && scope.workerId !== activeRun.activeActorId) failures.push("workerId does not match activeActorId");
    const actor = actorRecordById(repoRoot, scope.workerId);
    if (normalizedScope(actor.story) !== normalizedScope(scope.activeStory)) failures.push("worker actor story does not match scope");
    if (canonicalPhase(actor.phase) !== canonicalPhase(scope.phase)) failures.push("worker actor phase does not match scope");
    if (!gitIsAncestor(repoRoot, scope.baseRef, gitHead(repoRoot))) failures.push(`baseRef ${scope.baseRef} is not an ancestor of HEAD`);
    return failures.length
      ? result("worker-scope", false, failures.join("; "))
      : result("worker-scope", true, `${scope.workerId} is bound to ${scope.activeStory}/${scope.phase}`);
  } catch (error) {
    return result("worker-scope", false, error.message);
  }
}

function checkEvidenceManifests(repoRoot) {
  const activeRun = typedActiveRun(repoRoot);
  if (!activeRun) return result("evidence-manifest", true, "No typed active run; legacy evidence checks remain active");
  const files = jsonRecords(path.join(repoRoot, "docs", "ai", "evidence"));
  const records = [];
  const failures = [];
  for (const filePath of files) {
    try {
      const evidence = parseEvidenceManifest(filePath);
      if (normalizedScope(evidence.story) !== normalizedScope(activeRun.activeStory)) continue;
      records.push(evidence);
      failures.push(...validateEvidenceRecord(repoRoot, evidence));
    } catch (error) {
      failures.push(`${path.relative(repoRoot, filePath)}: ${error.message}`);
    }
  }
  const dirty = workingApplicationChanges(repoRoot);
  if (dirty.length) failures.push(`working tree has application changes: ${dirty.slice(0, 8).join(", ")}`);
  if (!records.length) failures.push(`No typed evidence manifests for ${activeRun.activeStory}`);
  return failures.length
    ? result("evidence-manifest", false, failures.join("; "))
    : result("evidence-manifest", true, `${records.length} typed evidence manifest(s) verified for ${activeRun.activeStory}`);
}

function checkGateVerdict(repoRoot) {
  const activeRun = typedActiveRun(repoRoot);
  if (!activeRun) return result("gate-verdict", true, "No typed active run; legacy gate checks remain active");
  let activeScope = null;
  if (activeRun.workerScopePath) {
    try {
      activeScope = parseWorkerScope(resolvePath(activeRun.workerScopePath, repoRoot));
    } catch {
      activeScope = null;
    }
  }
  const requiresDurableStateEvidence = stateChangingRisk(repoRoot, activeRun, activeScope);
  const files = jsonRecords(path.join(repoRoot, "docs", "ai", "gates"));
  const matching = [];
  const failures = [];
  for (const filePath of files) {
    try {
      const gate = parseGateVerdict(filePath);
      if (normalizedScope(gate.scope) === normalizedScope(activeRun.activeStory)) matching.push(gate);
    } catch (error) {
      failures.push(`${path.relative(repoRoot, filePath)}: ${error.message}`);
    }
  }
  const gate = matching.filter((record) => record.verdict === "PASS").sort((a, b) => String(b.createdAt || "").localeCompare(String(a.createdAt || "")))[0];
  if (!gate) failures.push(`No typed PASS gate verdict for ${activeRun.activeStory}`);
  if (gate) {
    try {
      const actor = actorRecordById(repoRoot, gate.decidedBy);
      if (normalizedScope(actor.story) !== normalizedScope(activeRun.activeStory)) failures.push(`gate actor ${gate.decidedBy} story mismatch`);
      if (canonicalPhase(actor.phase) !== "processjudge" && canonicalPhase(actor.phase) !== "epicprocessjudge") {
        failures.push(`gate actor ${gate.decidedBy} is not a Process Judge`);
      }
    } catch (error) {
      failures.push(error.message);
    }
    const commitError = recordCommitError(repoRoot, gate.repositoryCommit, `gate ${gate.gateId}`);
    if (commitError) failures.push(commitError);
    for (const evidenceId of gate.evidenceIds || []) {
      try {
        const evidence = evidenceRecordById(repoRoot, evidenceId);
        if (evidence.exitCode !== 0) failures.push(`PASS gate cites failed evidence ${evidenceId}`);
        if (/^\s*story\b/i.test(activeRun.activeStory)
          && normalizedScope(evidence.story) !== normalizedScope(activeRun.activeStory)) {
          failures.push(`PASS gate cites evidence ${evidenceId} from another story`);
        }
        failures.push(...validateEvidenceRecord(repoRoot, evidence));
      } catch (error) {
        failures.push(error.message);
      }
    }
    const fullSurfaceValidation = ["full-bmad", "guarded"].includes(activeRun.lane);
    if (fullSurfaceValidation && !activeScope?.surfaces?.length) {
      failures.push(`${activeRun.lane} PASS gate requires active worker scope surfaces`);
    }
    if (fullSurfaceValidation && activeScope?.surfaces?.length) {
      for (const surface of missingInferredSurfaces(repoRoot, activeScope.surfaces, activeScope)) {
        failures.push(`surface inferred from changed paths but not declared in active worker scope: ${surface}`);
      }
      const surfaceEvidence = gate.surfaceEvidence || [];
      for (const surface of activeScope.surfaces) {
        const match = surfaceEvidence.find((entry) => entry.surface === surface);
        if (!match) {
          failures.push(`${activeRun.lane} PASS gate requires surface evidence for ${surface}`);
          continue;
        }
        try {
          const evidence = evidenceRecordById(repoRoot, match.evidenceId);
          if (evidence.exitCode !== 0) failures.push(`surface ${surface} cites failed evidence ${match.evidenceId}`);
          if (!gate.evidenceIds?.includes(match.evidenceId)) {
            failures.push(`surface ${surface} cites evidence ${match.evidenceId} not listed in evidenceIds`);
          }
          if (/^\s*story\b/i.test(activeRun.activeStory)
            && normalizedScope(evidence.story) !== normalizedScope(activeRun.activeStory)) {
            failures.push(`surface ${surface} cites evidence ${match.evidenceId} from another story`);
          }
        } catch (error) {
          failures.push(error.message);
        }
      }
    }
    for (const surfaceEntry of gate.surfaceEvidence || []) {
      try {
        const evidence = evidenceRecordById(repoRoot, surfaceEntry.evidenceId);
        if (evidence.exitCode !== 0) failures.push(`surface ${surfaceEntry.surface} cites failed evidence ${surfaceEntry.evidenceId}`);
        if (!gate.evidenceIds?.includes(surfaceEntry.evidenceId)) {
          failures.push(`surface ${surfaceEntry.surface} cites evidence ${surfaceEntry.evidenceId} not listed in evidenceIds`);
        }
        if (surfaceEntry.firstUsePattern && !surfaceEntry.roundTrip) {
          failures.push(`surface ${surfaceEntry.surface} first-use pattern requires roundTrip=true`);
        }
      } catch (error) {
        failures.push(error.message);
      }
    }
    for (const bindingEntry of gate.inputOutputEvidence || []) {
      const label = `${bindingEntry.inputSurface}>${bindingEntry.outputSurface}:${bindingEntry.field}`;
      try {
        const evidence = evidenceRecordById(repoRoot, bindingEntry.evidenceId);
        if (evidence.exitCode !== 0) failures.push(`binding ${label} cites failed evidence ${bindingEntry.evidenceId}`);
        if (!gate.evidenceIds?.includes(bindingEntry.evidenceId)) {
          failures.push(`binding ${label} cites evidence ${bindingEntry.evidenceId} not listed in evidenceIds`);
        }
      } catch (error) {
        failures.push(error.message);
      }
    }
    const scopeRequiresRoundTrip = activeScope
      && (activeScope.requiresRoundTrip === true || activeScope.patternUse === "new-reusable-pattern");
    if (scopeRequiresRoundTrip) {
      const roundTripSurfaces = new Set((gate.surfaceEvidence || [])
        .filter((entry) => entry.roundTrip === true)
        .map((entry) => entry.surface));
      const requiredSurfaces = activeScope.surfaces?.length ? activeScope.surfaces : ["surface"];
      for (const surface of requiredSurfaces) {
        if (!roundTripSurfaces.has(surface)) {
          failures.push(`scope requires round-trip surface evidence for ${surface}`);
        }
      }
    }
    if (activeScope?.inputOutputBindings?.length) {
      const bindingEvidence = gate.inputOutputEvidence || [];
      for (const binding of activeScope.inputOutputBindings) {
        const label = `${binding.inputSurface}>${binding.outputSurface}:${binding.field}`;
        const match = bindingEvidence.find((entry) => entry.inputSurface === binding.inputSurface
          && entry.outputSurface === binding.outputSurface
          && entry.field === binding.field);
        if (!match) {
          failures.push(`scope requires input-output binding evidence for ${label}`);
          continue;
        }
        if (match.nonDefaultValue !== true) {
          failures.push(`binding ${label} requires nonDefaultValue=true`);
        }
        if (binding.defaultMaskingRisk === true && match.defaultRejected !== true) {
          failures.push(`binding ${label} has default masking risk and requires defaultRejected=true`);
        }
      }
    }
    if (requiresDurableStateEvidence) {
      const durableEvidenceIds = [...new Set([
        ...(gate.evidenceIds || []),
        ...(gate.surfaceEvidence || []).map((entry) => entry.evidenceId),
        ...(gate.inputOutputEvidence || []).map((entry) => entry.evidenceId),
      ].filter(Boolean))];
      const rawTexts = [];
      for (const evidenceId of durableEvidenceIds) {
        try {
          rawTexts.push(evidenceRawText(repoRoot, evidenceRecordById(repoRoot, evidenceId)));
        } catch {
          // Missing evidence is reported by the normal evidence validation path.
        }
      }
      if (!rawTexts.some(durablePersistenceEvidenceText)) {
        failures.push(stateChangingEvidenceFailure("state-changing PASS gate", rawTexts.join("\n")));
      }
    }
  }
  return failures.length
    ? result("gate-verdict", false, failures.join("; "))
    : result("gate-verdict", true, `${gate.gateId} PASS is actor-bound and evidence-backed`);
}

function checkSourceReconciliation(repoRoot, ledgerPath) {
  if (!ledgerPath || !exists(ledgerPath)) return result("source-reconciliation", false, "Missing ledger path");
  const text = read(ledgerPath);
  const activeRun = typedActiveRun(repoRoot);
  if (activeRun && !["full-bmad", "guarded"].includes(activeRun.lane)) {
    return result("source-reconciliation", true, "Lane is not full BMAD/guarded");
  }
  if (!activeRun && !isFullBmad(text)) return result("source-reconciliation", true, "Lane is not full BMAD");
  const section = extractSection(text, "Source Reconciliation");
  if (!section) return result("source-reconciliation", false, "Missing ## Source Reconciliation section");
  const table = markdownTable(section);
  const required = ["source", "path", "decision", "discrepancy", "resolution"];
  const missingHeaders = required.filter((field) => !table.headers.includes(field));
  if (missingHeaders.length) return result("source-reconciliation", false, `Missing column(s): ${missingHeaders.join(", ")}`);
  if (!table.rows.length) return result("source-reconciliation", false, "Source Reconciliation has no source rows");
  const index = Object.fromEntries(required.map((field) => [field, table.headers.indexOf(field)]));
  const failures = [];
  for (const [rowIndex, row] of table.rows.entries()) {
    const source = normalizedFieldValue(row[index.source]);
    const sourcePath = String(row[index.path] || "").trim().replace(/^`|`$/g, "");
    const decision = normalizedPhase(row[index.decision]);
    const discrepancy = normalizedFieldValue(row[index.discrepancy]);
    const resolution = normalizedFieldValue(row[index.resolution]);
    if (!hasMeaningfulValue(source)) failures.push(`row ${rowIndex + 1}: missing source`);
    if (!sourcePath || !exists(resolvePath(sourcePath, repoRoot))) failures.push(`row ${rowIndex + 1}: missing source path ${sourcePath || "<empty>"}`);
    if (!new Set(["used", "notused", "conflict"]).has(decision)) failures.push(`row ${rowIndex + 1}: decision must be USED, NOT USED, or CONFLICT`);
    if (decision === "conflict" && !hasMeaningfulValue(discrepancy)) failures.push(`row ${rowIndex + 1}: conflict requires discrepancy`);
    if ((decision === "conflict" || decision === "notused") && !hasMeaningfulValue(resolution)) failures.push(`row ${rowIndex + 1}: ${decision} requires resolution`);
    if (/^(?:pending|tbd|unresolved|open)$/i.test(resolution)) failures.push(`row ${rowIndex + 1}: resolution remains open`);
  }
  if (failures.length) return result("source-reconciliation", false, failures.join("; "));
  return result("source-reconciliation", true, `${table.rows.length} planning source(s) reconciled`);
}

function checkEpicContextPack(repoRoot, ledgerPath) {
  if (!ledgerPath || !exists(ledgerPath)) return result("epic-context-pack", false, "Missing ledger path");
  const text = read(ledgerPath);
  if (!isFullBmad(text)) return result("epic-context-pack", true, "Lane is not full BMAD");
  const section = extractSection(text, "Epic Context Pack");
  if (!section) return result("epic-context-pack", false, "Missing ## Epic Context Pack section");

  const fields = sessionHandoffFields(section);
  const required = ["status", "scope", "pack_path", "consumed_by_story", "worker_input_mode", "broad_repo_reread"];
  const missing = required.filter((field) => !hasMeaningfulValue(fields[field]));
  if (missing.length) return result("epic-context-pack", false, `Missing field(s): ${missing.join(", ")}`);

  const failures = [];
  if (!/^pass$/i.test(fields.status)) failures.push("status must be PASS");
  if (!/pack.*story|story.*pack|pack-plus-story|pack_only|pack-only/i.test(fields.worker_input_mode)) {
    failures.push("worker_input_mode must declare pack + narrow story input");
  }
  if (!/^(?:no|false|blocked|forbidden)$/i.test(fields.broad_repo_reread || "")) {
    failures.push("broad_repo_reread must be no/false/blocked/forbidden");
  }

  const packPath = resolvePath(fields.pack_path, repoRoot);
  if (!exists(packPath)) {
    failures.push(`pack_path missing file ${fields.pack_path}`);
  } else {
    const pack = read(packPath);
    const requiredHeadings = [
      "Resolved Patterns",
      "Golden Neighbors",
      "Source Reconciliation Summary",
      "Risk List",
      "Test Strategy",
      "Reusable Fixtures",
      "Allowed Scope",
      "Deferred Scope",
      "Exact Commands",
      "Known Pitfalls",
      "Per-Story Touched Surfaces",
    ];
    const missingHeadings = requiredHeadings.filter((heading) => !new RegExp(`^\\s*#{1,6}\\s+${heading}\\s*$`, "im").test(pack));
    if (missingHeadings.length) failures.push(`pack missing heading(s): ${missingHeadings.join(", ")}`);
  }

  if (failures.length) return result("epic-context-pack", false, failures.join("; "));
  return result("epic-context-pack", true, `${fields.scope} context pack is ready and story-scoped`);
}

function checkCurrentContext(repoRoot, ledgerPath) {
  if (!ledgerPath || !exists(ledgerPath)) return result("current-context", false, "Missing ledger path");
  const ledgerText = read(ledgerPath);
  const activeRunPath = path.join(repoRoot, "docs", "ai", "ACEF_ACTIVE_RUN.json");
  const activeRun = exists(activeRunPath) ? parseActiveRun(activeRunPath) : null;
  if (activeRun && resolvePath(activeRun.ledgerPath, repoRoot) !== path.resolve(ledgerPath)) {
    return result("current-context", false, "ACEF_ACTIVE_RUN.json ledgerPath does not match active ledger");
  }

  const fields = activeRun ? {
    status: ["active", "complete"].includes(activeRun.status) ? "PASS" : activeRun.status,
    context_path: activeRun.contextPath || "",
    active_story: activeRun.activeStory || "",
    active_phase: activeRun.activePhase || "",
    worker_role: activeRun.workerRole || "",
    full_ledger_access: activeRun.fullLedgerAccess || "",
    max_lines: activeRun.maxLines === undefined || activeRun.maxLines === null ? "" : String(activeRun.maxLines),
  } : sessionHandoffFields(extractSection(ledgerText, "Current Context Contract"));

  const fullBmad = activeRun ? ["full-bmad", "guarded"].includes(activeRun.lane) : isFullBmad(ledgerText);
  if (!fullBmad) return result("current-context", true, "Lane is not full BMAD/guarded");

  if (!activeRun && !extractSection(ledgerText, "Current Context Contract")) {
    return result("current-context", false, "Missing ## Current Context Contract section");
  }

  const required = [
    "status",
    "context_path",
    "active_story",
    "active_phase",
    "worker_role",
    "full_ledger_access",
    "max_lines",
  ];
  const missing = required.filter((field) => !hasMeaningfulValue(fields[field]));
  if (missing.length) return result("current-context", false, `Missing field(s): ${missing.join(", ")}`);

  const failures = [];
  if (!/^pass$/i.test(fields.status)) failures.push("status must be PASS");

  const role = fields.worker_role.toLowerCase().replace(/[\s_]+/g, "-");
  const standardRoles = new Set([
    "planner",
    "pm",
    "atdd",
    "test-author",
    "developer",
    "dev",
    "code-review",
    "reviewer",
    "verify-patch",
    "test-review",
  ]);
  if (role === "epic-judge" || role === "epic-process-judge") {
    if (!/^(?:allowed|full|yes|true)$/i.test(fields.full_ledger_access)) {
      failures.push("epic judge requires full_ledger_access: allowed/full");
    }
  } else if (role === "process-judge" || role === "story-process-judge") {
    if (!/^(?:story-slice|story_slice|scoped|compact)$/i.test(fields.full_ledger_access)) {
      failures.push("story Process Judge requires full_ledger_access: story-slice/scoped");
    }
  } else if (standardRoles.has(role)) {
    if (!/^(?:denied|no|false|blocked|forbidden)$/i.test(fields.full_ledger_access)) {
      failures.push(`${fields.worker_role} requires full_ledger_access: denied`);
    }
  } else {
    failures.push(`unsupported worker_role: ${fields.worker_role}`);
  }

  const maxLines = Number(fields.max_lines);
  if (!Number.isInteger(maxLines) || maxLines < 1 || maxLines > 150) {
    failures.push("max_lines must be an integer between 1 and 150");
  }

  const contextPath = resolvePath(fields.context_path, repoRoot);
  if (!exists(contextPath)) {
    failures.push(`context_path missing file ${fields.context_path}`);
  } else {
    const context = read(contextPath);
    const lineCount = context.split(/\r?\n/).length;
    if (Number.isInteger(maxLines) && lineCount > maxLines) failures.push(`context has ${lineCount} lines; max_lines is ${maxLines}`);
    if (lineCount > 150) failures.push(`context exceeds hard limit of 150 lines (${lineCount})`);

    const contextFields = sessionHandoffFields(context);
    const contextRequired = ["source_ledger", "active_story", "active_phase", "last_passed_gate"];
    const contextMissing = contextRequired.filter((field) => !hasMeaningfulValue(contextFields[field]));
    if (contextMissing.length) failures.push(`context missing field(s): ${contextMissing.join(", ")}`);

    if (hasMeaningfulValue(contextFields.source_ledger)) {
      const declaredLedger = resolvePath(contextFields.source_ledger, repoRoot);
      if (path.resolve(declaredLedger) !== path.resolve(ledgerPath)) failures.push("source_ledger does not match active ledger");
    }
    if (hasMeaningfulValue(contextFields.active_story)
      && normalizedFieldValue(contextFields.active_story).toLowerCase() !== normalizedFieldValue(fields.active_story).toLowerCase()) {
      failures.push("context active_story does not match ledger contract");
    }
    if (hasMeaningfulValue(contextFields.active_phase)
      && normalizedFieldValue(contextFields.active_phase).toLowerCase() !== normalizedFieldValue(fields.active_phase).toLowerCase()) {
      failures.push("context active_phase does not match ledger contract");
    }

    const handoff = sessionHandoffFields(extractSection(ledgerText, "Session Handoff"));
    if (hasMeaningfulValue(handoff.last_passed_gate)
      && hasMeaningfulValue(contextFields.last_passed_gate)
      && normalizedFieldValue(handoff.last_passed_gate).toLowerCase() !== normalizedFieldValue(contextFields.last_passed_gate).toLowerCase()) {
      failures.push("context last_passed_gate does not match Session Handoff");
    }

    const requiredHeadings = [
      "Current Work",
      "Gate State",
      "Allowed Scope",
      "Relevant Acceptance Criteria",
      "Required Commands",
      "Deferred and Out of Scope",
      "Known Pitfalls",
      "Artifact Paths",
      "Role Inputs",
    ];
    const missingHeadings = requiredHeadings.filter((heading) => !new RegExp(`^\\s*#{1,6}\\s+${heading}\\s*$`, "im").test(context));
    if (missingHeadings.length) failures.push(`context missing heading(s): ${missingHeadings.join(", ")}`);
  }

  if (failures.length) return result("current-context", false, failures.join("; "));
  return result("current-context", true, `${fields.active_story}/${fields.active_phase} hot context is reconciled for ${fields.worker_role}`);
}

function checkGraduationReconciliation(repoRoot, ledgerPath) {
  if (!ledgerPath || !exists(ledgerPath)) return result("graduation-reconciliation", false, "Missing ledger path");
  const findings = extractConformanceFindings(read(ledgerPath)).filter((finding) => needsGraduationReconciliation(finding.text));
  if (!findings.length) return result("graduation-reconciliation", true, "No graduation dispositions recorded");

  const missing = [];
  for (const finding of findings) {
    const line = reconciliationLine(finding.text);
    if (!line) {
      missing.push(`${finding.line}: missing Reconciled`);
      continue;
    }
    if (/\benforcedBy\s*:\s*[^,\s]+/i.test(line)) continue;
    const claims = pathClaimsFromText(line);
    if (!claims.length) {
      missing.push(`${finding.line}: missing path/enforcedBy`);
      continue;
    }
    const existing = claims.some((claim) => exists(resolvePath(claim, repoRoot)));
    if (!existing) missing.push(`${finding.line}: missing reconciled file`);
  }

  if (missing.length) {
    return result("graduation-reconciliation", false, `Graduation reconciliation missing for finding(s): ${missing.join("; ")}`);
  }
  return result("graduation-reconciliation", true, `All ${findings.length} graduation disposition(s) reconcile to evidence`);
}

function extractSection(text, title) {
  const lines = text.split(/\r?\n/);
  const start = lines.findIndex((line) => new RegExp(`^\\s*#{1,6}\\s+${title}\\s*$`, "i").test(line));
  if (start < 0) return "";
  let end = lines.length;
  for (let index = start + 1; index < lines.length; index += 1) {
    if (/^\s*#{1,6}\s+/.test(lines[index])) {
      end = index;
      break;
    }
  }
  return lines.slice(start, end).join("\n");
}

function normalizedFieldValue(value) {
  return String(value || "").trim().replace(/[`"'.,;]+$/g, "");
}

function sessionHandoffFields(section) {
  const fields = {};
  for (const line of section.split(/\r?\n/)) {
    const match = line.match(/^\s*(?:[-*]\s*)?([A-Za-z][A-Za-z0-9_-]*)\s*:\s*(.+?)\s*$/);
    if (!match) continue;
    fields[match[1].trim().toLowerCase().replace(/-/g, "_")] = normalizedFieldValue(match[2]);
  }
  return fields;
}

function hasMeaningfulValue(value) {
  return Boolean(value) && !/^(?:none|n\/a|null|unknown|tbd|pending)$/i.test(value);
}

function pathExistsField(repoRoot, fields, field) {
  if (!hasMeaningfulValue(fields[field])) return `${field} missing`;
  const filePath = resolvePath(fields[field], repoRoot);
  return exists(filePath) ? "" : `${field} missing file ${fields[field]}`;
}

function checkLeanEvidence(repoRoot, ledgerPath) {
  if (!ledgerPath || !exists(ledgerPath)) return result("lean-evidence", false, "Missing ledger path");
  const text = read(ledgerPath);
  const section = extractSection(text, "Lean Evidence Contract");
  if (!section) return result("lean-evidence", false, "Missing ## Lean Evidence Contract section");

  const fields = sessionHandoffFields(section);
  const required = [
    "status",
    "scope",
    "worker_report",
    "review_report",
    "process_judge_report",
    "session_handoff_updated",
    "worker_context",
    "fork_context",
    "raw_output_policy",
    "diff_policy",
    "test_output_policy",
    "search_output_policy",
  ];
  const missing = required.filter((field) => !hasMeaningfulValue(fields[field]));
  if (missing.length) return result("lean-evidence", false, `Missing field(s): ${missing.join(", ")}`);

  const failures = [];
  for (const field of ["worker_report", "review_report", "process_judge_report"]) {
    const pathFailure = pathExistsField(repoRoot, fields, field);
    if (pathFailure) failures.push(pathFailure);
  }

  if (!/^yes|true|pass$/i.test(fields.session_handoff_updated)) {
    failures.push("session_handoff_updated must be yes/true/PASS");
  }
  if (!/^(bounded|minimal|scoped)$/i.test(fields.worker_context || "")) {
    failures.push("worker_context must be bounded/minimal/scoped");
  }
  if (!/^(false|no|off|disabled)$/i.test(fields.fork_context || "")) {
    failures.push("fork_context must be false/no/off/disabled");
  }
  if (!/^(artifact-only|artifact_only|disk|disk-only|disk_only)$/i.test(fields.raw_output_policy || "")) {
    failures.push("raw_output_policy must be artifact-only/disk-only");
  }
  if (!/^(targeted|path-scoped|path_scoped|commit-scoped|commit_scoped|summary-only|summary_only)$/i.test(fields.diff_policy || "")) {
    failures.push("diff_policy must be targeted/path-scoped/commit-scoped/summary-only");
  }
  if (!/^(summary-only|summary_only|artifact-only|artifact_only|disk-only|disk_only)$/i.test(fields.test_output_policy || "")) {
    failures.push("test_output_policy must be summary-only/artifact-only/disk-only");
  }
  if (!/^(summarized|summary-only|summary_only|targeted|artifact-only|artifact_only)$/i.test(fields.search_output_policy || "")) {
    failures.push("search_output_policy must be summarized/targeted/artifact-only");
  }

  if (/epic/i.test(fields.scope)) {
    const recommendation = fields.fresh_session_recommended || fields.fresh_session_handoff;
    if (!/^yes|true|pass$/i.test(recommendation || "")) {
      failures.push("epic scope requires fresh_session_recommended: yes");
    }
  }

  if (!/^pass$/i.test(fields.status)) failures.push("status must be PASS at close");
  if (failures.length) return result("lean-evidence", false, failures.join("; "));
  return result("lean-evidence", true, `${fields.scope} evidence is artifact-backed and handoff is refreshed`);
}

function checkSessionHandoff(repoRoot, ledgerPath, adapterPath, registryPath) {
  if (!ledgerPath || !exists(ledgerPath)) return result("session-handoff", false, "Missing ledger path");

  for (const filePath of [adapterPath, registryPath].filter(Boolean).filter(exists)) {
    if (filePath === ledgerPath) continue;
    if (/session\s+handoff/i.test(read(filePath))) {
      return result("session-handoff", false, `Session Handoff belongs in the delivery ledger, not ${path.relative(repoRoot, filePath)}`);
    }
  }

  const section = extractSection(read(ledgerPath), "Session Handoff");
  if (!section) return result("session-handoff", false, "Missing ## Session Handoff block");

  const fields = sessionHandoffFields(section);
  const required = [
    "status",
    "current_step",
    "last_passed_gate",
    "next_allowed_step",
    "active_lane",
    "active_track",
    "ledger_path",
  ];
  const missing = required.filter((field) => !hasMeaningfulValue(fields[field]));
  if (missing.length) return result("session-handoff", false, `Missing Session Handoff field(s): ${missing.join(", ")}`);

  const declaredLedgerPath = resolvePath(fields.ledger_path, repoRoot);
  if (!exists(declaredLedgerPath)) {
    return result("session-handoff", false, `Session Handoff ledger_path does not exist: ${fields.ledger_path}`);
  }

  const guardedOrBlocked = /^guarded$/i.test(fields.active_track)
    || /^(?:blocked|hold|halt)$/i.test(fields.status);
  if (guardedOrBlocked
    && !hasMeaningfulValue(fields.blocked_on)
    && !hasMeaningfulValue(fields.do_not_continue_without)) {
    return result("session-handoff", false, "Guarded/blocked handoff requires blocked_on or do_not_continue_without");
  }

  return result("session-handoff", true, `Session Handoff ready; next allowed step: ${fields.next_allowed_step}`);
}

function checkPrReview(repoRoot) {
  const manifestPath = path.join(repoRoot, "docs", "ai", "ACEF_PR_REVIEW.json");
  if (!exists(manifestPath)) return result("pr-review", false, "Missing docs/ai/ACEF_PR_REVIEW.json");
  try {
    const review = parsePrReview(manifestPath);
    const failures = [];
    const head = cp.execFileSync("git", ["rev-parse", "HEAD"], { cwd: repoRoot, encoding: "utf8" }).trim();
    if (head !== review.headCommit) failures.push(`review HEAD changed from ${review.headCommit} to ${head}`);
    if (!gitIsAncestor(repoRoot, review.baseCommit, review.headCommit)) failures.push("baseCommit is not an ancestor of headCommit");

    const requiredInputs = [review.inputs.issuePath, review.inputs.adapterPath, review.inputs.patternRegistryPath, ...review.inputs.qaEvidencePaths, ...review.broadReadPaths];
    for (const input of requiredInputs) {
      if (!exists(path.join(repoRoot, input))) failures.push(`missing review input ${input}`);
    }
    const profilePath = path.join(repoRoot, review.reviewProfile.path);
    let profile = null;
    if (!exists(profilePath)) failures.push(`missing review profile ${review.reviewProfile.path}`);
    else {
      const profileText = read(profilePath);
      if (sha256(profileText) !== review.reviewProfile.sha256) failures.push("review profile hash mismatch");
      try {
        profile = parsePrReviewProfile(profilePath);
      } catch (error) {
        failures.push(`invalid review profile: ${error.message}`);
      }
    }
    if (profile) {
      if (profile.reviewId !== review.reviewId) failures.push("review profile reviewId mismatch");
      if (profile.baseCommit !== review.baseCommit) failures.push("review profile baseCommit mismatch");
      if (profile.headCommit !== review.headCommit) failures.push("review profile headCommit mismatch");
      if (JSON.stringify(profile.changedFiles) !== JSON.stringify(review.changedFiles)) failures.push("review profile changedFiles mismatch");
      if (JSON.stringify(profile.selectedPaths) !== JSON.stringify(review.selectedPaths)) failures.push("review profile selectedPaths mismatch");
      if (JSON.stringify([...profile.workShapes].sort()) !== JSON.stringify([...review.workShapes].sort())) failures.push("review profile workShapes mismatch");
      const adapterPath = path.join(repoRoot, review.inputs.adapterPath);
      const registryPath = path.join(repoRoot, review.inputs.patternRegistryPath);
      if (profile.source.adapter.path !== review.inputs.adapterPath) failures.push("review profile adapter path mismatch");
      if (profile.source.patternRegistry.path !== review.inputs.patternRegistryPath) failures.push("review profile pattern registry path mismatch");
      if (exists(adapterPath) && sha256File(adapterPath) !== profile.source.adapter.sha256) failures.push("review profile adapter source hash mismatch");
      if (exists(registryPath) && sha256File(registryPath) !== profile.source.patternRegistry.sha256) failures.push("review profile pattern registry source hash mismatch");
      const profileShapes = new Set(profile.selectedPatterns.map((pattern) => pattern.workShape));
      const missingShapes = review.workShapes.filter((shape) => !profileShapes.has(shape));
      if (missingShapes.length) failures.push(`review profile missing workShape coverage: ${missingShapes.join(", ")}`);
      if (profile.genericRulesSupplementOnly !== true) failures.push("review profile must mark generic rules as supplement-only");
    }
    const diffPath = path.join(repoRoot, review.diffArtifact.path);
    if (!exists(diffPath)) failures.push(`missing diff artifact ${review.diffArtifact.path}`);
    else {
      if (sha256File(diffPath) !== review.diffArtifact.sha256) failures.push("diff artifact hash mismatch");
      const lineCount = read(diffPath).split(/\r?\n/).length - (read(diffPath).endsWith("\n") ? 1 : 0);
      if (lineCount !== review.diffArtifact.lineCount) failures.push("diff artifact lineCount mismatch");
      if (lineCount > review.maxDiffLines) failures.push(`diff artifact exceeds maxDiffLines ${review.maxDiffLines}`);
    }
    if (!exists(path.join(repoRoot, review.reportPath))) failures.push(`missing report ${review.reportPath}`);
    if (review.selectedPaths.length > review.maxFiles) failures.push(`selected paths exceed maxFiles ${review.maxFiles}`);

    const allowedWrites = new Set([
      "docs/ai/ACEF_PR_REVIEW.json",
      review.reviewProfile.path,
      review.diffArtifact.path,
      review.reportPath,
    ]);
    const status = gitStatusPorcelain(repoRoot);
    if (status === null) failures.push("unable to inspect git status");
    else {
      const authored = status.map((line) => line.slice(3).replace(/^"|"$/g, "")).filter((filePath) => !allowedWrites.has(filePath));
      if (authored.length) failures.push(`reviewer-authored patch or scope escape: ${authored.slice(0, 8).join(", ")}`);
    }
    return failures.length
      ? result("pr-review", false, failures.join("; "))
      : result("pr-review", true, `${review.reviewId} is bounded to ${review.selectedPaths.length} changed file(s); reviewer is report-only`);
  } catch (error) {
    return result("pr-review", false, error.message);
  }
}

function checkLightweightLifecycle(repoRoot) {
  const statePath = path.join(repoRoot, "docs", "ai", "ACEF_LIGHTWEIGHT_RUN.json");
  if (!exists(statePath)) return result("lightweight-lifecycle", false, "Missing docs/ai/ACEF_LIGHTWEIGHT_RUN.json");
  try {
    const run = parseLightweightRun(statePath);
    const missing = [];
    for (const step of run.steps) {
      for (const evidencePath of step.evidencePaths) {
        if (!exists(path.join(repoRoot, evidencePath))) missing.push(`${step.name}: ${evidencePath}`);
      }
    }
    if (run.status === "complete") {
      const lightweightStateRisk = stateChangingRisk(repoRoot, {
        activeStory: run.scope || run.runId,
        laneRationale: run.summary || run.reason || "",
        riskTriggers: run.riskTriggers || run.surfaces || [],
      }, null);
      const lightweightSurfaceTexts = [];
      if (!Array.isArray(run.surfaces) || !run.surfaces.length) {
        missing.push("surface declaration");
      }
      for (const surface of missingInferredSurfaces(repoRoot, run.surfaces || [])) {
        missing.push(`surface inferred from changed paths but not declared: ${surface}`);
      }
      const surfaceEvidence = Array.isArray(run.surfaceEvidence) ? run.surfaceEvidence : [];
      for (const surface of run.surfaces || []) {
        const match = surfaceEvidence.find((entry) => entry.surface === surface);
        if (!match) {
          missing.push(`surface evidence for ${surface}`);
          continue;
        }
        const evidencePath = path.join(repoRoot, match.evidencePath);
        if (!exists(evidencePath)) {
          missing.push(`${surface}: ${match.evidencePath}`);
        } else {
          const artifactSha256 = sha256File(evidencePath);
          const artifactText = read(evidencePath);
          lightweightSurfaceTexts.push(artifactText);
          if (!artifactHasRunnerHeader(artifactText, match.command, match.exitCode)) {
            missing.push(`runner command/exit header for ${surface}`);
          }
          if (match.runnerProof?.schema !== "acef-lightweight-surface-proof-v1"
            || match.runnerProof?.runner !== "acef-lightweight-surface-evidence"
            || match.runnerProof?.sha256 !== lightweightSurfaceProof(match, artifactSha256)) {
            missing.push(`runner proof for ${surface}`);
          }
        }
        if (!match.command || !String(match.command).trim()) {
          missing.push(`surface evidence command for ${surface}`);
        }
        if (match.exitCode !== 0) {
          missing.push(`successful surface evidence for ${surface}`);
        }
      }
      if (lightweightStateRisk && !lightweightSurfaceTexts.some(durablePersistenceEvidenceText)) {
        missing.push(stateChangingEvidenceFailure("state-changing lightweight closeout", lightweightSurfaceTexts.join("\n")));
      }
      if (run.lane === "quick-fix") {
        if (!run.quickFix) {
          missing.push("quick-fix evidence");
        } else {
          for (const field of ["reproEvidencePath", "beforePatchEvidencePath", "afterPatchEvidencePath"]) {
            const evidencePath = run.quickFix[field];
            if (!exists(path.join(repoRoot, evidencePath))) missing.push(`quick-fix ${field}: ${evidencePath}`);
          }
          if (!run.quickFix.envelope) {
            missing.push("quick-fix envelope");
          } else {
            const envelopeTestPaths = new Set(run.quickFix.envelope.testPaths || []);
            const integrityByPath = new Map((run.quickFix.testIntegrity || []).map((entry) => [entry.testPath, entry]));
            for (const testPath of changedTestPaths(repoRoot)) {
              if (!envelopeTestPaths.has(testPath)) {
                missing.push(`quick-fix test outside envelope: ${testPath}`);
                continue;
              }
              const integrity = integrityByPath.get(testPath);
              if (!integrity) {
                missing.push(`quick-fix test integrity evidence for ${testPath}`);
                continue;
              }
              if (!exists(path.join(repoRoot, integrity.evidencePath))) {
                missing.push(`quick-fix test integrity evidence path: ${integrity.evidencePath}`);
              }
              if (integrity.afterAssertionCount < integrity.beforeAssertionCount) {
                missing.push(`quick-fix test assertions decreased for ${testPath}`);
              }
              if (integrity.forbiddenPatternsAdded) {
                missing.push(`quick-fix test forbidden pattern flag for ${testPath}`);
              }
              if (integrity.matcherLoosening) {
                missing.push(`quick-fix test matcher loosening flag for ${testPath}`);
              }
              missing.push(...testEditIntegrityFailures(repoRoot, testPath));
            }
          }
        }
      }
    }
    if (missing.length) return result("lightweight-lifecycle", false, `missing lifecycle evidence: ${missing.join(", ")}`);
    return result("lightweight-lifecycle", true, `${run.runId} follows the compact lifecycle with independent review and ${run.promotion.decision}`);
  } catch (error) {
    return result("lightweight-lifecycle", false, error.message);
  }
}

function checkLaneSelection(repoRoot) {
  const activeRun = typedActiveRun(repoRoot);
  if (!activeRun) return result("lane-selection", true, "No typed active run; legacy lane selection checks remain active");
  const failures = [];
  if (isDispatchPhase(activeRun)) {
    const decision = activeRun.intakeDecision || null;
    if (!decision) {
      failures.push("planning/execution requires recorded intakeDecision before dispatch");
    } else {
      const clarifyingQuestions = decision.clarifyingQuestions || [];
      const inferredAnswers = decision.inferredAnswers || [];
      const unresolvedQuestions = decision.unresolvedQuestions || [];
      if (!clarifyingQuestions.length && !inferredAnswers.length) {
        failures.push("intakeDecision must record clarifying questions asked or facts inferred without asking");
      }
      if (decision.confidence !== "high" && !clarifyingQuestions.length) {
        failures.push("low/medium-confidence intakeDecision requires clarifying questions before planning/execution");
      }
      if (decision.confidence === "low" && !unresolvedQuestions.length) {
        failures.push("low-confidence intakeDecision must record unresolvedQuestions");
      }
      if (unresolvedQuestions.length && decision.executionApproved === true) {
        failures.push("execution cannot be approved while intakeDecision has unresolvedQuestions");
      }
      if (decision.executionApproved !== true) {
        failures.push("planning/execution requires explicit execution approval in intakeDecision");
      }
      if (["full-bmad", "guarded"].includes(activeRun.lane) && decision.briefApproved !== true) {
        failures.push(`${activeRun.lane} planning/execution requires approved interview brief before spec or plan`);
      }
    }
  }
  const triggers = (activeRun.riskTriggers || []).map((item) => String(item).toLowerCase());
  let activeScope = null;
  if (activeRun.workerScopePath) {
    try {
      activeScope = parseWorkerScope(resolvePath(activeRun.workerScopePath, repoRoot));
    } catch {
      activeScope = null;
    }
  }
  const inferredTriggers = inferredRiskTriggers(pathHints(repoRoot, activeScope));
  for (const trigger of inferredTriggers) {
    if (!triggers.includes(trigger)) failures.push(`risk trigger inferred from changed paths but not declared: ${trigger}`);
  }
  const allTriggers = [...new Set([...triggers, ...inferredTriggers])];
  failures.push(...validateSpecReadinessForDispatch(repoRoot, activeRun, allTriggers));
  if (!activeRun.laneRationale || !String(activeRun.laneRationale).trim()) {
    failures.push("active run requires laneRationale");
  }
  const guardedTerms = /(auth|authorization|permission|role|payment|billing|invoice|accounting|finance|financial|revenue|expense|tax|ledger|muhasebe|migration|delete|destructive|security|token|session|webhook|irreversible|tenant|privacy|pii)/i;
  const fullTerms = /(new-pattern|new abstraction|shared abstraction|multi-surface|unclear repro|scope expansion|broad refactor|feature|crm|notes?|workflow|reporting|dashboard|tracking)/i;
  const guardedTrigger = allTriggers.find((item) => guardedTerms.test(item));
  const fullTrigger = allTriggers.find((item) => fullTerms.test(item));
  if (guardedTrigger && activeRun.lane !== "guarded") {
    failures.push(`risk trigger requires guarded lane: ${guardedTrigger}`);
  }
  if (fullTrigger && ["quick-fix", "lightweight"].includes(activeRun.lane)) {
    failures.push(`risk trigger requires full-bmad or guarded lane: ${fullTrigger}`);
  }
  if (activeRun.lane === "quick-fix" && !triggers.includes("bugfix") && !triggers.includes("bug-fix") && !triggers.includes("defect")) {
    failures.push("quick-fix lane requires bugfix/defect risk trigger");
  }
  return failures.length
    ? result("lane-selection", false, failures.join("; "))
    : result("lane-selection", true, `${activeRun.lane} lane selection is justified`);
}

function checkSpecReadiness(repoRoot) {
  const activeRun = typedActiveRun(repoRoot);
  if (!activeRun) return result("spec-readiness", true, "No typed active run; spec readiness is checked at lane selection when a typed run exists");
  const triggers = (activeRun.riskTriggers || []).map((item) => String(item).toLowerCase());
  let activeScope = null;
  if (activeRun.workerScopePath) {
    try {
      activeScope = parseWorkerScope(resolvePath(activeRun.workerScopePath, repoRoot));
    } catch {
      activeScope = null;
    }
  }
  const allTriggers = [...new Set([...triggers, ...inferredRiskTriggers(pathHints(repoRoot, activeScope))])];
  const failures = validateSpecReadinessForDispatch(repoRoot, activeRun, allTriggers);
  if (!failures.length) {
    if (!specReadinessRequired(activeRun, allTriggers)) return result("spec-readiness", true, "Spec readiness not required for this phase/lane/risk profile");
    const verdict = parseSpecReadiness(specReadinessPath(repoRoot, activeRun));
    return result("spec-readiness", true, `Spec readiness ${verdict.status} for ${activeRun.activeStory}`);
  }
  return result("spec-readiness", false, failures.join("; "));
}

const USER_VISIBLE_SURFACES = new Set(["ui", "admin", "mobile", "http"]);

function goalLooksUserFacing(activeRun) {
  const goal = activeRun?.activeGoal || {};
  if (goal.userFacing === true || goal.completionMode === "product-workspace") return true;
  if (goal.completionMode === "backend-capability" || goal.userFacing === false) return false;
  const text = [
    activeRun?.activeStory,
    activeRun?.laneRationale,
    ...(activeRun?.riskTriggers || []),
    goal.description,
  ].filter(Boolean).join(" ");
  return /\b(workspace|screen|page|panel|console|dashboard|staff|user|capture|manage|track|notes?|crm|finance|accounting|muhasebe|lead|student|teacher|customer|client)\b/i.test(text);
}

function evidenceRefExists(repoRoot, ref) {
  const value = String(ref || "").trim();
  if (!value) return false;
  const filePart = value.split("#")[0].replace(/^`|`$/g, "").trim();
  if (!filePart) return false;
  return exists(resolvePath(filePart, repoRoot));
}

function checkGoalCoverage(repoRoot) {
  const activeRun = typedActiveRun(repoRoot);
  if (!activeRun) return result("goal-coverage", true, "No typed active run; legacy goal coverage checks remain active");
  if (activeRun.status !== "complete") return result("goal-coverage", true, "Active run is not complete");
  if (!goalLooksUserFacing(activeRun)) return result("goal-coverage", true, "Goal is not classified as user-facing");

  const failures = [];
  const coverage = activeRun.goalCoverage || null;
  if (!coverage) {
    return result("goal-coverage", false, "user-facing complete run requires goalCoverage with visible product surface evidence");
  }
  if (coverage.status !== "PASS") failures.push("goalCoverage.status must be PASS before user-facing goal completion");
  if (["foundation", "backend-capability"].includes(coverage.storyType)) {
    failures.push(`storyType ${coverage.storyType} cannot complete a user-facing product goal`);
  }
  const required = coverage.requiredSurfaces || [];
  const covered = coverage.coveredSurfaces || [];
  if (!required.length) failures.push("goalCoverage.requiredSurfaces must name the user-visible surface(s)");
  const missingSurfaces = required.filter((surface) => !covered.includes(surface));
  if (missingSurfaces.length) failures.push(`goalCoverage missing covered surface(s): ${missingSurfaces.join(", ")}`);
  if (!covered.some((surface) => USER_VISIBLE_SURFACES.has(surface))) {
    failures.push("goalCoverage must include a user-visible surface: ui, admin, mobile, or http");
  }
  const evidenceRefs = coverage.evidenceRefs || [];
  if (!evidenceRefs.length) failures.push("goalCoverage.evidenceRefs must cite real route/component/action/runtime evidence");
  for (const ref of evidenceRefs) {
    if (!evidenceRefExists(repoRoot, ref)) failures.push(`goalCoverage evidence ref missing: ${ref}`);
  }
  if (Array.isArray(coverage.missing) && coverage.missing.length) {
    failures.push(`goalCoverage still has missing goal item(s): ${coverage.missing.join(", ")}`);
  }
  return failures.length
    ? result("goal-coverage", false, failures.join("; "))
    : result("goal-coverage", true, `User-facing goal covered by ${covered.join(", ")} surface evidence`);
}

function closeoutResultFailure(item) {
  return item.ok ? "" : `${item.name}: ${item.message}`;
}

function checkLaneCloseout(repoRoot, ledgerPath, adapterPath, registryPath) {
  const activeRun = typedActiveRun(repoRoot);
  let lane = activeRun?.lane || "";
  if (!lane) {
    const lightweightPath = path.join(repoRoot, "docs", "ai", "ACEF_LIGHTWEIGHT_RUN.json");
    if (exists(lightweightPath)) lane = parseLightweightRun(lightweightPath).lane;
  }
  if (!lane) return result("lane-closeout", false, "Missing typed active run or lightweight run lane");

  const checks = [];
  checks.push(checkControlDosing(repoRoot));
  if (lane === "quick-fix") {
    checks.push(checkLaneSelection(repoRoot));
    checks.push(checkLightweightLifecycle(repoRoot));
    checks.push(checkLeanEvidence(repoRoot, ledgerPath));
    checks.push(checkSessionHandoff(repoRoot, ledgerPath, adapterPath, registryPath));
  } else if (lane === "lightweight") {
    checks.push(checkLaneSelection(repoRoot));
    checks.push(checkLightweightLifecycle(repoRoot));
    checks.push(checkLeanEvidence(repoRoot, ledgerPath));
    checks.push(checkSessionHandoff(repoRoot, ledgerPath, adapterPath, registryPath));
  } else if (lane === "full-bmad") {
    checks.push(checkLaneSelection(repoRoot));
    checks.push(checkGoalCoverage(repoRoot));
    checks.push(checkCurrentContext(repoRoot, ledgerPath));
    checks.push(checkActorSeparation(repoRoot, ledgerPath));
    checks.push(checkWorkerScope(repoRoot));
    checks.push(checkEvidenceManifests(repoRoot));
    checks.push(checkGateVerdict(repoRoot));
    checks.push(checkSourceReconciliation(repoRoot, ledgerPath));
    checks.push(checkLeanEvidence(repoRoot, ledgerPath));
    checks.push(checkSessionHandoff(repoRoot, ledgerPath, adapterPath, registryPath));
  } else if (lane === "guarded") {
    checks.push(checkLaneSelection(repoRoot));
    checks.push(checkGoalCoverage(repoRoot));
    checks.push(checkCurrentContext(repoRoot, ledgerPath));
    checks.push(checkActorSeparation(repoRoot, ledgerPath));
    checks.push(checkWorkerScope(repoRoot));
    checks.push(checkEvidenceManifests(repoRoot));
    checks.push(checkGateVerdict(repoRoot));
    checks.push(checkSourceReconciliation(repoRoot, ledgerPath));
    checks.push(checkGuardedTestFloor(repoRoot, ledgerPath));
    checks.push(checkLeanEvidence(repoRoot, ledgerPath));
    checks.push(checkSessionHandoff(repoRoot, ledgerPath, adapterPath, registryPath));
  } else {
    return result("lane-closeout", false, `Unsupported closeout lane: ${lane}`);
  }
  const failures = checks.map(closeoutResultFailure).filter(Boolean);
  return failures.length
    ? result("lane-closeout", false, failures.join("; "))
    : result("lane-closeout", true, `${lane} closeout bundle passed`);
}

function controlDosingManifestPath(repoRoot) {
  const candidates = [
    path.join(repoRoot, "docs", "ai", "ACEF_CONTROL_DOSING.json"),
    path.join(repoRoot, ".acef", "control-dosing.json"),
    path.join(__dirname, "..", "control-dosing.json"),
    path.join(repoRoot, "method", "control-dosing.json"),
  ];
  return candidates.find((candidate) => exists(candidate)) || "";
}

function displayPath(repoRoot, filePath) {
  try {
    return safeRelative(filePath, repoRoot);
  } catch {
    return filePath;
  }
}

function checkControlDosing(repoRoot) {
  const manifestPath = controlDosingManifestPath(repoRoot);
  if (!manifestPath) {
    return result("control-dosing", false, "Missing control dosing manifest: docs/ai/ACEF_CONTROL_DOSING.json or .acef/control-dosing.json");
  }
  try {
    const record = parseControlDosing(manifestPath);
    return result("control-dosing", true, `${displayPath(repoRoot, manifestPath)} defines ${record.controls.length} control dose(s)`);
  } catch (error) {
    return result("control-dosing", false, `${displayPath(repoRoot, manifestPath)}: ${error.message}`);
  }
}

function capabilityChangePaths(repoRoot) {
  const paths = [];
  const single = path.join(repoRoot, "docs", "ai", "ACEF_CAPABILITY_CHANGE.json");
  if (exists(single)) paths.push(single);
  const dir = path.join(repoRoot, "docs", "ai", "capabilities");
  if (exists(dir)) paths.push(...jsonRecords(dir));
  return paths.sort();
}

function isCapabilityRelevantPath(filePath) {
  const normalized = String(filePath || "").replaceAll(path.sep, "/");
  return normalized === "README.md"
    || normalized === "AGENTS.md"
    || normalized.startsWith("method/")
    || normalized.startsWith("skills/")
    || normalized.startsWith("schemas/")
    || normalized.startsWith("scripts/")
    || normalized.startsWith("workflows/")
    || normalized.startsWith("claude-plugins/")
    || /^docs\/(?:overview|print|sdlc|roles|index)\.html$/.test(normalized);
}

function changedCapabilityFiles(repoRoot) {
  const status = gitStatusPorcelain(repoRoot);
  if (status === null) return [];
  return status
    .map((line) => line.slice(3).replace(/^"|"$/g, ""))
    .filter(Boolean)
    .filter(isCapabilityRelevantPath)
    .filter((filePath) => filePath !== "docs/ai/ACEF_CAPABILITY_CHANGE.json")
    .filter((filePath) => !filePath.startsWith("docs/ai/capabilities/"));
}

function capabilityRefExists(repoRoot, ref) {
  const value = String(ref || "").trim();
  if (!value || /^(cmd|commit|external|note):/i.test(value)) return true;
  if (/^(https?:)?\/\//i.test(value)) return true;
  const candidate = value.split("#")[0].replace(/:\d+(?::\d+)?$/, "");
  if (!candidate) return true;
  const resolved = resolvePath(candidate, repoRoot);
  return resolved.startsWith(`${repoRoot}${path.sep}`) && exists(resolved);
}

function checkCapabilityChange(repoRoot) {
  const relevantChanges = changedCapabilityFiles(repoRoot);
  const capabilityFiles = capabilityChangePaths(repoRoot);
  if (!relevantChanges.length && !capabilityFiles.length) {
    return result("capability-change", true, "No active ACEF capability change");
  }
  const failures = [];
  if (relevantChanges.length && !capabilityFiles.length) {
    failures.push(`ACEF capability-relevant files changed without docs/ai/ACEF_CAPABILITY_CHANGE.json or docs/ai/capabilities/*.json: ${relevantChanges.slice(0, 12).join(", ")}`);
  }
  for (const filePath of capabilityFiles) {
    try {
      const record = parseCapabilityChange(filePath);
      if (record.status === "documented-only") {
        const nonDocLayers = Object.entries(record.implementedLayers || {})
          .filter(([layer, refs]) => layer !== "docs" && Array.isArray(refs) && refs.length)
          .map(([layer]) => layer);
        if (nonDocLayers.length) {
          failures.push(`${path.relative(repoRoot, filePath)} status documented-only cannot list non-doc implemented layers: ${nonDocLayers.join(", ")}`);
        }
      }
      for (const [layer, refs] of Object.entries(record.implementedLayers || {})) {
        for (const ref of refs) {
          if (!capabilityRefExists(repoRoot, ref)) {
            failures.push(`${path.relative(repoRoot, filePath)} ${layer} evidence missing: ${ref}`);
          }
        }
      }
    } catch (error) {
      failures.push(`${path.relative(repoRoot, filePath)}: ${error.message}`);
    }
  }
  return failures.length
    ? result("capability-change", false, failures.join("; "))
    : result("capability-change", true, `${capabilityFiles.length} capability change record(s) classify implemented layers`);
}

function main() {
  const args = parseArgs(process.argv);
  if (args.help) {
    usage();
    return;
  }

  const ledger = args.ledger || findLedger(args.repo);
  const adapter = args.adapter || findAdapter(args.repo);
  const registry = findPatternRegistry(args.repo, adapter);
  const checks = args.check === "all"
    ? ["clean-tree", "preflight", "claims", "adapter-freshness", "pattern-registry", "reuse-before-create", "do-not-copy", "partial-workshape", "finding-promotion", "graduation-reconciliation", "vertical-slice", "test-authenticity", "guarded-test-floor", "actor-separation", "worker-scope", "evidence-manifest", "gate-verdict", "source-reconciliation", "epic-context-pack", "current-context", "pr-review", "spec-readiness", "goal-coverage", "lane-selection", "lane-closeout", "lightweight-lifecycle", "lean-evidence", "control-dosing", "capability-change", "session-handoff", "seeded-epic-gates", "epic-boundary", "epic-transition-approval", "replan-counter"]
    : [args.check];

  const results = checks.map((check) => {
    if (check === "clean-tree") return checkCleanTree(args.repo);
    if (check === "preflight") return checkPreflight(args.repo);
    if (check === "claims") return checkClaims(args.repo, ledger);
    if (check === "adapter-freshness") return checkAdapterFreshness(args.repo, adapter);
    if (check === "pattern-registry") return checkPatternRegistry(registry);
    if (check === "reuse-before-create") return checkReuseBeforeCreate(ledger, registry);
    if (check === "do-not-copy") return checkDoNotCopy(ledger, registry);
    if (check === "partial-workshape") return checkPartialWorkshape(ledger, registry);
    if (check === "finding-promotion") return checkFindingPromotion(ledger);
    if (check === "graduation-reconciliation") return checkGraduationReconciliation(args.repo, ledger);
    if (check === "vertical-slice") return checkVerticalSlice(args.repo, ledger);
    if (check === "test-authenticity") return checkTestAuthenticity(args.repo);
    if (check === "guarded-test-floor") return checkGuardedTestFloor(args.repo, ledger);
    if (check === "actor-separation") return checkActorSeparation(args.repo, ledger);
    if (check === "worker-scope") return checkWorkerScope(args.repo);
    if (check === "evidence-manifest") return checkEvidenceManifests(args.repo);
    if (check === "gate-verdict") return checkGateVerdict(args.repo);
    if (check === "source-reconciliation") return checkSourceReconciliation(args.repo, ledger);
    if (check === "epic-context-pack") return checkEpicContextPack(args.repo, ledger);
    if (check === "current-context") return checkCurrentContext(args.repo, ledger);
    if (check === "pr-review") return checkPrReview(args.repo);
    if (check === "spec-readiness") return checkSpecReadiness(args.repo);
    if (check === "goal-coverage") return checkGoalCoverage(args.repo);
    if (check === "lane-selection") return checkLaneSelection(args.repo);
    if (check === "lane-closeout") return checkLaneCloseout(args.repo, ledger, adapter, registry);
    if (check === "lightweight-lifecycle") return checkLightweightLifecycle(args.repo);
    if (check === "lean-evidence") return checkLeanEvidence(args.repo, ledger);
    if (check === "control-dosing") return checkControlDosing(args.repo);
    if (check === "capability-change") return checkCapabilityChange(args.repo);
    if (check === "session-handoff") return checkSessionHandoff(args.repo, ledger, adapter, registry);
    if (check === "seeded-epic-gates") return checkSeededEpicGates(args.repo, ledger);
    if (check === "epic-boundary") return checkEpicBoundary(args.repo, ledger, args.targetEpic);
    if (check === "epic-transition-approval") return checkEpicTransitionApproval(args.repo, ledger, args.targetEpic);
    if (check === "replan-counter") return checkReplanCounter(ledger);
    return result(check, false, `Unknown check: ${check}`);
  });

  for (const item of results) {
    console.log(`${item.ok ? "PASS" : "FAIL"} ${item.name}: ${item.message}`);
  }

  if (results.some((item) => !item.ok)) process.exitCode = 1;
}

try {
  main();
} catch (error) {
  console.error(`FAIL validator: ${error.message}`);
  process.exitCode = 1;
}
