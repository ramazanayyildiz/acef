    workerId: "ACEF_BMAD_WORKER",
    allowedPaths: ["src/**", "tests/**"],
    baseRef: "HEAD",
    maxCommits: 1,
    canEditLedger: false,
    canSpawnAgents: false,
  }, null, 2));
  expectHookDecision("worker outside active story scope denied", {
    tool_name: "Write",
    cwd: tmp,
    tool_input: {
      file_path: path.join(tmp, "app", "Models", "OutOfScope.php"),
      content: "<?php\n",
    },
  }, "deny", workerEnv, [
    "outside allowedPaths for Story 1.1",
    "Requested implementation path(s): app/Models/OutOfScope.php.",
    "If this is not an active ACEF run, close the stale lane marker",
  ]);
  expectHookDecision("worker apply_patch outside active story scope denied", {
    tool_name: "apply_patch",
    cwd: tmp,
    tool_input: {
      patch: [
        "*** Begin Patch",
        "*** Add File: app/Models/OutOfScope.php",
        "+<?php",
        "*** End Patch",
      ].join("\n"),
    },
  }, "deny", workerEnv);
  expectHookDecision("worker commit must cite active story", {
    tool_name: "Bash",
    cwd: tmp,
    tool_input: {
      command: "git commit -m 'feat: Story 1.2 wrong story'",
      cwd: tmp,
    },
  }, "deny", workerEnv);
  expectHookDecision("P1 conformance allows source write", {
    tool_name: "Write",
    cwd: tmp,
    tool_input: {
      file_path: path.join(tmp, "src", "new-service.ts"),
      content: "export const ok = true;\n",
    },
  }, "allow", workerEnv);

  // --- Identity-absent graceful degradation -------------------------------------------
  // The harness (e.g. Claude Code subagents) does not propagate worker identity into hook
  // env. With no identity, the hard wall must degrade from per-actor to scope-level gating
  // rather than fail-closed on every guarded write. The P1-conformance fixtures established
  // above remain in place, so these cases exercise only the identity/scope decision.
  const noIdentityEnv = {
    ACEF_BMAD_WORKER: "",
    ACEF_ROLE: "",
    ACEF_WORKER_ID: "",
    CLAUDE_AGENT_NAME: "",
    CLAUDE_SUBAGENT_NAME: "",
    OPENCODE_AGENT_NAME: "",
    AGENT_NAME: "",
  };
  function writeWorkerScope(overrides) {
    fs.writeFileSync(path.join(tmp, "docs", "ai", "ACEF_ACTIVE_WORKER_SCOPE.json"), JSON.stringify({
      activeStory: "1.1",
      phase: "development",
      workerId: "ACEF_BMAD_WORKER",
      allowedPaths: ["src/**", "tests/**"],
      baseRef: "HEAD",
      maxCommits: 1,
      canEditLedger: false,
      canSpawnAgents: false,
      ...overrides,
    }, null, 2));
  }

  // (a) no identity + dev-phase scope + path in allowedPaths -> ALLOW
  writeWorkerScope({ phase: "development", allowedPaths: ["src/**", "tests/**"] });
  expectHookDecision("identity fallback allows dev-phase write inside allowedPaths", {
    tool_name: "Write",
    cwd: tmp,
    tool_input: {
      file_path: path.join(tmp, "src", "fallback-ok.ts"),
      content: "export const ok = true;\n",
    },
  }, "allow", noIdentityEnv, ["worker identity not propagated by harness"]);

  // (b) no identity + non-implementation phase (process-judge) -> DENY
  writeWorkerScope({ phase: "process-judge" });
  expectHookDecision("identity fallback denies non-dev phase write", {
    tool_name: "Write",
    cwd: tmp,
    tool_input: {
      file_path: path.join(tmp, "src", "fallback-phase.ts"),
      content: "export const blocked = true;\n",
    },
  }, "deny", noIdentityEnv, [
    "does not permit implementation writes",
    "set a developer scope via 'acef-state worker-scope'",
  ]);

  // (c) no identity + dev phase but path outside allowedPaths -> DENY
  writeWorkerScope({ phase: "development", allowedPaths: ["lib/**"] });
  expectHookDecision("identity fallback denies write outside allowedPaths", {
    tool_name: "Write",
    cwd: tmp,
    tool_input: {
      file_path: path.join(tmp, "src", "fallback-outside.ts"),
      content: "export const blocked = true;\n",
    },
  }, "deny", noIdentityEnv, ["outside allowedPaths for Story 1.1"]);

  // (d) identity present (ACEF_WORKER_ID) matching scope.workerId -> ALLOW
  writeWorkerScope({ phase: "development", workerId: "dev-worker-7", allowedPaths: ["src/**"] });
  expectHookDecision("identity present matching scope allows write", {
    tool_name: "Write",
    cwd: tmp,
    tool_input: {
      file_path: path.join(tmp, "src", "matched.ts"),
      content: "export const ok = true;\n",
    },
  }, "allow", { ...noIdentityEnv, ACEF_WORKER_ID: "dev-worker-7" });

  // (e) identity present but mismatched scope.workerId -> DENY
  writeWorkerScope({ phase: "development", workerId: "dev-worker-7", allowedPaths: ["src/**"] });
  expectHookDecision("identity present mismatched scope denies write", {
    tool_name: "Write",
    cwd: tmp,
    tool_input: {
      file_path: path.join(tmp, "src", "mismatch.ts"),
      content: "export const blocked = true;\n",
    },
  }, "deny", { ...noIdentityEnv, ACEF_WORKER_ID: "intruder-9" }, [
    "active worker scope is assigned to a different worker identity",
  ]);

  // Restore the worker scope expected by the review-patch tests that follow.
  writeWorkerScope({ phase: "dev", workerId: "ACEF_BMAD_WORKER", allowedPaths: ["src/**", "tests/**"] });
  fs.writeFileSync(path.join(tmp, "docs", "ai", "ACEF_REVIEW_PATCH_REQUIRED.json"), JSON.stringify({
    activeStory: "1.1",
    reviewVerdict: "MERGE WITH REQUIRED PATCH",
    status: "REQUIRED",
  }, null, 2));
  expectHookDecision("review patch gate blocks conductor implementation patch", {
    tool_name: "Write",
    cwd: tmp,
    tool_input: {
      file_path: path.join(tmp, "src", "review-fix.ts"),
      content: "export const conductorPatch = true;\n",
    },
  }, "deny");
  expectHookDecision("review patch gate blocks non-verify worker phase", {
    tool_name: "Write",
    cwd: tmp,
    tool_input: {
      file_path: path.join(tmp, "src", "review-fix.ts"),
      content: "export const devPatch = true;\n",
    },
  }, "deny", workerEnv);
  fs.writeFileSync(path.join(tmp, "docs", "ai", "ACEF_ACTIVE_WORKER_SCOPE.json"), JSON.stringify({
    activeStory: "1.1",
    phase: "verify-patch",
    workerId: "ACEF_BMAD_WORKER",
    allowedPaths: ["src/**", "tests/**"],
    baseRef: "HEAD",
    maxCommits: 1,
    canEditLedger: false,
    canSpawnAgents: false,
  }, null, 2));
  expectHookDecision("review patch gate allows scoped verify-patch worker", {
    tool_name: "Write",
    cwd: tmp,
    tool_input: {
      file_path: path.join(tmp, "src", "review-fix.ts"),
      content: "export const verifyPatch = true;\n",
    },
  }, "allow", workerEnv);
  fs.rmSync(path.join(tmp, "docs", "ai", "ACEF_REVIEW_PATCH_REQUIRED.json"));

  const fakeHome = fs.mkdtempSync(path.join(os.tmpdir(), "acef-home-"));
  const nonAcefRepo = path.join(fakeHome, "work", "browser-rts");
  fs.mkdirSync(path.join(fakeHome, ".bmad"), { recursive: true });
  fs.mkdirSync(nonAcefRepo, { recursive: true });
  expectHookDecision("home-level bmad marker does not activate unrelated repo", {
    tool_name: "Bash",
    cwd: nonAcefRepo,
    tool_input: {
      command: "npm install fast-check",
      cwd: nonAcefRepo,
    },
  }, "allow", { HOME: fakeHome });

  const lightweight = fs.mkdtempSync(path.join(os.tmpdir(), "acef-lightweight-"));
  fs.mkdirSync(path.join(lightweight, "docs", "ai"), { recursive: true });
  fs.writeFileSync(path.join(lightweight, ".acef-lightweight-lane"), "active\n");
  fs.writeFileSync(path.join(lightweight, "docs", "ai", "pattern-registry.json"), fs.readFileSync(path.join(tmp, "docs", "ai", "pattern-registry.json"), "utf8"));
  expectHookDecision("lightweight lane missing P1 conformance", {
    tool_name: "Write",
    cwd: lightweight,
    tool_input: {
      file_path: path.join(lightweight, "src", "light.ts"),
      content: "export const light = true;\n",
    },
  }, "deny", workerEnv);
  fs.rmSync(lightweight, { recursive: true, force: true });

  expectPass("preflight", ["--repo", tmp, "--check", "preflight"]);
  expectPass("adapter-freshness", ["--repo", tmp, "--check", "adapter-freshness", "--adapter", "docs/codebase-map.md"]);
  expectPass("pattern-registry", ["--repo", tmp, "--check", "pattern-registry"]);
  const registryPath = path.join(tmp, "docs", "ai", "pattern-registry.json");
  const validRegistry = JSON.parse(fs.readFileSync(registryPath, "utf8"));
  const missingCompletionEvidence = JSON.parse(JSON.stringify(validRegistry));
  delete missingCompletionEvidence.patterns[0].completionEvidence;
  fs.writeFileSync(registryPath, JSON.stringify(missingCompletionEvidence));
  expectFail("pattern-registry", ["--repo", tmp, "--check", "pattern-registry"]);
  const emptyCompletionEvidence = JSON.parse(JSON.stringify(validRegistry));
  emptyCompletionEvidence.patterns[0].completionEvidence = {};
  fs.writeFileSync(registryPath, JSON.stringify(emptyCompletionEvidence));
  expectFail("pattern-registry", ["--repo", tmp, "--check", "pattern-registry"]);
  const staleSchemaRegistry = JSON.parse(JSON.stringify(validRegistry));
  staleSchemaRegistry.schemaVersion = 1;
  fs.writeFileSync(registryPath, JSON.stringify(staleSchemaRegistry));
  expectFail("pattern-registry", ["--repo", tmp, "--check", "pattern-registry"]);
  fs.writeFileSync(registryPath, JSON.stringify(validRegistry));
  expectPass("reuse-before-create", ["--repo", tmp, "--check", "reuse-before-create", "--ledger", "docs/ai/ACEF_demo_DELIVERY_AUDIT.md"]);
