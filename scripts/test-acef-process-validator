#!/usr/bin/env node
const fs = require("node:fs");
const os = require("node:os");
const path = require("node:path");
const cp = require("node:child_process");
const crypto = require("node:crypto");

const repoRoot = path.resolve(__dirname, "..");
const validator = path.join(repoRoot, "scripts", "acef-process-validator");
const codexGuard = path.join(repoRoot, "scripts", "acef-codex-guard");
const bmadHook = path.join(repoRoot, "claude-plugins", "acef-bmad-guard", "hooks", "acef-bmad-hard-wall.mjs");
const bmadDispatcher = path.join(repoRoot, "claude-plugins", "acef-bmad-guard", "hooks", "acef-bmad-dispatcher.mjs");

function run(command, args, options = {}) {
  return cp.execFileSync(command, args, {
    encoding: "utf8",
    stdio: ["ignore", "pipe", "pipe"],
    ...options,
  }).trim();
}

function runValidator(args, options = {}) {
  return run("node", [validator, ...args], options);
}

function sha256File(filePath) {
  return crypto.createHash("sha256").update(fs.readFileSync(filePath)).digest("hex");
}

function sha256(value) {
  return crypto.createHash("sha256").update(value).digest("hex");
}

function runnerArtifact(command, exitCode, body) {
  return [
    `command: ${command}`,
    "started_at: 2026-06-25T00:00:00.000Z",
    "finished_at: 2026-06-25T00:00:01.000Z",
    `exit_code: ${exitCode}`,
    "",
    "--- stdout ---",
    body,
    "--- stderr ---",
    "",
  ].join("\n");
}

function evidenceRunnerProof(record) {
  return {
    schema: "acef-evidence-runner-proof-v1",
    runner: "acef-state evidence-run",
    sha256: sha256(JSON.stringify({
      schema: "acef-evidence-runner-proof-v1",
      runner: "acef-state evidence-run",
      evidenceId: record.evidenceId,
      kind: record.kind,
      command: record.command,
      exitCode: record.exitCode,
      startedAt: record.startedAt || null,
      finishedAt: record.finishedAt || null,
      repositoryCommit: record.repositoryCommit,
      repositoryTree: record.repositoryTree || null,
      dirtyDigest: record.dirtyDigest,
      dirtyApplicationPathsBefore: record.dirtyApplicationPathsBefore || [],
      dirtyApplicationPathsAfter: record.dirtyApplicationPathsAfter || [],
      environmentDigest: record.environmentDigest || null,
      actorInstanceId: record.actorInstanceId,
      story: record.story,
      rawArtifact: record.rawArtifact,
      satisfies: record.satisfies,
    })),
  };
}

function expectPass(label, args) {
  const output = runValidator(args);
  if (!output.includes(`PASS ${label}:`)) {
    throw new Error(`Expected ${label} to pass, got:\n${output}`);
  }
}

function expectFail(label, args) {
  try {
    runValidator(args);
  } catch (error) {
    const output = `${error.stdout || ""}${error.stderr || ""}`;
    if (output.includes(`FAIL ${label}:`)) return;
    throw new Error(`Expected ${label} to fail, got:\n${output}`);
  }
  throw new Error(`Expected ${label} to fail, but it passed`);
}

function runCodexGuard(args, options = {}) {
  return run("node", [codexGuard, ...args], options);
}

function expectCodexGuardPass(label, args) {
  const output = runCodexGuard(args);
  if (!output.includes("PASS codex-guard:")) {
    throw new Error(`Expected codex guard ${label} to pass, got:\n${output}`);
  }
}

function expectCodexGuardFail(label, args) {
  try {
    runCodexGuard(args);
  } catch (error) {
    const output = `${error.stdout || ""}${error.stderr || ""}`;
    if (output.includes("FAIL codex-guard:")) return;
    throw new Error(`Expected codex guard ${label} to fail, got:\n${output}`);
  }
  throw new Error(`Expected codex guard ${label} to fail, but it passed`);
}

function runHook(payload, env = {}) {
  const output = cp.execFileSync("node", [bmadHook], {
    input: JSON.stringify(payload),
    encoding: "utf8",
    stdio: ["pipe", "pipe", "pipe"],
    env: { ...process.env, ...env },
  }).trim();
  return JSON.parse(output);
}

function runDispatcher(payload, env = {}) {
  const output = cp.execFileSync("node", [bmadDispatcher], {
    input: JSON.stringify(payload),
    encoding: "utf8",
    stdio: ["pipe", "pipe", "pipe"],
    env: { ...process.env, ...env },
  }).trim();
  return JSON.parse(output);
}

function expectDispatcherDecision(label, payload, decision, env = {}) {
  const output = runDispatcher(payload, env);
  const hookEventName = output?.hookSpecificOutput?.hookEventName;
  if (hookEventName !== "PreToolUse") {
    throw new Error(`Expected dispatcher ${label} to include hookEventName PreToolUse, got ${hookEventName || "none"}:\n${JSON.stringify(output, null, 2)}`);
  }
  const actual = output?.hookSpecificOutput?.permissionDecision;
  if (actual !== decision) {
    throw new Error(`Expected dispatcher ${label} to ${decision}, got ${actual || "none"}:\n${JSON.stringify(output, null, 2)}`);
  }
}

function expectHookDecision(label, payload, decision, env = {}, expectedSystemMessages = []) {
  const output = runHook(payload, env);
  const hookEventName = output?.hookSpecificOutput?.hookEventName;
  if (hookEventName !== "PreToolUse") {
    throw new Error(`Expected hook ${label} to include hookEventName PreToolUse, got ${hookEventName || "none"}:\n${JSON.stringify(output, null, 2)}`);
  }
  const actual = output?.hookSpecificOutput?.permissionDecision;
  if (actual !== decision) {
    throw new Error(`Expected hook ${label} to ${decision}, got ${actual || "none"}:\n${JSON.stringify(output, null, 2)}`);
  }
  for (const expected of expectedSystemMessages) {
    if (!String(output.systemMessage || "").includes(expected)) {
      throw new Error(`Expected hook ${label} message to include ${expected}, got:\n${JSON.stringify(output, null, 2)}`);
    }
  }
}

