#!/usr/bin/env node
const fs = require("node:fs");
const os = require("node:os");
const path = require("node:path");
const cp = require("node:child_process");

const repoRoot = path.resolve(__dirname, "..");
const validator = path.join(repoRoot, "scripts", "acef-process-validator");
const bmadHook = path.join(repoRoot, "claude-plugins", "acef-bmad-guard", "hooks", "acef-bmad-hard-wall.mjs");

function run(command, args, options = {}) {
  return cp.execFileSync(command, args, {
    encoding: "utf8",
    stdio: ["ignore", "pipe", "pipe"],
    ...options,
  }).trim();
}

function runValidator(args, options = {}) {
  return run("node", [validator, ...args], options);
}

function expectPass(label, args) {
  const output = runValidator(args);
  if (!output.includes(`PASS ${label}:`)) {
    throw new Error(`Expected ${label} to pass, got:\n${output}`);
  }
}

function expectFail(label, args) {
  try {
    runValidator(args);
  } catch (error) {
    const output = `${error.stdout || ""}${error.stderr || ""}`;
    if (output.includes(`FAIL ${label}:`)) return;
    throw new Error(`Expected ${label} to fail, got:\n${output}`);
  }
  throw new Error(`Expected ${label} to fail, but it passed`);
}

function runHook(payload, env = {}) {
  const output = cp.execFileSync("node", [bmadHook], {
    input: JSON.stringify(payload),
    encoding: "utf8",
    stdio: ["pipe", "pipe", "pipe"],
    env: { ...process.env, ...env },
  }).trim();
  return JSON.parse(output);
}

function expectHookDecision(label, payload, decision, env = {}) {
  const output = runHook(payload, env);
  const actual = output?.hookSpecificOutput?.permissionDecision;
  if (actual !== decision) {
    throw new Error(`Expected hook ${label} to ${decision}, got ${actual || "none"}:\n${JSON.stringify(output, null, 2)}`);
  }
}

const tmp = fs.mkdtempSync(path.join(os.tmpdir(), "acef-validator-"));

try {
  run("git", ["init"], { cwd: tmp });
  run("git", ["config", "user.email", "acef@example.invalid"], { cwd: tmp });
  run("git", ["config", "user.name", "ACEF Test"], { cwd: tmp });

  fs.mkdirSync(path.join(tmp, "docs", "ai"), { recursive: true });
  fs.writeFileSync(path.join(tmp, "README.md"), "# fixture\n");
  run("git", ["add", "README.md"], { cwd: tmp });
  run("git", ["commit", "-m", "init"], { cwd: tmp });
  const head = run("git", ["rev-parse", "--short", "HEAD"], { cwd: tmp });

  fs.writeFileSync(path.join(tmp, "docs", "ai", "ACEF_PREFLIGHT.md"), "Status: PASS\n");
  fs.writeFileSync(path.join(tmp, "docs", "codebase-map.md"), `# Codebase Map\n\ngenerated_at: 2026-06-21 · commit: ${head}\n`);
  fs.writeFileSync(path.join(tmp, "docs", "ai", "pattern-registry.json"), JSON.stringify({
    schemaVersion: 1,
    repo: "fixture",
    generatedAt: "2026-06-21",
    generatedFromCommit: head,
    coveredScopes: ["src"],
    status: "PARTIAL",
    patterns: [
      {
        id: "pattern.service.shared-client",
        workShape: "service",
        status: "canonical",
        maturity: "rubric-item",
        enforcedBy: null,
        summary: "Services use the shared API client.",
        evidence: "Fixture service pattern evidence.",
        sourceEvidence: [{ path: "src/services/current.ts", line: 1 }],
        goldenNeighbors: [{ path: "src/services/current.ts", why: "canonical service" }],
        reuseProbe: ["sharedApiClient", "src/services/current.ts"],
        doNotCopy: ["legacy.service.direct-fetch"],
        confidence: "single-example",
        lastVerifiedAt: "2026-06-21",
        lastVerifiedCommit: head,
        refreshTriggers: ["touched-scope-change"],
      },
    ],
    doNotCopy: [
      {
        id: "legacy.service.direct-fetch",
        reason: "Bypasses shared API client.",
        sourceEvidence: [{ path: "src/legacy/direct-fetch.ts", line: 1 }],
        lastVerifiedCommit: head,
      },
    ],
  }, null, 2));
  fs.writeFileSync(path.join(tmp, "docs", "out.md"), "generated output\n");
  fs.writeFileSync(path.join(tmp, "docs", "ai", "ACEF_demo_DELIVERY_AUDIT.md"), [
    "# ACEF Demo Delivery Audit",
    "",
    "Epic 1",
    "",
    "Outputs:",
    "- `docs/out.md`",
    "",
    "Epic 1 Process Judge",
    "",
    "Status: PASS",
    "",
  ].join("\n"));

  fs.writeFileSync(path.join(tmp, ".acef-bmad-lane"), "active\n");
  const storyCommandPayload = {
    tool_name: "Bash",
    cwd: tmp,
    tool_input: {
      command: "bmad-create-story --story E1-1",
    },
  };
  expectHookDecision("missing step ledger", storyCommandPayload, "deny");
  const workerEnv = { ACEF_BMAD_WORKER: "1" };
  expectHookDecision("missing P1 conformance", {
    tool_name: "Write",
    cwd: tmp,
    tool_input: {
      file_path: path.join(tmp, "src", "new-service.ts"),
      content: "export const ok = true;\n",
    },
  }, "deny", workerEnv);
  fs.appendFileSync(path.join(tmp, "docs", "ai", "ACEF_demo_DELIVERY_AUDIT.md"), [
    "",
    "| Step | Tool | Status |",
    "| --- | --- | --- |",
    "| Story 1.1 create | bmad-create-story | IN PROGRESS |",
    "",
    "Reuse-before-create:",
    "- Checked `src/services/current.ts` and `sharedApiClient`; reused the canonical service pattern.",
    "- Do-not-copy: avoided `legacy.service.direct-fetch`.",
    "",
  ].join("\n"));
  expectHookDecision("started step ledger", storyCommandPayload, "allow");
  expectHookDecision("P1 conformance allows source write", {
    tool_name: "Write",
    cwd: tmp,
    tool_input: {
      file_path: path.join(tmp, "src", "new-service.ts"),
      content: "export const ok = true;\n",
    },
  }, "allow", workerEnv);

  const lightweight = fs.mkdtempSync(path.join(os.tmpdir(), "acef-lightweight-"));
  fs.mkdirSync(path.join(lightweight, "docs", "ai"), { recursive: true });
  fs.writeFileSync(path.join(lightweight, ".acef-lightweight-lane"), "active\n");
  fs.writeFileSync(path.join(lightweight, "docs", "ai", "pattern-registry.json"), fs.readFileSync(path.join(tmp, "docs", "ai", "pattern-registry.json"), "utf8"));
  expectHookDecision("lightweight lane missing P1 conformance", {
    tool_name: "Write",
    cwd: lightweight,
    tool_input: {
      file_path: path.join(lightweight, "src", "light.ts"),
      content: "export const light = true;\n",
    },
  }, "deny", workerEnv);
  fs.rmSync(lightweight, { recursive: true, force: true });

  expectPass("preflight", ["--repo", tmp, "--check", "preflight"]);
  expectPass("adapter-freshness", ["--repo", tmp, "--check", "adapter-freshness", "--adapter", "docs/codebase-map.md"]);
  expectPass("pattern-registry", ["--repo", tmp, "--check", "pattern-registry"]);
  expectPass("reuse-before-create", ["--repo", tmp, "--check", "reuse-before-create", "--ledger", "docs/ai/ACEF_demo_DELIVERY_AUDIT.md"]);
  expectPass("do-not-copy", ["--repo", tmp, "--check", "do-not-copy", "--ledger", "docs/ai/ACEF_demo_DELIVERY_AUDIT.md"]);
  expectPass("claims", ["--repo", tmp, "--check", "claims", "--ledger", "docs/ai/ACEF_demo_DELIVERY_AUDIT.md"]);
  expectPass("seeded-epic-gates", ["--repo", tmp, "--check", "seeded-epic-gates", "--ledger", "docs/ai/ACEF_demo_DELIVERY_AUDIT.md"]);
  expectPass("epic-boundary", ["--repo", tmp, "--check", "epic-boundary", "--ledger", "docs/ai/ACEF_demo_DELIVERY_AUDIT.md", "--target-epic", "2"]);
  expectPass("replan-counter", ["--repo", tmp, "--check", "replan-counter", "--ledger", "docs/ai/ACEF_demo_DELIVERY_AUDIT.md"]);

  run("git", ["add", "docs"], { cwd: tmp });
  run("git", ["commit", "-m", "add acef docs"], { cwd: tmp });
  expectPass("adapter-freshness", ["--repo", tmp, "--check", "adapter-freshness", "--adapter", "docs/codebase-map.md"]);

  fs.mkdirSync(path.join(tmp, "src"), { recursive: true });
  fs.writeFileSync(path.join(tmp, "src", "changed.ts"), "export const changed = true;\n");
  run("git", ["add", "src/changed.ts"], { cwd: tmp });
  run("git", ["commit", "-m", "change covered source"], { cwd: tmp });
  expectFail("adapter-freshness", ["--repo", tmp, "--check", "adapter-freshness", "--adapter", "docs/codebase-map.md"]);

  fs.writeFileSync(path.join(tmp, "docs", "stale-map.md"), "# stale\n\ncommit: deadbeef\n");
  expectFail("adapter-freshness", ["--repo", tmp, "--check", "adapter-freshness", "--adapter", "docs/stale-map.md"]);

  fs.writeFileSync(path.join(tmp, "docs", "ai", "ACEF_bad_reuse_DELIVERY_AUDIT.md"), "Status: PASS\n");
  expectFail("reuse-before-create", ["--repo", tmp, "--check", "reuse-before-create", "--ledger", "docs/ai/ACEF_bad_reuse_DELIVERY_AUDIT.md"]);

  fs.writeFileSync(path.join(tmp, "docs", "ai", "ACEF_bad_copy_DELIVERY_AUDIT.md"), [
    "Status: PASS",
    "Reuse-before-create:",
    "- Use legacy.service.direct-fetch as the implementation pattern.",
    "- Checked `src/services/current.ts`.",
  ].join("\n"));
  expectFail("do-not-copy", ["--repo", tmp, "--check", "do-not-copy", "--ledger", "docs/ai/ACEF_bad_copy_DELIVERY_AUDIT.md"]);
  expectHookDecision("P1 do-not-copy misuse denies source write", {
    tool_name: "Write",
    cwd: tmp,
    tool_input: {
      file_path: path.join(tmp, "src", "bad-service.ts"),
      content: "export const bad = true;\n",
    },
  }, "deny", workerEnv);

  fs.rmSync(path.join(tmp, "docs", "ai", "ACEF_PREFLIGHT.md"));
  expectFail("preflight", ["--repo", tmp, "--check", "preflight"]);

  console.log("acef-process-validator tests passed");
} finally {
  fs.rmSync(tmp, { recursive: true, force: true });
}
