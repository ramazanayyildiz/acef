    canSpawnAgents: false,
  }, null, 2));
  expectHookDecision("PARTIAL accepted guarded workshape allows source write", {
    tool_name: "Write",
    cwd: partialHook,
    tool_input: {
      file_path: path.join(partialHook, "src", "accepted.ts"),
      content: "export const accepted = true;\n",
    },
  }, "allow", workerEnv);
  fs.writeFileSync(path.join(partialHook, "docs", "ai", "ACEF_partial_DELIVERY_AUDIT.md"), [
    "Status: PASS",
    "track: standard",
    "workShape: controller",
    "Reuse-before-create:",
    "- Checked `src/services/current.ts` and `sharedApiClient`.",
    "- Do-not-copy: avoided `legacy.service.direct-fetch`.",
  ].join("\n"));
  expectHookDecision("PARTIAL uncovered workshape denies source write", {
    tool_name: "Write",
    cwd: partialHook,
    tool_input: {
      file_path: path.join(partialHook, "src", "blocked.ts"),
      content: "export const blocked = true;\n",
    },
  }, "deny", workerEnv);
  fs.rmSync(partialHook, { recursive: true, force: true });

  fs.rmSync(path.join(tmp, "docs", "ai", "ACEF_PREFLIGHT.md"));
  expectFail("preflight", ["--repo", tmp, "--check", "preflight"]);

  const codexTmp = fs.mkdtempSync(path.join(os.tmpdir(), "acef-codex-guard-"));
  run("git", ["init"], { cwd: codexTmp });
  run("git", ["config", "user.email", "acef@example.invalid"], { cwd: codexTmp });
  run("git", ["config", "user.name", "ACEF Test"], { cwd: codexTmp });
  fs.mkdirSync(path.join(codexTmp, "docs", "ai"), { recursive: true });
  fs.mkdirSync(path.join(codexTmp, "src"), { recursive: true });
  fs.writeFileSync(path.join(codexTmp, "docs", "ai", "ACEF_demo_DELIVERY_AUDIT.md"), "Status: PASS\n");
  fs.writeFileSync(path.join(codexTmp, "docs", "ai", "ACEF_ACTIVE_LEDGER"), "docs/ai/ACEF_demo_DELIVERY_AUDIT.md\n");
  fs.writeFileSync(path.join(codexTmp, "README.md"), "# codex guard fixture\n");
  run("git", ["add", "."], { cwd: codexTmp });
  run("git", ["commit", "-m", "init"], { cwd: codexTmp });
  const codexBase = run("git", ["rev-parse", "--short", "HEAD"], { cwd: codexTmp });

  fs.writeFileSync(path.join(codexTmp, "src", "needs-scope.ts"), "export const needsScope = true;\n");
  expectCodexGuardFail("missing worker scope", ["--repo", codexTmp, "--role", "worker", "--story", "1.1", "--base-ref", codexBase]);
  fs.rmSync(path.join(codexTmp, "src", "needs-scope.ts"));

  fs.writeFileSync(path.join(codexTmp, "docs", "ai", "ACEF_CURRENT_CONTEXT.md"), [
    "source_ledger: docs/ai/ACEF_demo_DELIVERY_AUDIT.md",
    "active_story: 1.1",
    "active_phase: dev",
    "",
  ].join("\n"));
  fs.writeFileSync(path.join(codexTmp, "docs", "ai", "ACEF_ACTIVE_RUN.json"), JSON.stringify({
    runId: "RUN-codex-guard",
    repo: "codex-guard-fixture",
    lane: "lightweight",
    status: "active",
    activeStory: "1.1",
    activePhase: "dev",
    ledgerPath: "docs/ai/ACEF_demo_DELIVERY_AUDIT.md",
    contextPath: "docs/ai/ACEF_CURRENT_CONTEXT.md",
  }, null, 2));
  fs.writeFileSync(path.join(codexTmp, "docs", "ai", "ACEF_ACTIVE_WORKER_SCOPE.json"), JSON.stringify({
    activeStory: "1.1",
    phase: "dev",
    workerId: "codex-worker",
    allowedPaths: ["src/story-1-1/**", "tests/story-1-1/**"],
    baseRef: codexBase,
    maxCommits: 1,
    canEditLedger: false,
    canSpawnAgents: false,
  }, null, 2));
  run("git", ["add", "docs/ai/ACEF_ACTIVE_RUN.json", "docs/ai/ACEF_CURRENT_CONTEXT.md", "docs/ai/ACEF_ACTIVE_WORKER_SCOPE.json"], { cwd: codexTmp });
  run("git", ["commit", "-m", "scope Story 1.1"], { cwd: codexTmp });
  const codexScopedBase = run("git", ["rev-parse", "--short", "HEAD"], { cwd: codexTmp });
  fs.mkdirSync(path.join(codexTmp, "src", "story-1-1"), { recursive: true });
  fs.writeFileSync(path.join(codexTmp, "src", "story-1-1", "ok.ts"), "export const ok = true;\n");
  expectCodexGuardPass("allowed worker scope", ["--repo", codexTmp, "--role", "worker", "--story", "1.1", "--base-ref", codexScopedBase]);
  run("git", ["add", "src/story-1-1/ok.ts"], { cwd: codexTmp });
  run("git", ["commit", "--amend", "--no-edit"], { cwd: codexTmp });
  fs.appendFileSync(path.join(codexTmp, "src", "story-1-1", "ok.ts"), "export const stillOk = true;\n");
  expectCodexGuardPass("allowed modified tracked file", ["--repo", codexTmp, "--role", "worker", "--story", "1.1", "--base-ref", "HEAD"]);
  fs.writeFileSync(path.join(codexTmp, "src", "story-1-2.ts"), "export const bad = true;\n");
  expectCodexGuardFail("out of scope worker write", ["--repo", codexTmp, "--role", "worker", "--story", "1.1", "--base-ref", codexScopedBase]);
  fs.rmSync(path.join(codexTmp, "src", "story-1-2.ts"));
  fs.appendFileSync(path.join(codexTmp, "docs", "ai", "ACEF_demo_DELIVERY_AUDIT.md"), "worker should not edit ledger\n");
  expectCodexGuardFail("worker ledger edit", ["--repo", codexTmp, "--role", "worker", "--story", "1.1", "--base-ref", codexScopedBase]);
  fs.rmSync(codexTmp, { recursive: true, force: true });

  const dispatcherNoHook = fs.mkdtempSync(path.join(os.tmpdir(), "acef-dispatcher-no-hook-"));
  fs.mkdirSync(path.join(dispatcherNoHook, "src"), { recursive: true });
  expectDispatcherDecision("allows repo without local hook", {
    tool_name: "Write",
    cwd: dispatcherNoHook,
    tool_input: { file_path: path.join(dispatcherNoHook, "src", "free.ts") },
  }, "allow");
  fs.rmSync(dispatcherNoHook, { recursive: true, force: true });

  const dispatcherLocal = fs.mkdtempSync(path.join(os.tmpdir(), "acef-dispatcher-local-"));
  fs.mkdirSync(path.join(dispatcherLocal, ".acef", "hooks"), { recursive: true });
  fs.mkdirSync(path.join(dispatcherLocal, "src"), { recursive: true });
  fs.writeFileSync(path.join(dispatcherLocal, ".acef-lightweight-lane"), "active\n");
  fs.copyFileSync(bmadHook, path.join(dispatcherLocal, ".acef", "hooks", "acef-bmad-hard-wall.mjs"));
  expectDispatcherDecision("forwards to local hook", {
    tool_name: "Write",
    cwd: dispatcherLocal,
    tool_input: { file_path: path.join(dispatcherLocal, "src", "guarded.ts") },
  }, "deny");
  fs.rmSync(dispatcherLocal, { recursive: true, force: true });

  const installerHome = fs.mkdtempSync(path.join(os.tmpdir(), "acef-installer-home-"));
  fs.mkdirSync(path.join(installerHome, ".codex"), { recursive: true });
  fs.writeFileSync(path.join(installerHome, ".codex", "hooks.json"), JSON.stringify({
    hooks: {
      PreToolUse: [
        {
          matcher: "exec_command",
          hooks: [{ type: "command", command: "context-mode hook codex pretooluse" }],
        },
        {
          matcher: "Write",
          hooks: [{ type: "command", command: "node ~/.codex/hooks/acef-bmad-hard-wall.mjs" }],
        },
      ],
    },
  }, null, 2));
  fs.mkdirSync(path.join(installerHome, ".config", "opencode", "plugins"), { recursive: true });
  fs.writeFileSync(path.join(installerHome, ".config", "opencode", "plugins", "acef-bmad-hard-wall.mjs"), "old global full hook\n");
  const installerRepo = fs.mkdtempSync(path.join(os.tmpdir(), "acef-installer-repo-"));
  run("node", [path.join(repoRoot, "scripts", "install-acef-bmad-guard"), "--repo", installerRepo, "--global-dispatcher"], {
    env: { ...process.env, HOME: installerHome },
  });
  if (!fs.existsSync(path.join(installerRepo, ".acef", "hooks", "acef-bmad-hard-wall.mjs"))) {
    throw new Error("Expected installer to add local ACEF guard engine");
  }
  if (!fs.existsSync(path.join(installerRepo, ".opencode", "plugins", "acef-bmad-hard-wall.js"))) {
    throw new Error("Expected installer to add local OpenCode plugin");
  }
  const installedCodexHooks = JSON.parse(fs.readFileSync(path.join(installerHome, ".codex", "hooks.json"), "utf8"));
  const codexPreTool = installedCodexHooks.hooks.PreToolUse || [];
  if (!codexPreTool.some((entry) => (entry.hooks || []).some((hook) => String(hook.command || "").includes("context-mode hook codex pretooluse")))) {
    throw new Error("Expected installer to preserve existing Codex PreToolUse hook");
  }
  if (!codexPreTool.some((entry) => (entry.hooks || []).some((hook) => String(hook.command || "").includes("acef-bmad-dispatcher.mjs")))) {
    throw new Error("Expected installer to add ACEF dispatcher to Codex PreToolUse hooks");
  }
  if (codexPreTool.some((entry) => (entry.hooks || []).some((hook) => String(hook.command || "").includes("acef-bmad-hard-wall.mjs")))) {
    throw new Error("Expected installer to remove old full ACEF guard from Codex PreToolUse hooks");
  }
  const installedClaudeSettings = JSON.parse(fs.readFileSync(path.join(installerHome, ".claude", "settings.json"), "utf8"));
  if (!String(JSON.stringify(installedClaudeSettings)).includes("acef-bmad-dispatcher.mjs")) {
    throw new Error("Expected installer to add ACEF dispatcher to Claude PreToolUse hooks");
  }
  if (fs.existsSync(path.join(installerHome, ".config", "opencode", "plugins", "acef-bmad-hard-wall.mjs"))) {
    throw new Error("Expected installer to remove old full ACEF guard sibling from global OpenCode plugin dir");
  }
  fs.rmSync(installerHome, { recursive: true, force: true });
  fs.rmSync(installerRepo, { recursive: true, force: true });

  console.log("acef-process-validator tests passed");
} finally {
  fs.rmSync(tmp, { recursive: true, force: true });
}
