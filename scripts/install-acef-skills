#!/usr/bin/env node
const fs = require("node:fs");
const path = require("node:path");
const { validateSkillMetadata } = require("./lib/acef-skill-metadata");
const { writeInstallationManifest } = require("./lib/acef-installation");

const repoRoot = path.resolve(__dirname, "..");
const sourceSkillsDir = path.join(repoRoot, "skills");
const defaultSkills = [
  "acef",
  "acef-adapter",
  "acef-router",
  "acef-test-bootstrap",
  "map-codebase",
];
const reviewLensSkills = ["bug-hunter", "implementation-shape-review"];

const toolSkillDirs = {
  codex: [".codex", "skills"],
  claude: [".claude", "skills"],
  opencode: [".opencode", "skills"],
};

function usage() {
  console.log(`Usage: scripts/install-acef-skills --repo <path> [--tool codex|claude|opencode|all] [--skill name ...] [--review-lenses] [--all-core]

Installs ACEF skills repo-locally. Defaults:
  --tool all
  --skill acef acef-adapter acef-router acef-test-bootstrap map-codebase

Examples:
  scripts/install-acef-skills --repo /path/to/repo
  scripts/install-acef-skills --repo /path/to/repo --review-lenses
  scripts/install-acef-skills --repo /path/to/repo --tool codex --skill acef --skill map-codebase
  scripts/install-acef-skills --repo /path/to/repo --all-core`);
}

function parseArgs(argv) {
  const opts = {
    repo: "",
    tools: ["all"],
    skills: [],
    reviewLenses: false,
    allCore: false,
  };

  for (let i = 0; i < argv.length; i += 1) {
    const arg = argv[i];
    if (arg === "--repo" || arg === "--target") {
      opts.repo = argv[++i];
    } else if (arg === "--tool") {
      opts.tools = [argv[++i]];
    } else if (arg === "--skill") {
      opts.skills.push(argv[++i]);
    } else if (arg === "--all-core") {
      opts.allCore = true;
    } else if (arg === "--review-lenses") {
      opts.reviewLenses = true;
    } else if (arg === "-h" || arg === "--help") {
      usage();
      process.exit(0);
    } else {
      throw new Error(`Unknown argument: ${arg}`);
    }
  }

  if (!opts.repo) throw new Error("--repo is required");
  opts.repo = path.resolve(opts.repo);
  return opts;
}

function copyDir(source, target) {
  if (!fs.existsSync(source)) throw new Error(`Skill source not found: ${source}`);
  fs.rmSync(target, { recursive: true, force: true });
  fs.mkdirSync(path.dirname(target), { recursive: true });
  fs.cpSync(source, target, { recursive: true });
}

function commandBody(skill) {
  return `---
description: Use the ${skill} ACEF skill in this repo
---

Use the \`${skill}\` skill for this request.

Load the project-local skill from this repo, follow its instructions, and keep the response lean:
- use the active repo ledger and local ACEF files;
- do not paste large artifacts or logs into chat;
- write durable evidence to disk when the skill requires it.

User request:
{{args}}
`;
}

function installOpenCodeCommands(repo, skills) {
  const commandDir = path.join(repo, ".opencode", "commands");
  fs.mkdirSync(commandDir, { recursive: true });
  for (const skill of skills) {
    const file = path.join(commandDir, `${skill}.md`);
    fs.writeFileSync(file, commandBody(skill));
  }
  console.log(`Installed ${skills.length} OpenCode command(s): ${commandDir}`);
}

function selectedTools(tools) {
  const values = tools.includes("all") ? Object.keys(toolSkillDirs) : tools;
  for (const tool of values) {
    if (!toolSkillDirs[tool]) throw new Error(`Unknown tool: ${tool}`);
  }
  return values;
}

function selectedSkills(opts) {
  if (opts.allCore) {
    return fs.readdirSync(sourceSkillsDir)
      .filter((name) => fs.existsSync(path.join(sourceSkillsDir, name, "SKILL.md")))
      .sort();
  }
  const selected = opts.skills.length ? [...opts.skills] : [...defaultSkills];
  if (opts.reviewLenses) selected.push(...reviewLensSkills);
  return [...new Set(selected)].sort();
}

const opts = parseArgs(process.argv.slice(2));
const tools = selectedTools(opts.tools);
const skills = selectedSkills(opts);

for (const skill of skills) {
  const source = path.join(sourceSkillsDir, skill, "SKILL.md");
  if (!fs.existsSync(source)) throw new Error(`Skill source not found: ${source}`);
  const { errors } = validateSkillMetadata(source, skill);
  if (errors.length) throw new Error(`Invalid skill metadata for ${skill}: ${errors.join("; ")}`);
}

for (const tool of tools) {
  const targetBase = path.join(opts.repo, ...toolSkillDirs[tool]);
  for (const skill of skills) {
    copyDir(path.join(sourceSkillsDir, skill), path.join(targetBase, skill));
  }
  console.log(`Installed ${skills.length} ACEF skill(s) for ${tool}: ${targetBase}`);
  if (tool === "opencode") {
    installOpenCodeCommands(opts.repo, skills);
  }
}
console.log(`Updated ACEF installation manifest: ${writeInstallationManifest(opts.repo, repoRoot, "skills", {
  tools,
  skills,
  reviewLenses: opts.reviewLenses,
  allCore: opts.allCore,
})}`);
