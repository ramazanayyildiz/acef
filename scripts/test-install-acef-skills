#!/usr/bin/env node
const assert = require("node:assert/strict");
const fs = require("node:fs");
const os = require("node:os");
const path = require("node:path");
const cp = require("node:child_process");

const repoRoot = path.resolve(__dirname, "..");
const installer = path.join(repoRoot, "scripts", "install-acef-skills");
const tmp = fs.mkdtempSync(path.join(os.tmpdir(), "acef-skills-"));

function run(args) {
  return cp.execFileSync(process.execPath, [installer, ...args], { cwd: repoRoot, encoding: "utf8" });
}

try {
  run(["--repo", tmp]);
  let installation = JSON.parse(fs.readFileSync(path.join(tmp, "docs", "ai", "ACEF_INSTALLATION.json"), "utf8"));
  assert.equal(installation.schema, "acef.installation.v1");
  assert.ok(installation.acefVersion.sourceCommit);
  assert.deepEqual(installation.components.skills.skills, [
    "acef",
    "acef-adapter",
    "acef-router",
    "acef-test-bootstrap",
    "map-codebase",
    "spec-readiness",
  ]);
  for (const toolDir of [[".codex", "skills"], [".claude", "skills"], [".opencode", "skills"]]) {
    assert.ok(fs.existsSync(path.join(tmp, ...toolDir, "acef", "SKILL.md")));
    assert.ok(fs.existsSync(path.join(tmp, ...toolDir, "spec-readiness", "SKILL.md")));
    assert.ok(!fs.existsSync(path.join(tmp, ...toolDir, "bug-hunter")), "bug-hunter must not enter minimal default");
    assert.ok(!fs.existsSync(path.join(tmp, ...toolDir, "implementation-shape-review")), "shape review must not enter minimal default");
  }

  run(["--repo", tmp, "--review-lenses"]);
  installation = JSON.parse(fs.readFileSync(path.join(tmp, "docs", "ai", "ACEF_INSTALLATION.json"), "utf8"));
  assert.equal(installation.components.skills.reviewLenses, true);
  assert.ok(installation.components.skills.skills.includes("bug-hunter"));
  assert.ok(installation.components.skills.skills.includes("implementation-shape-review"));
  for (const toolDir of [[".codex", "skills"], [".claude", "skills"], [".opencode", "skills"]]) {
    assert.ok(fs.existsSync(path.join(tmp, ...toolDir, "bug-hunter", "SKILL.md")));
    assert.ok(fs.existsSync(path.join(tmp, ...toolDir, "bug-hunter", "templates", "report-template.md")));
    assert.ok(fs.existsSync(path.join(tmp, ...toolDir, "implementation-shape-review", "SKILL.md")));
    assert.ok(fs.existsSync(path.join(tmp, ...toolDir, "implementation-shape-review", "templates", "report-template.md")));
  }
  assert.ok(fs.existsSync(path.join(tmp, ".opencode", "commands", "bug-hunter.md")));
  assert.ok(fs.existsSync(path.join(tmp, ".opencode", "commands", "implementation-shape-review.md")));

  console.log("acef skill installer tests passed");
} finally {
  fs.rmSync(tmp, { recursive: true, force: true });
}
