#!/usr/bin/env node
const fs = require("node:fs");
const os = require("node:os");
const path = require("node:path");
const cp = require("node:child_process");

const repoRoot = path.resolve(__dirname, "..");
const installer = path.join(repoRoot, "scripts", "install-acef-tools");
const tmp = fs.mkdtempSync(path.join(os.tmpdir(), "acef-tools-install-"));

function run(command, args, options = {}) {
  const { allowFailure = false, ...execOptions } = options;
  try {
    return cp.execFileSync(command, args, {
      encoding: "utf8",
      stdio: ["ignore", "pipe", "pipe"],
      ...execOptions,
    });
  } catch (error) {
    if (allowFailure) return error.stdout || "";
    throw error;
  }
}

try {
  fs.writeFileSync(path.join(tmp, "package.json"), JSON.stringify({ private: true, type: "module" }, null, 2));
  fs.writeFileSync(path.join(tmp, "AGENTS.md"), "# ACEF test repo\n");
  run("node", [installer, "--repo", tmp]);

  const validator = path.join(tmp, ".acef", "bin", "acef-process-validator");
  const state = path.join(tmp, ".acef", "bin", "acef-state");
  const status = path.join(tmp, ".acef", "bin", "acef-status");
  const next = path.join(tmp, ".acef", "bin", "acef-next");
  const updater = path.join(tmp, ".acef", "bin", "update-acef-installation");
  const workflowValidate = path.join(tmp, ".acef", "bin", "acef-workflow-validate");
  const parser = path.join(tmp, ".acef", "bin", "lib", "acef-state-parser.js");
  const installationHelper = path.join(tmp, ".acef", "bin", "lib", "acef-installation.js");
  const schema = path.join(tmp, ".acef", "schemas", "active-run.schema.json");
  const capabilitySchema = path.join(tmp, ".acef", "schemas", "capability-change.schema.json");
  const controlDosingSchema = path.join(tmp, ".acef", "schemas", "control-dosing.schema.json");
  const controlDosingManifest = path.join(tmp, ".acef", "control-dosing.json");
  const workflowSchema = path.join(tmp, ".acef", "schemas", "workflow.schema.json");
  const workflow = path.join(tmp, ".acef", "workflows", "lightweight-review.yaml");
  const runtimePackage = path.join(tmp, ".acef", "bin", "package.json");
  if (!fs.existsSync(validator)) throw new Error("validator wrapper was not installed");
  if (!fs.existsSync(state)) throw new Error("typed-state writer was not installed");
  if (!fs.existsSync(status)) throw new Error("status helper was not installed");
  if (!fs.existsSync(next)) throw new Error("next-action helper was not installed");
  if (!fs.existsSync(updater)) throw new Error("ACEF update helper was not installed");
  if (!fs.existsSync(workflowValidate)) throw new Error("workflow validator was not installed");
  if (!fs.existsSync(parser)) throw new Error("parser support library was not installed");
  if (!fs.existsSync(installationHelper)) throw new Error("installation support library was not installed");
  if (!fs.existsSync(schema)) throw new Error("typed-state schemas were not installed");
  if (!fs.existsSync(capabilitySchema)) throw new Error("capability-change schema was not installed");
  if (!fs.existsSync(controlDosingSchema)) throw new Error("control-dosing schema was not installed");
  if (!fs.existsSync(controlDosingManifest)) throw new Error("control-dosing manifest was not installed");
  if (!fs.existsSync(workflowSchema)) throw new Error("workflow schema was not installed");
  if (!fs.existsSync(workflow)) throw new Error("lightweight workflow was not installed");
  if (JSON.parse(fs.readFileSync(runtimePackage, "utf8")).type !== "commonjs") throw new Error("ACEF runtime CommonJS boundary was not installed");
  const installationManifest = path.join(tmp, "docs", "ai", "ACEF_INSTALLATION.json");
  if (!fs.existsSync(installationManifest)) throw new Error("ACEF installation manifest was not written");
  const installation = JSON.parse(fs.readFileSync(installationManifest, "utf8"));
  if (installation.schema !== "acef.installation.v1") throw new Error("installation manifest schema missing");
  if (!installation.acefVersion?.sourceCommit) throw new Error("installation manifest missing source commit");
  if (!installation.components?.tools) throw new Error("installation manifest missing tools component");
  if (!installation.components.tools.tools.includes("update-acef-installation")) throw new Error("tools component missing updater");
  if (!installation.components.tools.controlDosing) throw new Error("tools component missing control-dosing manifest");

  fs.mkdirSync(path.join(tmp, "docs", "ai"), { recursive: true });
  fs.writeFileSync(path.join(tmp, "docs", "ai", "ACEF_demo_DELIVERY_AUDIT.md"), [
    "# Demo",
    "active_lane: Full BMAD v2",
    "",
    "## Session Handoff",
    "last_passed_gate: Story 1.1 ATDD PASS",
    "",
  ].join("\n"));
  fs.writeFileSync(path.join(tmp, "docs", "ai", "ACEF_CURRENT_CONTEXT.md"), [
    "source_ledger: docs/ai/ACEF_demo_DELIVERY_AUDIT.md",
    "active_story: story 1.1",
    "active_phase: development",
    "last_passed_gate: Story 1.1 ATDD PASS",
    "",
    "## Current Work",
    "Story 1.1",
    "## Gate State",
    "ATDD PASS",
    "## Allowed Scope",
    "Scope",
    "## Relevant Acceptance Criteria",
    "AC",
    "## Required Commands",
    "npm test",
    "## Deferred and Out of Scope",
    "None",
    "## Known Pitfalls",
    "None",
    "## Artifact Paths",
    "docs/ai/ACEF_CURRENT_CONTEXT.md",
    "## Role Inputs",
    "Inputs",
    "",
  ].join("\n"));
  run("git", ["init", "-q"], { cwd: tmp });
  run("git", ["config", "user.email", "acef@example.test"], { cwd: tmp });
  run("git", ["config", "user.name", "ACEF Test"], { cwd: tmp });
  run("git", ["add", "."], { cwd: tmp });
  run("git", ["commit", "-qm", "fixture"], { cwd: tmp });
  run(state, [
    "active-run", "--repo", tmp,
    "--run-id", "RUN-install-test",
    "--lane", "full-bmad",
    "--status", "active",
    "--story", "story 1.1",
    "--phase", "development",
    "--worker-role", "developer",
    "--full-ledger-access", "denied",
    "--max-lines", "120",
    "--ledger", "docs/ai/ACEF_demo_DELIVERY_AUDIT.md",
    "--context", "docs/ai/ACEF_CURRENT_CONTEXT.md",
  ]);

  const output = run(validator, [
    "--repo", tmp,
    "--check", "current-context",
    "--ledger", "docs/ai/ACEF_demo_DELIVERY_AUDIT.md",
  ]);
  if (!output.includes("PASS current-context:")) {
    throw new Error(`installed validator did not use installed parser:\n${output}`);
  }
  const controlDosingOutput = run(validator, ["--repo", tmp, "--check", "control-dosing"]);
  if (!controlDosingOutput.includes("PASS control-dosing:")) {
    throw new Error(`installed validator did not validate installed control dosing:\n${controlDosingOutput}`);
  }
  const statusOutput = run(status, ["--repo", tmp, "--format", "json"]);
  const statusJson = JSON.parse(statusOutput);
  if (statusJson.status !== "ready") throw new Error(`installed status helper did not report ready:\n${statusOutput}`);
  if (statusJson.activeRun.activeStory !== "story 1.1") throw new Error("installed status helper did not read active run");
  if (!statusJson.readOrder.includes("docs/ai/ACEF_CURRENT_CONTEXT.md")) throw new Error("installed status helper did not include current-context read order");
  if (statusJson.installation.sourceCommit !== installation.acefVersion.sourceCommit) throw new Error("installed status helper did not report ACEF installation version");
  if (!statusJson.installation.components.includes("tools")) throw new Error("installed status helper missing installed components");
  fs.writeFileSync(installationManifest, "{}\n");
  const invalidStatus = run(status, ["--repo", tmp, "--format", "json"], { allowFailure: true });
  const invalidJson = JSON.parse(invalidStatus);
  if (invalidJson.status !== "needs-attention") throw new Error("installed status helper accepted an invalid ACEF installation manifest");
  fs.writeFileSync(installationManifest, `${JSON.stringify(installation, null, 2)}\n`);
  const nextOutput = run(next, ["--repo", tmp, "--format", "json"]);
  const nextJson = JSON.parse(nextOutput);
  if (nextJson.status !== "ready") throw new Error(`installed next helper did not report ready:\n${nextOutput}`);
  if (nextJson.active_state.next_allowed_action !== "implement_to_green") throw new Error("installed next helper did not derive development action");
  if (!nextJson.forbidden.actions.includes("start_next_story")) throw new Error("installed next helper missing story boundary");
  const workflowOutput = run(workflowValidate, ["--repo", tmp, "--workflow", ".acef/workflows/lightweight-review.yaml"]);
  if (!workflowOutput.includes("PASS workflow lightweight-review:")) throw new Error("installed workflow validator did not validate installed workflow");
  run(updater, ["--repo", tmp, "--review-lenses"]);
  if (!fs.existsSync(path.join(tmp, ".acef", "hooks", "acef-bmad-hard-wall.mjs"))) throw new Error("installed updater did not refresh guard hook");
  if (!fs.existsSync(path.join(tmp, ".codex", "skills", "acef", "SKILL.md"))) throw new Error("installed updater did not refresh Codex skills");
  const refreshedInstallation = JSON.parse(fs.readFileSync(installationManifest, "utf8"));
  if (!refreshedInstallation.components?.bmadGuard) throw new Error("installed updater did not record guard component");
  if (!refreshedInstallation.components?.skills?.skills?.includes("bug-hunter")) throw new Error("installed updater did not record refreshed review lenses");

  console.log("install-acef-tools tests passed");
} finally {
  fs.rmSync(tmp, { recursive: true, force: true });
}
