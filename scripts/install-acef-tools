#!/usr/bin/env node
const fs = require("node:fs");
const path = require("node:path");
const { writeInstallationManifest } = require("./lib/acef-installation");

const repoRoot = path.resolve(__dirname, "..");
const tools = [
  "acef-state",
  "acef-status",
  "acef-next",
  "acef-workflow-validate",
  "acef-process-validator",
  "acef-closeout-verify",
  "acef-codex-guard",
  "acef-query",
  "acef-context-experiment",
  "acef-context-experiment-report",
  "acef-context-experiment-manifest",
  "acef-context-next-run",
  "acef-context-actor-prompt",
  "acef-context-actor-prompt-batch",
  "acef-context-record-actor-report",
  "acef-pr-review",
  "acef-worker-result",
  "update-acef-installation",
];

function usage() {
  console.log(`Usage: scripts/install-acef-tools --repo <path>

Installs ACEF local helper CLIs into:
  <repo>/.acef/bin/

This keeps validators and guards repo-local instead of relying on the ACEF checkout path.`);
}

function parseArgs(argv) {
  const opts = { repo: "" };
  for (let index = 0; index < argv.length; index += 1) {
    const arg = argv[index];
    if (arg === "--repo" || arg === "--target") {
      opts.repo = argv[++index] || "";
    } else if (arg === "-h" || arg === "--help") {
      usage();
      process.exit(0);
    } else {
      throw new Error(`Unknown argument: ${arg}`);
    }
  }
  if (!opts.repo) throw new Error("--repo is required");
  opts.repo = path.resolve(opts.repo);
  return opts;
}

function copyTool(name, targetRepo) {
  const source = path.join(repoRoot, "scripts", name);
  const target = path.join(targetRepo, ".acef", "bin", name);
  const targetCjs = `${target}.cjs`;
  if (!fs.existsSync(source)) throw new Error(`Tool source not found: ${source}`);
  fs.mkdirSync(path.dirname(target), { recursive: true });
  fs.copyFileSync(source, targetCjs);
  fs.writeFileSync(target, `#!/usr/bin/env sh\nexec node "$(dirname "$0")/${name}.cjs" "$@"\n`);
  fs.chmodSync(target, 0o755);
  fs.chmodSync(targetCjs, 0o755);
  return target;
}

function copySupportLibraries(targetRepo) {
  const sourceDir = path.join(repoRoot, "scripts", "lib");
  const targetDir = path.join(targetRepo, ".acef", "bin", "lib");
  if (!fs.existsSync(sourceDir)) return [];
  fs.mkdirSync(targetDir, { recursive: true });
  const copied = [];
  for (const entry of fs.readdirSync(sourceDir).sort((a, b) => a.localeCompare(b))) {
    const source = path.join(sourceDir, entry);
    if (!fs.statSync(source).isFile()) continue;
    const target = path.join(targetDir, entry);
    fs.copyFileSync(source, target);
    copied.push(target);
  }
  return copied;
}

function writeRuntimePackage(targetRepo) {
  const targetDir = path.join(targetRepo, ".acef", "bin");
  fs.mkdirSync(targetDir, { recursive: true });
  const target = path.join(targetDir, "package.json");
  fs.writeFileSync(target, `${JSON.stringify({ private: true, type: "commonjs" }, null, 2)}\n`);
  return target;
}

function copySchemas(targetRepo) {
  const sourceDir = path.join(repoRoot, "schemas");
  const targetDir = path.join(targetRepo, ".acef", "schemas");
  if (!fs.existsSync(sourceDir)) return [];
  fs.mkdirSync(targetDir, { recursive: true });
  const copied = [];
  for (const entry of fs.readdirSync(sourceDir).sort((a, b) => a.localeCompare(b))) {
    const source = path.join(sourceDir, entry);
    if (!fs.statSync(source).isFile()) continue;
    const target = path.join(targetDir, entry);
    fs.copyFileSync(source, target);
    copied.push(target);
  }
  return copied;
}

function copyControlDosing(targetRepo) {
  const source = path.join(repoRoot, "method", "control-dosing.json");
  if (!fs.existsSync(source)) return "";
  const target = path.join(targetRepo, ".acef", "control-dosing.json");
  fs.mkdirSync(path.dirname(target), { recursive: true });
  fs.copyFileSync(source, target);
  return target;
}

function copyExperimentFixtures(targetRepo) {
  const sourceDir = path.join(repoRoot, "docs", "experiments", "context-retrieval", "tasks");
  const targetDir = path.join(targetRepo, ".acef", "context-retrieval", "tasks");
  if (!fs.existsSync(sourceDir)) return [];
  fs.mkdirSync(targetDir, { recursive: true });
  const copied = [];
  for (const entry of fs.readdirSync(sourceDir).sort((a, b) => a.localeCompare(b))) {
    const source = path.join(sourceDir, entry);
    if (!fs.statSync(source).isFile()) continue;
    const target = path.join(targetDir, entry);
    fs.copyFileSync(source, target);
    copied.push(target);
  }
  return copied;
}

function copyWorkflows(targetRepo) {
  const sourceDir = path.join(repoRoot, "workflows");
  const targetDir = path.join(targetRepo, ".acef", "workflows");
  if (!fs.existsSync(sourceDir)) return [];
  fs.mkdirSync(targetDir, { recursive: true });
  const copied = [];
  for (const entry of fs.readdirSync(sourceDir).sort((a, b) => a.localeCompare(b))) {
    const source = path.join(sourceDir, entry);
    if (!fs.statSync(source).isFile()) continue;
    const target = path.join(targetDir, entry);
    fs.copyFileSync(source, target);
    copied.push(target);
  }
  return copied;
}

const opts = parseArgs(process.argv.slice(2));
console.log(`Installed ACEF runtime package boundary: ${writeRuntimePackage(opts.repo)}`);
for (const tool of tools) {
  console.log(`Installed ${tool}: ${copyTool(tool, opts.repo)}`);
}
for (const library of copySupportLibraries(opts.repo)) {
  console.log(`Installed support library: ${library}`);
}
for (const schema of copySchemas(opts.repo)) {
  console.log(`Installed schema: ${schema}`);
}
const controlDosing = copyControlDosing(opts.repo);
if (controlDosing) {
  console.log(`Installed control dosing manifest: ${controlDosing}`);
}
for (const fixture of copyExperimentFixtures(opts.repo)) {
  console.log(`Installed context experiment fixture: ${fixture}`);
}
for (const workflow of copyWorkflows(opts.repo)) {
  console.log(`Installed workflow: ${workflow}`);
}
console.log(`Updated ACEF installation manifest: ${writeInstallationManifest(opts.repo, repoRoot, "tools", {
  tools,
  schemas: fs.existsSync(path.join(repoRoot, "schemas")),
  controlDosing: fs.existsSync(path.join(repoRoot, "method", "control-dosing.json")),
  workflows: fs.existsSync(path.join(repoRoot, "workflows")),
})}`);
