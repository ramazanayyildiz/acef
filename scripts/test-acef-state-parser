#!/usr/bin/env node
const fs = require("node:fs");
const os = require("node:os");
const path = require("node:path");

const {
  parseActiveRun,
  parseActorRecord,
  parseEvidenceManifest,
  parseGateVerdict,
  parseApproval,
  parseWorkerScope,
  parseWorkflow,
  parseFreshness,
  safeRelative,
} = require("./lib/acef-state-parser");

const tmp = fs.mkdtempSync(path.join(os.tmpdir(), "acef-state-parser-"));

function write(rel, value) {
  const filePath = path.join(tmp, rel);
  fs.mkdirSync(path.dirname(filePath), { recursive: true });
  fs.writeFileSync(filePath, typeof value === "string" ? value : JSON.stringify(value, null, 2));
  return filePath;
}

function assertThrows(fn, pattern, label) {
  try {
    fn();
  } catch (error) {
    if (pattern.test(error.message)) return;
    throw new Error(`${label} threw wrong error: ${error.message}`);
  }
  throw new Error(`${label} did not throw`);
}

try {
  const activeRun = write("docs/ai/ACEF_ACTIVE_RUN.json", {
    runId: "RUN-1",
    repo: "demo",
    lane: "full-bmad",
    status: "active",
    activeStory: "Story 5.2",
    activePhase: "developer",
    ledgerPath: "docs/ai/ACEF_demo_DELIVERY_AUDIT.md",
  });
  if (parseActiveRun(activeRun).activeStory !== "Story 5.2") throw new Error("active run parse failed");

  const actor = write("docs/ai/actors/dev-1.json", {
    actorInstanceId: "dev-1",
    story: "Story 5.2",
    phase: "development",
    role: "developer",
    client: "codex",
    inputCommit: "abc123",
    allowedContextProfile: "developer",
  });
  if (parseActorRecord(actor).role !== "developer") throw new Error("actor parse failed");

  const evidence = write("docs/ai/evidence/EV-1.json", {
    evidenceId: "EV-1",
    kind: "runtime-test",
    command: "php artisan test",
    exitCode: 0,
    repositoryCommit: "abc123",
    dirtyDigest: null,
    actorInstanceId: "dev-1",
    story: "Story 5.2",
    rawArtifact: { path: "docs/ai/evidence/raw/EV-1.log", sha256: "sha256-demo" },
    runnerProof: {
      schema: "acef-evidence-runner-proof-v1",
      runner: "acef-state evidence-run",
      sha256: "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
    },
    satisfies: ["AC-5.2.1"],
  });
  if (parseEvidenceManifest(evidence).exitCode !== 0) throw new Error("evidence parse failed");

  const gate = write("docs/ai/gates/story-5-2.json", {
    gateId: "story-5-2-process-judge",
    scope: "Story 5.2",
    verdict: "PASS",
    decidedBy: "judge-1",
    repositoryCommit: "abc123",
    evidenceIds: ["EV-1"],
  });
  if (parseGateVerdict(gate).verdict !== "PASS") throw new Error("gate parse failed");

  const approval = write("docs/ai/approvals/APP-1.json", {
    approvalId: "APP-1",
    decision: "APPROVE",
    scope: "epic-transition:5->6",
    actorType: "human",
    userQuote: "Start Epic 6",
    statementHash: "sha256-demo",
    repositoryCommit: "abc123",
  });
  if (parseApproval(approval).scope !== "epic-transition:5->6") throw new Error("approval parse failed");

  const workerScope = write("docs/ai/ACEF_ACTIVE_WORKER_SCOPE.json", {
    activeStory: "Story 5.2",
    phase: "development",
    workerId: "dev-1",
    allowedPaths: ["app/**", "tests/**"],
    baseRef: "abc123",
    maxCommits: 1,
    canEditLedger: false,
    canSpawnAgents: false,
  });
  if (parseWorkerScope(workerScope).workerId !== "dev-1") throw new Error("worker scope parse failed");
  const workflow = write("workflows/lightweight-review.yaml", [
    "workflow: lightweight-review",
    "version: 1",
    "nodes:",
    "  - id: implement",
    "    type: agent",
    "    role: developer",
    "    inputs:",
    "      - docs/ai/ACEF_CURRENT_CONTEXT.md",
    "    outputs:",
    "      - docs/ai/reports/dev.md",
    "  - id: test",
    "    type: command",
    "    command: npm test",
    "    requires:",
    "      - implement",
    "    inputs:",
    "      - docs/ai/reports/dev.md",
    "    outputs:",
    "      - docs/ai/evidence/test.json",
  ].join("\n"));
  if (parseWorkflow(workflow).nodes.length !== 2) throw new Error("workflow parse failed");
  const unsafeScope = { ...JSON.parse(fs.readFileSync(workerScope, "utf8")), allowedPaths: ["../outside/**"] };
  write("unsafe-scope.json", unsafeScope);
  assertThrows(() => parseWorkerScope(path.join(tmp, "unsafe-scope.json")), /repo-relative/, "unsafe worker scope");
  if (parseFreshness({ commit: "abc123", verifiedAt: "2026-06-23T00:00:00Z", scope: "app/**" }).commit !== "abc123") {
    throw new Error("freshness parse failed");
  }

  write("bad-active.json", { runId: "RUN-2" });
  assertThrows(() => parseActiveRun(path.join(tmp, "bad-active.json")), /missing required field/, "bad active run");
  write("bad-evidence.json", {
    evidenceId: "EV-2",
    kind: "runtime-test",
    command: "npm test",
    exitCode: "0",
    repositoryCommit: "abc123",
    dirtyDigest: null,
    actorInstanceId: "dev-1",
    story: "Story 5.2",
    rawArtifact: { path: "raw.log", sha256: "demo" },
    runnerProof: {
      schema: "acef-evidence-runner-proof-v1",
      runner: "acef-state evidence-run",
      sha256: "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
    },
    satisfies: ["AC-1"],
  });
  assertThrows(() => parseEvidenceManifest(path.join(tmp, "bad-evidence.json")), /integer exitCode/, "bad evidence");
  assertThrows(() => safeRelative(path.join(tmp, "..", "escape.json"), tmp), /escapes root/, "safeRelative");

  console.log("acef-state-parser tests passed");
} finally {
  fs.rmSync(tmp, { recursive: true, force: true });
}
