#!/usr/bin/env node
const assert = require("node:assert/strict");
const fs = require("node:fs");
const os = require("node:os");
const path = require("node:path");
const cp = require("node:child_process");
const crypto = require("node:crypto");

const acefRoot = path.resolve(__dirname, "..");
const validator = path.join(acefRoot, "scripts", "acef-process-validator");
const tmpRoot = fs.mkdtempSync(path.join(os.tmpdir(), "acef-lightweight-"));

const steps = [
  "preflight-current-context",
  "reuse-before-create",
  "implementation",
  "independent-review",
  "focused-verification",
  "closeout-evidence",
];

function run(repo, check = "lightweight-lifecycle") {
  return cp.spawnSync(process.execPath, [validator, "--repo", repo, "--check", check], {
    cwd: repo,
    encoding: "utf8",
    stdio: ["ignore", "pipe", "pipe"],
  });
}

function write(repo, filePath, text) {
  const absolute = path.join(repo, filePath);
  fs.mkdirSync(path.dirname(absolute), { recursive: true });
  fs.writeFileSync(absolute, text);
}

function sha256(value) {
  return crypto.createHash("sha256").update(value).digest("hex");
}

function surfaceArtifact(command, exitCode, body) {
  return [
    `command: ${command}`,
    "started_at: 2026-06-25T00:00:00.000Z",
    "finished_at: 2026-06-25T00:00:01.000Z",
    `exit_code: ${exitCode}`,
    "",
    "--- stdout ---",
    body,
    "--- stderr ---",
    "",
  ].join("\n");
}

function lightweightSurfaceProof(entry, artifactText) {
  return {
    schema: "acef-lightweight-surface-proof-v1",
    runner: "acef-lightweight-surface-evidence",
    sha256: sha256(JSON.stringify({
      schema: "acef-lightweight-surface-proof-v1",
      runner: "acef-lightweight-surface-evidence",
      surface: entry.surface,
      evidencePath: entry.evidencePath,
      command: entry.command,
      exitCode: entry.exitCode,
      artifactSha256: sha256(artifactText),
    })),
  };
}

function quickFixEvidence(overrides = {}) {
  return {
    intent: "Fix API 500 for missing optional field.",
    scope: "API handler, regression test, and local fixture envelope.",
    envelope: {
      source: "computed",
      implementationPaths: ["src/api/handler.ts"],
      testPaths: ["tests/api/handler.test.ts"],
      fixturePaths: ["tests/fixtures/api.json"],
      smokePaths: [],
      sharedResources: ["api:handler"],
    },
    testIntegrity: [
      {
        testPath: "tests/api/handler.test.ts",
        implementationReference: "src/api/handler.ts#handleRequest",
        beforeAssertionCount: 1,
        afterAssertionCount: 1,
        forbiddenPatternsAdded: false,
        matcherLoosening: false,
        evidencePath: "docs/ai/evidence/test-integrity.txt",
      },
    ],
    reproEvidencePath: "docs/ai/evidence/repro.txt",
    beforePatchEvidencePath: "docs/ai/evidence/before-patch.txt",
    afterPatchEvidencePath: "docs/ai/evidence/after-patch.txt",
    ...overrides,
  };
}

function makeRepo(name, mutate = (record) => record) {
  const repo = path.join(tmpRoot, name);
  fs.mkdirSync(repo, { recursive: true });
  for (const step of steps) write(repo, `docs/ai/evidence/${step}.txt`, `${step}\n`);
  const surfaceEntry = {
    surface: "api",
    evidencePath: "docs/ai/evidence/api-surface.txt",
    command: "npm run test:api -- story",
    exitCode: 0,
  };
  const apiSurfaceArtifact = surfaceArtifact(surfaceEntry.command, surfaceEntry.exitCode, "api surface PASS\n");
  surfaceEntry.runnerProof = lightweightSurfaceProof(surfaceEntry, apiSurfaceArtifact);
  write(repo, surfaceEntry.evidencePath, apiSurfaceArtifact);
  write(repo, "docs/ai/evidence/repro.txt", "bug reproduced\n");
  write(repo, "docs/ai/evidence/before-patch.txt", "before patch failing\n");
  write(repo, "docs/ai/evidence/after-patch.txt", "after patch passing\n");
  write(repo, "docs/ai/evidence/test-integrity.txt", "assertions preserved; no skip/only/todo added\n");
  const record = mutate({
    runId: name,
    lane: "lightweight",
    status: "complete",
    implementationActorId: "impl-1",
    reviewActorId: "review-1",
    steps: steps.map((step) => ({
      name: step,
      status: "PASS",
      evidencePaths: [`docs/ai/evidence/${step}.txt`],
    })),
    promotion: {
      decision: "stay-lightweight",
      triggers: [],
    },
    surfaces: ["api"],
    surfaceEvidence: [surfaceEntry],
    updatedAt: "2026-06-23T00:00:00.000Z",
  });
  write(repo, "docs/ai/ACEF_LIGHTWEIGHT_RUN.json", `${JSON.stringify(record, null, 2)}\n`);
  write(repo, "docs/ai/ACEF_test_DELIVERY_AUDIT.md", [
    "# Test Delivery Audit",
    "",
    "## Lean Evidence Contract",
    "status: PASS",
    "scope: story 1.1",
    "worker_report: docs/ai/evidence/implementation.txt",
    "review_report: docs/ai/evidence/independent-review.txt",
    "process_judge_report: docs/ai/evidence/closeout-evidence.txt",
    "session_handoff_updated: yes",
    "worker_context: bounded",
    "fork_context: false",
    "raw_output_policy: artifact-only",
    "diff_policy: targeted",
    "test_output_policy: summary-only",
    "search_output_policy: summarized",
    "",
    "## Session Handoff",
    "status: ready",
    "current_step: closeout",
    "last_passed_gate: lightweight-lifecycle PASS",
    "next_allowed_step: done",
    `active_lane: ${record.lane}`,
    "active_track: standard",
    "ledger_path: docs/ai/ACEF_test_DELIVERY_AUDIT.md",
    "",
  ].join("\n"));
  return repo;
}

function initGit(repo) {
  cp.execFileSync("git", ["init"], { cwd: repo, stdio: "ignore" });
  cp.execFileSync("git", ["config", "user.email", "acef@example.invalid"], { cwd: repo, stdio: "ignore" });
  cp.execFileSync("git", ["config", "user.name", "ACEF Test"], { cwd: repo, stdio: "ignore" });
  cp.execFileSync("git", ["add", "."], { cwd: repo, stdio: "ignore" });
  cp.execFileSync("git", ["commit", "-m", "baseline"], { cwd: repo, stdio: "ignore" });
}

try {
  const green = makeRepo("green");
  const ok = run(green);
  assert.equal(ok.status, 0, ok.stderr || ok.stdout);
  assert.match(ok.stdout, /follows the compact lifecycle/);

  const wrongOrder = makeRepo("wrong-order", (record) => {
    [record.steps[1], record.steps[2]] = [record.steps[2], record.steps[1]];
    return record;
  });
  const wrongOrderResult = run(wrongOrder);
  assert.notEqual(wrongOrderResult.status, 0);
  assert.match(wrongOrderResult.stdout, /step 2 must be reuse-before-create/);

  const promotionTrigger = makeRepo("promotion-trigger", (record) => {
    record.promotion.triggers = ["touches unknown high-risk runtime boundary"];
    return record;
  });
  const triggerResult = run(promotionTrigger);
  assert.notEqual(triggerResult.status, 0);
  assert.match(triggerResult.stdout, /promotion triggers require full BMAD promotion/);

  const missingEvidence = makeRepo("missing-evidence", (record) => {
    record.steps[5].evidencePaths = ["docs/ai/evidence/missing.txt"];
    return record;
  });
  const missingResult = run(missingEvidence);
  assert.notEqual(missingResult.status, 0);
  assert.match(missingResult.stdout, /missing lifecycle evidence/);

  const missingSurfaceDeclaration = makeRepo("missing-surface-declaration", (record) => {
    delete record.surfaces;
    delete record.surfaceEvidence;
    return record;
  });
  const missingSurfaceDeclarationResult = run(missingSurfaceDeclaration);
  assert.notEqual(missingSurfaceDeclarationResult.status, 0);
  assert.match(missingSurfaceDeclarationResult.stdout, /surface declaration/);

  const missingSurfaceEvidence = makeRepo("missing-surface-evidence", (record) => {
    record.surfaceEvidence = [];
    return record;
  });
  const missingSurfaceEvidenceResult = run(missingSurfaceEvidence);
  assert.notEqual(missingSurfaceEvidenceResult.status, 0);
  assert.match(missingSurfaceEvidenceResult.stdout, /surface evidence for api/);

  const missingRunnerProof = makeRepo("missing-runner-proof", (record) => {
    delete record.surfaceEvidence[0].runnerProof;
    return record;
  });
  const missingRunnerProofResult = run(missingRunnerProof);
  assert.notEqual(missingRunnerProofResult.status, 0);
  assert.match(missingRunnerProofResult.stdout, /runnerProof/);

  const fakeRunnerArtifact = makeRepo("fake-runner-artifact");
  write(fakeRunnerArtifact, "docs/ai/evidence/api-surface.txt", "PASS but not produced by runner\n");
  const fakeRunnerArtifactResult = run(fakeRunnerArtifact);
  assert.notEqual(fakeRunnerArtifactResult.status, 0);
  assert.match(fakeRunnerArtifactResult.stdout, /runner command\/exit header|runner proof/);

  const hiddenSurface = makeRepo("hidden-surface");
  initGit(hiddenSurface);
  write(hiddenSurface, "src/components/GiftSummary.tsx", "export function GiftSummary() { return null; }\n");
  const hiddenSurfaceResult = run(hiddenSurface);
  assert.notEqual(hiddenSurfaceResult.status, 0);
  assert.match(hiddenSurfaceResult.stdout, /surface inferred from changed paths but not declared: ui/);

  const failedSurfaceEvidence = makeRepo("failed-surface-evidence", (record) => {
    record.surfaceEvidence[0].exitCode = 1;
    return record;
  });
  const failedSurfaceEvidenceResult = run(failedSurfaceEvidence);
  assert.notEqual(failedSurfaceEvidenceResult.status, 0);
  assert.match(failedSurfaceEvidenceResult.stdout, /successful surface evidence for api/);

  const quickFix = makeRepo("quick-fix", (record) => {
    record.lane = "quick-fix";
    record.quickFix = quickFixEvidence();
    return record;
  });
  const quickFixResult = run(quickFix);
  assert.equal(quickFixResult.status, 0, quickFixResult.stderr || quickFixResult.stdout);
  write(quickFix, "docs/ai/ACEF_ACTIVE_RUN.json", `${JSON.stringify({
    runId: "RUN-quick-fix",
    repo: "quick-fix",
    lane: "quick-fix",
    laneRationale: "Narrow reproduced defect with localized patch.",
    intakeDecision: {
      route: "C",
      confidence: "high",
      clarifyingQuestions: ["Is this a reproduced defect?"],
      inferredAnswers: ["The scope is localized from the fixture."],
      unresolvedQuestions: [],
      approvalRequired: false,
      executionApproved: true,
    },
    riskTriggers: ["bugfix"],
    status: "active",
    activeStory: "story 1.1",
    activePhase: "closeout",
    ledgerPath: "docs/ai/ACEF_test_DELIVERY_AUDIT.md",
  }, null, 2)}\n`);
  const quickFixSelection = run(quickFix, "lane-selection");
  assert.equal(quickFixSelection.status, 0, quickFixSelection.stderr || quickFixSelection.stdout);
  const quickFixCloseout = run(quickFix, "lane-closeout");
  assert.equal(quickFixCloseout.status, 0, quickFixCloseout.stderr || quickFixCloseout.stdout);

  const missingIntake = makeRepo("missing-intake", (record) => {
    record.lane = "quick-fix";
    record.quickFix = quickFixEvidence();
    return record;
  });
  write(missingIntake, "docs/ai/ACEF_ACTIVE_RUN.json", `${JSON.stringify({
    runId: "RUN-missing-intake",
    repo: "missing-intake",
    lane: "quick-fix",
    laneRationale: "Narrow reproduced defect with localized patch.",
    riskTriggers: ["bugfix"],
    status: "active",
    activeStory: "story 1.1",
    activePhase: "development",
    ledgerPath: "docs/ai/ACEF_test_DELIVERY_AUDIT.md",
  }, null, 2)}\n`);
  const missingIntakeSelection = run(missingIntake, "lane-selection");
  assert.notEqual(missingIntakeSelection.status, 0);
  assert.match(missingIntakeSelection.stdout, /requires recorded intakeDecision/);

  const missingBriefApproval = makeRepo("missing-brief-approval", (record) => {
    record.lane = "lightweight";
    return record;
  });
  write(missingBriefApproval, "docs/ai/ACEF_ACTIVE_RUN.json", `${JSON.stringify({
    runId: "RUN-missing-brief-approval",
    repo: "missing-brief-approval",
    lane: "full-bmad",
    laneRationale: "Raw CRM/accounting feature idea needs interview and full planning.",
    intakeDecision: {
      route: "B",
      confidence: "medium",
      clarifyingQuestions: ["Which CRM entities and accounting records are in scope?"],
      inferredAnswers: ["The request mentions CRM notes and accounting tracking."],
      unresolvedQuestions: [],
      approvalRequired: true,
      executionApproved: false,
    },
    riskTriggers: ["feature", "crm", "financial"],
    status: "active",
    activeStory: "CRM/accounting brief",
    activePhase: "planning",
    ledgerPath: "docs/ai/ACEF_test_DELIVERY_AUDIT.md",
  }, null, 2)}\n`);
  const missingBriefApprovalSelection = run(missingBriefApproval, "lane-selection");
  assert.notEqual(missingBriefApprovalSelection.status, 0);
  assert.match(missingBriefApprovalSelection.stdout, /explicit execution approval|approved interview brief/);

  const hiddenRisk = makeRepo("hidden-risk", (record) => {
    record.lane = "quick-fix";
    record.quickFix = quickFixEvidence({
      intent: "Fix reproduced auth-related defect.",
      scope: "Auth route patch.",
    });
    return record;
  });
  initGit(hiddenRisk);
  write(hiddenRisk, "src/auth/session.ts", "export const patched = true;\n");
  write(hiddenRisk, "docs/ai/ACEF_ACTIVE_RUN.json", `${JSON.stringify({
    runId: "RUN-hidden-risk",
    repo: "hidden-risk",
    lane: "quick-fix",
    laneRationale: "Narrow reproduced defect with localized patch.",
    intakeDecision: {
      route: "C",
      confidence: "high",
      clarifyingQuestions: ["Is this a reproduced defect?"],
      inferredAnswers: ["The fixture scope is localized."],
      unresolvedQuestions: [],
      approvalRequired: false,
      executionApproved: true,
    },
    riskTriggers: ["bugfix"],
    status: "active",
    activeStory: "story 1.1",
    activePhase: "closeout",
    ledgerPath: "docs/ai/ACEF_test_DELIVERY_AUDIT.md",
  }, null, 2)}\n`);
  const hiddenRiskSelection = run(hiddenRisk, "lane-selection");
  assert.notEqual(hiddenRiskSelection.status, 0);
  assert.match(hiddenRiskSelection.stdout, /risk trigger inferred from changed paths but not declared: auth/);

  const guardedMisroute = makeRepo("guarded-misroute", (record) => {
    record.lane = "quick-fix";
    record.quickFix = quickFixEvidence({
      intent: "Patch auth bypass.",
      scope: "Auth middleware.",
    });
    return record;
  });
  write(guardedMisroute, "docs/ai/ACEF_ACTIVE_RUN.json", `${JSON.stringify({
    runId: "RUN-guarded-misroute",
    repo: "guarded-misroute",
    lane: "quick-fix",
    laneRationale: "Incorrectly treated auth as quick fix.",
    intakeDecision: {
      route: "C",
      confidence: "medium",
      clarifyingQuestions: ["Is this a reproduced defect?"],
      inferredAnswers: ["Auth appears in the stated scope."],
      unresolvedQuestions: [],
      approvalRequired: true,
      executionApproved: true,
    },
    riskTriggers: ["bugfix", "auth"],
    status: "active",
    activeStory: "story 1.1",
    activePhase: "closeout",
    ledgerPath: "docs/ai/ACEF_test_DELIVERY_AUDIT.md",
  }, null, 2)}\n`);
  const guardedMisrouteResult = run(guardedMisroute, "lane-selection");
  assert.notEqual(guardedMisrouteResult.status, 0);
  assert.match(guardedMisrouteResult.stdout, /requires guarded lane/);

  const missingQuickFix = makeRepo("missing-quick-fix", (record) => {
    record.lane = "quick-fix";
    return record;
  });
  const missingQuickFixResult = run(missingQuickFix);
  assert.notEqual(missingQuickFixResult.status, 0);
  assert.match(missingQuickFixResult.stdout, /quickFix evidence|quick-fix evidence/);

  const missingAfterPatch = makeRepo("missing-after-patch", (record) => {
    record.lane = "quick-fix";
    record.quickFix = quickFixEvidence({
      afterPatchEvidencePath: "docs/ai/evidence/missing-after-patch.txt",
    });
    return record;
  });
  const missingAfterPatchResult = run(missingAfterPatch);
  assert.notEqual(missingAfterPatchResult.status, 0);
  assert.match(missingAfterPatchResult.stdout, /afterPatchEvidencePath/);

  const testOutsideEnvelope = makeRepo("test-outside-envelope", (record) => {
    record.lane = "quick-fix";
    record.quickFix = quickFixEvidence({
      envelope: {
        source: "computed",
        implementationPaths: ["src/api/handler.ts"],
        testPaths: ["tests/api/other.test.ts"],
        sharedResources: ["api:handler"],
      },
      testIntegrity: [],
    });
    return record;
  });
  initGit(testOutsideEnvelope);
  write(testOutsideEnvelope, "tests/api/handler.test.ts", [
    "import { handleRequest } from '../../src/api/handler';",
    "test('handles missing optional field', () => {",
    "  expect(handleRequest({})).toEqual({ ok: true });",
    "});",
    "",
  ].join("\n"));
  const testOutsideEnvelopeResult = run(testOutsideEnvelope);
  assert.notEqual(testOutsideEnvelopeResult.status, 0);
  assert.match(testOutsideEnvelopeResult.stdout, /test outside envelope/);

  const guttedTest = makeRepo("gutted-test", (record) => {
    record.lane = "quick-fix";
    record.quickFix = quickFixEvidence();
    return record;
  });
  write(guttedTest, "tests/api/handler.test.ts", [
    "import { handleRequest } from '../../src/api/handler';",
    "test('handles missing optional field', () => {",
    "  expect(handleRequest({})).toEqual({ ok: true });",
    "});",
    "",
  ].join("\n"));
  initGit(guttedTest);
  write(guttedTest, "tests/api/handler.test.ts", [
    "import { handleRequest } from '../../src/api/handler';",
    "test.skip('handles missing optional field', () => {",
    "  handleRequest({});",
    "});",
    "",
  ].join("\n"));
  const guttedTestResult = run(guttedTest);
  assert.notEqual(guttedTestResult.status, 0);
  assert.match(guttedTestResult.stdout, /skip\/only\/todo|assertion count appears to drop/);

  const sameActor = makeRepo("same-actor", (record) => {
    record.reviewActorId = record.implementationActorId;
    return record;
  });
  const sameActorResult = run(sameActor);
  assert.notEqual(sameActorResult.status, 0);
  assert.match(sameActorResult.stdout, /independent review actor/);

  console.log("acef lightweight lifecycle tests passed");
} finally {
  fs.rmSync(tmpRoot, { recursive: true, force: true });
}
