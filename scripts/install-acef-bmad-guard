#!/usr/bin/env node
const fs = require("node:fs");
const path = require("node:path");
const { writeInstallationManifest } = require("./lib/acef-installation");

const repoRoot = path.resolve(__dirname, "..");
const sourceHook = path.join(repoRoot, "claude-plugins", "acef-bmad-guard", "hooks", "acef-bmad-hard-wall.mjs");
const sourceDispatcher = path.join(repoRoot, "claude-plugins", "acef-bmad-guard", "hooks", "acef-bmad-dispatcher.mjs");
const sourceOpenCodePlugin = path.join(repoRoot, "opencode-plugins", "acef-bmad-guard", "acef-bmad-hard-wall.js");
const sourcePrecommitGate = path.join(repoRoot, "claude-plugins", "acef-bmad-guard", "hooks", "acef-precommit-gate.sh");
const home = process.env.HOME;

function usage() {
  console.log(`Usage: scripts/install-acef-bmad-guard [--repo <path>] [--global-dispatcher]

Default installs the full ACEF guard engine locally into the target repo:
  <repo>/.acef/hooks/acef-bmad-hard-wall.mjs
  <repo>/.opencode/plugins/acef-bmad-hard-wall.js

Use --global-dispatcher once per machine for Claude/Codex/OpenCode surfaces that need a user-level hook entry.
The dispatcher is tiny: it only forwards to a repo-local .acef/hooks/acef-bmad-hard-wall.mjs when one exists.`);
}

function parseArgs(argv) {
  const opts = {
    repo: process.cwd(),
    globalDispatcher: false,
  };
  for (let i = 0; i < argv.length; i += 1) {
    const arg = argv[i];
    if (arg === "--repo" || arg === "--target") {
      opts.repo = argv[++i];
    } else if (arg === "--global-dispatcher") {
      opts.globalDispatcher = true;
    } else if (arg === "-h" || arg === "--help") {
      usage();
      process.exit(0);
    } else {
      throw new Error(`Unknown argument: ${arg}`);
    }
  }
  opts.repo = path.resolve(opts.repo);
  return opts;
}

function assertFile(filePath) {
  if (!fs.existsSync(filePath)) {
    throw new Error(`Source not found: ${filePath}`);
  }
}

function backupIfExists(filePath) {
  if (!fs.existsSync(filePath)) return;
  const stamp = new Date().toISOString().replace(/[:.]/g, "-");
  fs.copyFileSync(filePath, `${filePath}.bak-${stamp}`);
}

function readJsonFile(filePath) {
  if (!fs.existsSync(filePath)) return {};
  const raw = fs.readFileSync(filePath, "utf8").trim();
  return raw ? JSON.parse(raw) : {};
}

function ensurePreToolUseHook(config, entry, commandNeedles) {
  const needles = Array.isArray(commandNeedles) ? commandNeedles : [commandNeedles];
  config.hooks = config.hooks && typeof config.hooks === "object" ? config.hooks : {};
  config.hooks.PreToolUse = Array.isArray(config.hooks.PreToolUse) ? config.hooks.PreToolUse : [];

  config.hooks.PreToolUse = config.hooks.PreToolUse.filter((existing) => {
    const hooks = Array.isArray(existing?.hooks) ? existing.hooks : [];
    return !hooks.some((hook) => typeof hook?.command === "string" && needles.some((needle) => hook.command.includes(needle)));
  });

  config.hooks.PreToolUse.push(entry);
  return config;
}

function copyFile(source, target) {
  fs.mkdirSync(path.dirname(target), { recursive: true });
  fs.copyFileSync(source, target);
}

function installLocal(targetRepo) {
  const localHook = path.join(targetRepo, ".acef", "hooks", "acef-bmad-hard-wall.mjs");
  const localOpenCodePlugin = path.join(targetRepo, ".opencode", "plugins", "acef-bmad-hard-wall.js");
  copyFile(sourceHook, localHook);
  copyFile(sourceOpenCodePlugin, localOpenCodePlugin);
  console.log(`Installed local ACEF guard engine: ${localHook}`);
  console.log(`Installed local OpenCode plugin: ${localOpenCodePlugin}`);
  installGitPrecommitGate(targetRepo);
}

// Install a git pre-commit hook that runs the ACEF lean-evidence check before
// every commit.  The hook is a no-op when no ACEF delivery session is active
// (ACEF_ACTIVE_RUN.json absent), so it is safe in non-ACEF repos too.
//
// If .git/hooks/pre-commit already exists and does not yet reference the gate,
// a one-line call is appended so we compose rather than clobber.
function installGitPrecommitGate(targetRepo) {
  // The gate script itself goes into .acef/hooks/ (alongside the bmad wall)
  // so it stays out of .git/ (which is not committed).  The git hook only
  // needs to call it.
  const gateTarget = path.join(targetRepo, ".acef", "hooks", "acef-precommit-gate.sh");
  copyFile(sourcePrecommitGate, gateTarget);
  fs.chmodSync(gateTarget, 0o755);
  console.log(`Installed ACEF pre-commit gate: ${gateTarget}`);

  const gitHooksDir = path.join(targetRepo, ".git", "hooks");
  if (!fs.existsSync(gitHooksDir)) {
    // Not a git repo or the .git dir is elsewhere; skip hook wiring silently.
    console.log("Skipped .git/hooks wiring: .git/hooks not found (not a git repo or detached worktree).");
    return;
  }

  const precommitPath = path.join(gitHooksDir, "pre-commit");
  // Double-quote the command substitution so $(...) expands; a single-quoted
  // path is taken literally, never matches `-x`, and (as the wrapper's last
  // command) makes it exit 1 on every commit — forcing --no-verify. The if-form
  // also keeps a missing gate from blocking commits while a failing gate still blocks.
  const dispatchCall = `\n# ACEF closeout gate (installed by install-acef-bmad-guard)\nACEF_GATE="$(git rev-parse --show-toplevel)/.acef/hooks/acef-precommit-gate.sh"\nif [ -x "$ACEF_GATE" ]; then "$ACEF_GATE"; fi\n`;

  if (fs.existsSync(precommitPath)) {
    const existing = fs.readFileSync(precommitPath, "utf8");
    if (existing.includes("acef-precommit-gate.sh")) {
      console.log("ACEF pre-commit gate already referenced in .git/hooks/pre-commit; skipped.");
      return;
    }
    // Append rather than clobber an existing pre-commit hook.
    fs.appendFileSync(precommitPath, dispatchCall);
    console.log(`Appended ACEF gate call to existing .git/hooks/pre-commit: ${precommitPath}`);
  } else {
    fs.writeFileSync(precommitPath, `#!/usr/bin/env sh\nset -e\n${dispatchCall}`);
    fs.chmodSync(precommitPath, 0o755);
    console.log(`Created .git/hooks/pre-commit with ACEF gate: ${precommitPath}`);
  }
}

function installGlobalDispatchers() {
  if (!home) {
    throw new Error("HOME is not set; cannot locate user hook directories.");
  }

  const claudeDir = path.join(home, ".claude");
  const claudeHooksDir = path.join(claudeDir, "hooks");
  const settingsPath = path.join(claudeDir, "settings.json");
  const claudeDispatcher = path.join(claudeHooksDir, "acef-bmad-dispatcher.mjs");
  copyFile(sourceDispatcher, claudeDispatcher);

  let settings = {};
  if (fs.existsSync(settingsPath)) {
    settings = readJsonFile(settingsPath);
    backupIfExists(settingsPath);
  }
  ensurePreToolUseHook(settings, {
    matcher: "Read|Write|Edit|MultiEdit|NotebookEdit|Bash",
    hooks: [
      {
        type: "command",
        command: "node ~/.claude/hooks/acef-bmad-dispatcher.mjs",
        timeout: 5,
      },
    ],
  }, ["acef-bmad-dispatcher.mjs", "acef-bmad-hard-wall.mjs"]);
  fs.mkdirSync(claudeDir, { recursive: true });
  fs.writeFileSync(settingsPath, `${JSON.stringify(settings, null, 2)}\n`);

  const codexDir = path.join(home, ".codex");
  const codexHooksDir = path.join(codexDir, "hooks");
  const codexHooksPath = path.join(codexDir, "hooks.json");
  const codexDispatcher = path.join(codexHooksDir, "acef-bmad-dispatcher.mjs");
  copyFile(sourceDispatcher, codexDispatcher);

  let codexHooks = {};
  if (fs.existsSync(codexHooksPath)) {
    codexHooks = readJsonFile(codexHooksPath);
    backupIfExists(codexHooksPath);
  }
  ensurePreToolUseHook(codexHooks, {
    matcher: "local_shell|shell|shell_command|exec_command|Bash|Shell|apply_patch|Edit|Write|MultiEdit|Read|grep_files|ctx_execute|ctx_execute_file|ctx_batch_execute|ctx_fetch_and_index|ctx_search|ctx_index|mcp__",
    hooks: [
      {
        type: "command",
        command: "node ~/.codex/hooks/acef-bmad-dispatcher.mjs",
      },
    ],
  }, ["acef-bmad-dispatcher.mjs", "acef-bmad-hard-wall.mjs"]);
  fs.mkdirSync(codexDir, { recursive: true });
  fs.writeFileSync(codexHooksPath, `${JSON.stringify(codexHooks, null, 2)}\n`);

  const opencodePluginsDir = path.join(home, ".config", "opencode", "plugins");
  const opencodeTargetPlugin = path.join(opencodePluginsDir, "acef-bmad-hard-wall.js");
  const opencodeTargetHook = path.join(opencodePluginsDir, "acef-bmad-hard-wall.mjs");
  if (fs.existsSync(opencodeTargetPlugin)) backupIfExists(opencodeTargetPlugin);
  if (fs.existsSync(opencodeTargetHook)) {
    backupIfExists(opencodeTargetHook);
    fs.rmSync(opencodeTargetHook);
  }
  copyFile(sourceOpenCodePlugin, opencodeTargetPlugin);

  console.log(`Installed Claude dispatcher: ${claudeDispatcher}`);
  console.log(`Updated Claude settings: ${settingsPath}`);
  console.log(`Installed Codex dispatcher: ${codexDispatcher}`);
  console.log(`Updated Codex hooks: ${codexHooksPath}`);
  console.log(`Installed OpenCode dispatcher plugin: ${opencodeTargetPlugin}`);
  console.log("Restart Claude Code / Codex / OpenCode for global dispatcher changes to load.");
}

assertFile(sourceHook);
assertFile(sourceDispatcher);
assertFile(sourceOpenCodePlugin);
assertFile(sourcePrecommitGate);

const opts = parseArgs(process.argv.slice(2));
installLocal(opts.repo);
console.log(`Updated ACEF installation manifest: ${writeInstallationManifest(opts.repo, repoRoot, "bmadGuard", {
  localHook: true,
  localOpenCodePlugin: true,
  globalDispatcher: opts.globalDispatcher,
})}`);
if (opts.globalDispatcher) {
  installGlobalDispatchers();
} else {
  console.log("Global dispatchers were not installed. Add --global-dispatcher once per machine if your tool needs a user-level hook entry.");
}
