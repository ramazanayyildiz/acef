{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://acef.local/schemas/pr-review-profile.schema.json",
  "title": "ACEF Codemap PR Review Profile",
  "type": "object",
  "required": ["profileId", "reviewId", "generatedAt", "baseCommit", "headCommit", "changedFiles", "selectedPaths", "workShapes", "genericRulesSupplementOnly", "source", "adapterSignals", "selectedPatterns", "globalDoNotCopy"],
  "additionalProperties": false,
  "properties": {
    "profileId": { "type": "string", "minLength": 1 },
    "reviewId": { "type": "string", "minLength": 1 },
    "generatedAt": { "type": "string", "minLength": 1 },
    "baseCommit": { "type": "string", "minLength": 7 },
    "headCommit": { "type": "string", "minLength": 7 },
    "changedFiles": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "selectedPaths": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "workShapes": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "genericRulesSupplementOnly": { "const": true },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["adapter", "patternRegistry"],
      "properties": {
        "adapter": { "$ref": "#/$defs/shaArtifact" },
        "patternRegistry": {
          "allOf": [{ "$ref": "#/$defs/shaArtifact" }],
          "type": "object",
          "required": ["path", "sha256", "status", "generatedAt", "generatedFromCommit", "coveredScopes"],
          "properties": {
            "path": { "type": "string", "minLength": 1 },
            "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "status": { "type": "string", "enum": ["READY", "PARTIAL"] },
            "generatedAt": { "type": ["string", "null"] },
            "generatedFromCommit": { "type": ["string", "null"] },
            "coveredScopes": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "adapterSignals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["line", "text"],
        "properties": {
          "line": { "type": "integer", "minimum": 1 },
          "text": { "type": "string", "minLength": 1 }
        }
      }
    },
    "selectedPatterns": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/pattern" }
    },
    "globalDoNotCopy": {
      "type": "array",
      "items": { "$ref": "#/$defs/doNotCopy" }
    }
  },
  "$defs": {
    "shaArtifact": {
      "type": "object",
      "additionalProperties": true,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "sourceEvidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 },
        "symbol": { "type": "string" },
        "why": { "type": "string" }
      }
    },
    "pattern": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "workShape", "status", "maturity", "enforcedBy", "summary", "evidence", "completionEvidence", "sourceEvidence", "goldenNeighbors", "reuseProbe", "doNotCopy", "confidence", "lastVerifiedAt", "lastVerifiedCommit", "refreshTriggers"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "workShape": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "minLength": 1 },
        "maturity": { "type": "string", "minLength": 1 },
        "enforcedBy": { "type": ["string", "null"] },
        "summary": { "type": "string" },
        "evidence": { "type": "string" },
        "completionEvidence": {
          "type": "object",
          "additionalProperties": false,
          "required": ["structure", "registration", "discoverability", "runtime"],
          "properties": {
            "structure": { "type": "string", "minLength": 1 },
            "registration": { "type": "string", "minLength": 1 },
            "discoverability": { "type": "string", "minLength": 1 },
            "runtime": { "type": "string", "minLength": 1 }
          }
        },
        "sourceEvidence": { "type": "array", "items": { "$ref": "#/$defs/sourceEvidence" } },
        "goldenNeighbors": { "type": "array", "items": { "$ref": "#/$defs/sourceEvidence" } },
        "reuseProbe": { "type": "array", "items": { "type": "string" } },
        "doNotCopy": { "type": "array", "items": { "type": "string" } },
        "confidence": { "type": "string" },
        "lastVerifiedAt": { "type": "string" },
        "lastVerifiedCommit": { "type": "string" },
        "refreshTriggers": { "type": "array", "items": { "type": "string" } }
      }
    },
    "doNotCopy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "reason", "sourceEvidence", "lastVerifiedCommit"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "sourceEvidence": { "type": "array", "items": { "$ref": "#/$defs/sourceEvidence" } },
        "lastVerifiedCommit": { "type": "string", "minLength": 1 }
      }
    }
  }
}
