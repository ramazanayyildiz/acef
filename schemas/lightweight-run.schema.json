{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://acef.local/schemas/lightweight-run.schema.json",
  "title": "ACEF Lightweight Lifecycle",
  "type": "object",
  "required": ["runId", "lane", "status", "implementationActorId", "reviewActorId", "steps", "promotion"],
  "additionalProperties": false,
  "properties": {
    "runId": { "type": "string", "minLength": 1 },
    "lane": { "type": "string", "enum": ["quick-fix", "lightweight", "guarded"] },
    "status": { "type": "string", "enum": ["active", "blocked", "complete"] },
    "implementationActorId": { "type": "string", "minLength": 1 },
    "reviewActorId": { "type": "string", "minLength": 1 },
    "steps": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status", "evidencePaths"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["PENDING", "PASS", "BLOCKED"] },
          "evidencePaths": { "type": "array", "items": { "type": "string", "minLength": 1 } }
        }
      }
    },
    "promotion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision", "triggers"],
      "properties": {
        "decision": { "type": "string", "enum": ["stay-lightweight", "promote-full-bmad", "human-risk-acceptance"] },
        "triggers": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "surfaces": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["ui", "admin", "mobile", "api", "http", "cli", "queue", "job", "scheduler", "storage", "email", "notification", "webhook", "integration", "config", "database", "library", "internal"]
      }
    },
    "surfaceEvidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["surface", "evidencePath", "command", "exitCode", "runnerProof"],
        "properties": {
          "surface": {
            "type": "string",
            "enum": ["ui", "admin", "mobile", "api", "http", "cli", "queue", "job", "scheduler", "storage", "email", "notification", "webhook", "integration", "config", "database", "library", "internal"]
          },
          "evidencePath": { "type": "string", "minLength": 1 },
          "command": { "type": "string" },
          "exitCode": { "type": "integer" },
          "runnerProof": {
            "type": "object",
            "additionalProperties": false,
            "required": ["schema", "runner", "sha256"],
            "properties": {
              "schema": { "type": "string", "const": "acef-lightweight-surface-proof-v1" },
              "runner": { "type": "string", "minLength": 1 },
              "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
            }
          },
          "notes": { "type": "string" }
        }
      }
    },
    "quickFix": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intent", "scope", "reproEvidencePath", "beforePatchEvidencePath", "afterPatchEvidencePath"],
      "properties": {
        "intent": { "type": "string", "minLength": 1 },
        "scope": { "type": "string", "minLength": 1 },
        "reproEvidencePath": { "type": "string", "minLength": 1 },
        "beforePatchEvidencePath": { "type": "string", "minLength": 1 },
        "afterPatchEvidencePath": { "type": "string", "minLength": 1 },
        "deferredWorkPath": { "type": "string", "minLength": 1 },
        "notes": { "type": "string" }
      }
    },
    "updatedAt": { "type": ["string", "null"] }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "lane": { "const": "quick-fix" },
          "status": { "const": "complete" }
        }
      },
      "then": {
        "required": ["quickFix"]
      }
    }
  ]
}
