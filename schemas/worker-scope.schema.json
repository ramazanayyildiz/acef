{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://acef.local/schemas/worker-scope.schema.json",
  "title": "ACEF Worker Scope",
  "type": "object",
  "additionalProperties": false,
  "required": ["activeStory", "phase", "workerId", "allowedPaths", "baseRef", "maxCommits", "canEditLedger", "canSpawnAgents"],
  "properties": {
    "activeStory": { "type": "string", "minLength": 1 },
    "phase": { "type": "string", "minLength": 1 },
    "workerId": { "type": "string", "minLength": 1 },
    "allowedPaths": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "surfaces": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["ui", "admin", "mobile", "api", "http", "cli", "queue", "job", "scheduler", "storage", "email", "notification", "webhook", "integration", "config", "database", "library", "internal"]
      }
    },
    "patternUse": { "type": "string", "enum": ["new-reusable-pattern", "reuse-existing-pattern", "one-off", "unknown"] },
    "requiresRoundTrip": { "type": "boolean" },
    "inputOutputBindings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["inputSurface", "outputSurface", "field"],
        "properties": {
          "inputSurface": {
            "type": "string",
            "enum": ["ui", "admin", "mobile", "api", "http", "cli", "queue", "job", "scheduler", "storage", "email", "notification", "webhook", "integration", "config", "database", "library", "internal"]
          },
          "outputSurface": {
            "type": "string",
            "enum": ["ui", "admin", "mobile", "api", "http", "cli", "queue", "job", "scheduler", "storage", "email", "notification", "webhook", "integration", "config", "database", "library", "internal"]
          },
          "field": { "type": "string", "minLength": 1 },
          "defaultMaskingRisk": { "type": "boolean" }
        }
      }
    },
    "baseRef": { "type": "string", "minLength": 1 },
    "maxCommits": { "type": "integer", "minimum": 1 },
    "canEditLedger": { "const": false },
    "canSpawnAgents": { "const": false },
    "createdAt": { "type": ["string", "null"] }
  }
}
