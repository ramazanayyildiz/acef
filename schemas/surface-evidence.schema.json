{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://acef.local/schemas/surface-evidence.schema.json",
  "title": "ACEF Surface Evidence Record",
  "description": "Input to scripts/acef-closeout-verify. Carries the goal surface set, the story's touched surfaces, the per-surface adapter status, and the evidence (recorded or executable) that backs each touched surface.",
  "type": "object",
  "required": ["schema", "goal", "story", "adapter"],
  "additionalProperties": false,
  "properties": {
    "schema": { "type": "string", "const": "acef.surface-evidence.v1" },
    "goal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "surfaceSet"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "surfaceSet": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "story": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "touchedSurfaces"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "goalId": { "type": "string", "minLength": 1 },
        "touchedSurfaces": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fingerprint", "surfaces"],
      "properties": {
        "fingerprint": { "type": ["string", "null"], "description": "Witness fingerprint the adapter was built from; drift if it differs from the current repo." },
        "surfaces": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": ["status"],
            "properties": {
              "status": {
                "type": "string",
                "enum": ["grounded", "provisional", "deferred", "aspirational", "unknown", "waived"]
              },
              "staleDoc": { "type": "boolean" },
              "needsReWitness": { "type": "boolean" },
              "reason": { "type": "string" }
            }
          }
        }
      }
    },
    "witnessFingerprint": {
      "type": ["string", "null"],
      "description": "Current repo witness fingerprint at evidence-collection time. May be recomputed by the verifier via --repo; a mismatch with adapter.fingerprint refuses closeout."
    },
    "intake": {
      "type": "object",
      "additionalProperties": false,
      "description": "Eventual-product wishes are parked here and never enter the active surface set or generate evidence (anti-self-fulfilling).",
      "properties": {
        "surfaceSet": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "assumptions": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "unknowns": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "deferred": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "surfaceRegistry": {
      "type": "object",
      "description": "Open registry extension: a repo adapter may register new surface types at verify time.",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["requiredEvidence"],
        "properties": {
          "requiredEvidence": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "evidence": {
      "type": "object",
      "description": "Map of evidence-kind -> result. 'fresh-read' and 'reachability' MUST be executable specs (proven by execution, not a recorded boolean).",
      "additionalProperties": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "description": "Recorded result evidence.",
            "properties": {
              "pass": { "type": "boolean" },
              "status": { "type": "string", "enum": ["pass", "partial", "fail"] },
              "label": { "type": "string" }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "description": "Cold-process fresh-read spec (persistence).",
            "required": ["writeCmd", "readCmd", "key", "value"],
            "properties": {
              "writeCmd": { "type": "string", "minLength": 1 },
              "readCmd": { "type": "string", "minLength": 1 },
              "key": { "type": "string", "minLength": 1 },
              "value": { "type": "string" }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "description": "Reachability spec.",
            "required": ["entrypoints", "featureModule", "graph"],
            "properties": {
              "entrypoints": { "type": "array", "items": { "type": "string", "minLength": 1 } },
              "featureModule": { "type": "string", "minLength": 1 },
              "graph": {
                "type": "object",
                "additionalProperties": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        ]
      }
    },
    "waivers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["surface", "reason", "signedBy", "version"],
        "properties": {
          "surface": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 },
          "signedBy": { "type": "string", "minLength": 1 },
          "version": { "type": "integer" },
          "createdAt": { "type": ["string", "null"] }
        }
      }
    }
  }
}
