{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://acef.local/schemas/actor.schema.json",
  "title": "ACEF Actor Record",
  "type": "object",
  "required": ["actorInstanceId", "story", "phase", "role", "client", "inputCommit", "allowedContextProfile"],
  "additionalProperties": false,
  "properties": {
    "actorInstanceId": { "type": "string", "minLength": 1 },
    "story": { "type": "string", "minLength": 1 },
    "phase": { "type": "string", "minLength": 1 },
    "role": { "type": "string", "minLength": 1 },
    "client": { "type": "string", "minLength": 1 },
    "model": { "type": ["string", "null"] },
    "sessionId": { "type": ["string", "null"] },
    "parentSessionId": { "type": ["string", "null"] },
    "promptArtifactHash": { "type": ["string", "null"] },
    "inputCommit": { "type": "string", "minLength": 1 },
    "inputTree": { "type": ["string", "null"] },
    "allowedContextProfile": { "type": "string", "minLength": 1 },
    "producedArtifactHash": { "type": ["string", "null"] },
    "createdAt": { "type": ["string", "null"] }
  }
}
