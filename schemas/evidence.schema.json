{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://acef.local/schemas/evidence.schema.json",
  "title": "ACEF Evidence Manifest",
  "type": "object",
  "required": ["evidenceId", "kind", "command", "exitCode", "repositoryCommit", "dirtyDigest", "actorInstanceId", "story", "rawArtifact", "satisfies"],
  "additionalProperties": false,
  "properties": {
    "evidenceId": { "type": "string", "minLength": 1 },
    "kind": { "type": "string", "enum": ["runtime-test", "static-check", "manual-smoke", "build", "lint", "typecheck", "other"] },
    "command": { "type": "string", "minLength": 1 },
    "exitCode": { "type": "integer" },
    "startedAt": { "type": ["string", "null"] },
    "finishedAt": { "type": ["string", "null"] },
    "repositoryCommit": { "type": "string", "minLength": 1 },
    "repositoryTree": { "type": ["string", "null"] },
    "dirtyDigest": { "type": ["string", "null"] },
    "actorInstanceId": { "type": "string", "minLength": 1 },
    "story": { "type": "string", "minLength": 1 },
    "environmentDigest": { "type": ["string", "null"] },
    "rawArtifact": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "minLength": 1 }
      },
      "required": ["path", "sha256"]
    },
    "satisfies": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
