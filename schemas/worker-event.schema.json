{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://acef.local/schemas/worker-event.schema.json",
  "title": "ACEF Worker Event",
  "type": "object",
  "required": ["eventId", "taskId", "workerId", "type", "createdAt", "summary"],
  "additionalProperties": false,
  "properties": {
    "eventId": { "type": "string", "minLength": 1 },
    "taskId": { "type": "string", "minLength": 1 },
    "workerId": { "type": "string", "minLength": 1 },
    "type": {
      "type": "string",
      "enum": ["dispatched", "started", "tool_call", "artifact_written", "completed", "failed", "cancelled"]
    },
    "createdAt": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "artifact": {
      "type": ["object", "null"],
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "usageDelta": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "runtimeMs": { "type": "number", "minimum": 0 },
        "toolCalls": { "type": "integer", "minimum": 0 },
        "tokens": { "type": "integer", "minimum": 0 },
        "costUsd": { "type": "number", "minimum": 0 }
      }
    }
  }
}
